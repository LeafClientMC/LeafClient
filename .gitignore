# ==================================================================
# Vendored third-party library noise
# (We re-vendor CmlLib / XboxAuthNet — keep their .cs but kill
# their docs/CI/test/example noise that bloats the repo.)
# ==================================================================
src/CmlLib.Core-master/**/.gitpod.yml
src/CmlLib.Core-master/**/.github/
src/CmlLib.Core-master/**/docs/
src/CmlLib.Core-master/**/docfx.json
src/CmlLib.Core-master/**/release.ps1
src/CmlLib.Core.Auth.Microsoft-master/**/.gitpod.yml
src/CmlLib.Core.Auth.Microsoft-master/**/.github/
src/CmlLib.Core.Auth.Microsoft-master/**/docs/
src/CmlLib.Core.Auth.Microsoft-master/**/docfx.json
src/CmlLib.Core.Commons-main/**/docs/
src/CmlLib.Core.Commons-main/**/docfx.json
src/XboxAuthNet-main/**/.gitpod.yml
src/XboxAuthNet-main/**/.github/
src/XboxAuthNet-main/**/docs/


# ==================================================================
# JetBrains / ReSharper junk
# ==================================================================
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings
*.DotSettings.user


# ==================================================================
# Source JAR exceptions (explicitly tracked — runtime/bootstrap)
# ==================================================================
!src/LeafClient/LeafRuntime/**/*.jar
!src/LeafClient/LeafBootstrap/**/*.jar


# ==================================================================
# Source folders that MUST stay tracked  (re-allow after broad rules)
# ==================================================================
!src/LeafClient/Models/
!src/LeafClient/Services/
!src/LeafClient/ViewModels/
!src/LeafClient/Controls/
!src/LeafClient/Utils/
!src/LeafClient/Views/
!src/LeafClient/Views/Pages/
!src/LeafClient/Views/Pages/*.cs
!src/LeafClient/Views/*.cs
!src/LeafClient/App.axaml.cs
!src/LeafClient/Program.cs
!src/LeafClient/Json.cs
!src/LeafClient/JsonContext.cs
!src/LeafClient/ViewLocator.cs
!src/LeafClient/LeafClient.csproj
!src/LeafClientInstaller/**/*.cs
!src/LeafClientInstaller/*.csproj
!src/LeafClientUpdater/**/*.cs
!src/LeafClientUpdater/*.csproj

# ==================================================================
# Final safety net: never commit these top-level items
# ==================================================================
/untrack-private.ps1
/deploy-ssh-key.ps1
