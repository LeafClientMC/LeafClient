*.suo
**/Properties/
**/.config/
packages.config
packages/
NuGet.Config
nuget.config
NuGet.config
*.nuspec
*.nupkg.metadata
project.assets.json
project.nuget.cache
*.csproj.user
*.csproj.FileListAbsolute.txt
*.csproj.AssemblyReference.cache
*.csproj.CoreCompileInputs.cache
*.csproj.CopyComplete
*.csproj.GenerateResource.cache
*.csproj.Backup*.tmp
*.csproj.dtbcache.json
*.dgspec.json
*.sourcelink.json
*.runtimeconfig.json
*.deps.json
GeneratedInternalTypeHelper.g.*
*.metagen
*.g.cs
*.g.i.cs
*.AssemblyInfo.cs
StyleCop.Cache
.NETStandard,Version=*.AssemblyAttributes.cs

