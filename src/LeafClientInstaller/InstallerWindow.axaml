<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LeafClientInstaller.InstallerWindow"
        Title="Leaf Client Setup"
        Width="720" Height="480"
        MinWidth="720" MinHeight="480"
        MaxWidth="720" MaxHeight="480"
        Background="#0F0F0F"
        FontFamily="Inter"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="None"
        CanResize="False">

    <Window.Styles>

        <!-- Window chrome buttons -->
        <Style Selector="Button.WinBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.WinBtn /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.WinBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1AFFFFFF"/>
        </Style>
        <Style Selector="Button.WinBtnClose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#CCE53935"/>
        </Style>

        <!-- Primary green action button -->
        <Style Selector="Button.PrimaryBtn">
            <Setter Property="Background" Value="#2ecc71"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="24,0"/>
        </Style>
        <Style Selector="Button.PrimaryBtn /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.PrimaryBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3ddb80"/>
        </Style>
        <Style Selector="Button.PrimaryBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#27ae60"/>
        </Style>
        <Style Selector="Button.PrimaryBtn:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>

        <!-- Secondary gray button -->
        <Style Selector="Button.SecondaryBtn">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="24,0"/>
        </Style>
        <Style Selector="Button.SecondaryBtn /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.SecondaryBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#333333"/>
        </Style>

        <!-- Text link button -->
        <Style Selector="Button.LinkBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#70FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button.LinkBtn /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.LinkBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- TextBox style -->
        <Style Selector="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#402ecc71"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#2ecc71"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
        </Style>
        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="#40FFFFFF"/>
        </Style>

        <!-- CheckBox style -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#90FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Browse button -->
        <Style Selector="Button.BrowseBtn">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.BrowseBtn /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.BrowseBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a2a2a"/>
        </Style>

    </Window.Styles>

    <Grid RowDefinitions="44,*,60">

        <!-- Background image with parallax -->
        <Image x:Name="BgImage" Grid.RowSpan="3"
               Source="avares://LeafClientSetup/Assets/bg.jpg"
               Stretch="UniformToFill" Opacity="0.25"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                    <TranslateTransform X="0" Y="0"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <!-- Dark overlay on top of bg -->
        <Border Grid.RowSpan="3" Background="#0F0F0F" Opacity="0.55"/>

        <!-- ROW 0: Title bar -->
        <Border x:Name="TitleBar" Grid.Row="0" Background="Transparent">
            <Grid>
                <!-- Left: icon + title -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="16,0,0,0"
                            Spacing="10">
                    <Image Source="avares://LeafClientSetup/Assets/LeafRebrandedTransparent.png"
                           Width="20" Height="20"
                           VerticalAlignment="Center"/>
                    <TextBlock Text="Leaf Client Setup"
                               Foreground="#AAFFFFFF"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: minimize + close -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Spacing="2">
                    <Button Classes="WinBtn" Click="MinimizeWindow_Click">
                        <TextBlock Text="&#x2014;"
                                   Foreground="#70FFFFFF"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,2"/>
                    </Button>
                    <Button Classes="WinBtn WinBtnClose" Click="CloseWindow_Click">
                        <TextBlock Text="&#x2715;"
                                   Foreground="#70FFFFFF"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1: Content area -->
        <Border Grid.Row="1" Background="Transparent" Padding="48,0">
            <Grid>

                <!-- STEP 1: Welcome -->
                <StackPanel x:Name="StepWelcome"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="0"
                            Opacity="0"
                            IsVisible="True">
                    <StackPanel.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                        </Transitions>
                    </StackPanel.Transitions>

                    <Image Source="avares://LeafClientSetup/Assets/LeafRebrandedTransparent.png"
                           Width="100" Height="100"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                    <Image Source="avares://LeafClientSetup/Assets/logo_text.png"
                           Width="220" Height="55"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- STEP 2: Install Location -->
                <StackPanel x:Name="StepConfig"
                            VerticalAlignment="Center"
                            Spacing="0"
                            Opacity="0"
                            IsVisible="False">
                    <StackPanel.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                        </Transitions>
                    </StackPanel.Transitions>

                    <TextBlock Text="Installation folder:"
                               Foreground="White"
                               FontSize="14"
                               Margin="0,0,0,12"/>

                    <Grid ColumnDefinitions="*,10,Auto" Margin="0,0,0,16">
                        <TextBox x:Name="PathBox" Grid.Column="0"/>
                        <Button Grid.Column="2"
                                Classes="BrowseBtn"
                                Content="Browse"
                                Click="Browse_Click"/>
                    </Grid>

                    <StackPanel Spacing="8">
                        <CheckBox x:Name="DesktopShortcutCheck"
                                  Content="Create Desktop Shortcut"
                                  IsChecked="True"/>
                        <CheckBox x:Name="StartMenuShortcutCheck"
                                  Content="Create Start Menu Shortcut"
                                  IsChecked="True"/>
                    </StackPanel>
                </StackPanel>

                <!-- STEP 3: Installing -->
                <StackPanel x:Name="StepInstalling"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="0"
                            Opacity="0"
                            IsVisible="False">
                    <StackPanel.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                        </Transitions>
                    </StackPanel.Transitions>

                    <TextBlock x:Name="InstallingTitle"
                               Text="Installing Leaf Client"
                               Foreground="#80DDFFEE"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>

                    <Image Source="avares://LeafClientSetup/Assets/LeafRebrandedTransparent.png"
                           Width="64" Height="64"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                    <!-- Progress bar -->
                    <Grid Width="400" Margin="0,0,0,12">
                        <Border Height="3" CornerRadius="2" Background="#1AFFFFFF"/>
                        <Border x:Name="ProgressFill"
                                Height="3"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                Width="0"
                                Background="#2ecc71"/>
                    </Grid>

                    <TextBlock x:Name="InstallingStatus"
                               Text="Preparing..."
                               Foreground="#60FFFFFF"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- STEP 4: Complete -->
                <StackPanel x:Name="StepComplete"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="0"
                            Opacity="0"
                            IsVisible="False">
                    <StackPanel.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                        </Transitions>
                    </StackPanel.Transitions>

                    <TextBlock Text="Installation Complete!"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,32"/>

                    <Button x:Name="LaunchBtn"
                            Classes="PrimaryBtn"
                            Click="Launch_Click"
                            HorizontalAlignment="Center"
                            MinWidth="200"
                            Content="Launch Leaf Client"/>

                    <Button Classes="LinkBtn"
                            Content="Close"
                            Click="CloseWindow_Click"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Error banner -->
                <Border x:Name="ErrorBanner"
                        IsVisible="False"
                        Background="#20F44336"
                        BorderBrush="#30F44336"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8">
                    <TextBlock x:Name="ErrorBannerText"
                               Foreground="#FF8A80"
                               FontSize="12"
                               TextWrapping="Wrap"
                               MaxWidth="500"/>
                </Border>

            </Grid>
        </Border>

        <!-- ROW 2: Bottom navigation bar -->
        <Border Grid.Row="2" Background="Transparent" Padding="20,0">
            <Grid>
                <!-- Back button (left) -->
                <Button x:Name="BackBtn"
                        Classes="LinkBtn"
                        Content="Back"
                        Click="Back_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        IsVisible="False"/>

                <!-- Next/Install button (right) -->
                <Button x:Name="NextBtn"
                        Classes="PrimaryBtn"
                        Content="Next"
                        Click="Next_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"/>

                <!-- Cancel button for installing step (right) -->
                <Button x:Name="CancelBtn"
                        Classes="SecondaryBtn"
                        Content="Cancel"
                        Click="CloseWindow_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        IsVisible="False"/>
            </Grid>
        </Border>

    </Grid>
</Window>
