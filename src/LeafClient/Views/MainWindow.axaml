<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:viewmodels="clr-namespace:LeafClient.ViewModels"
		xmlns:media="using:Avalonia.Media"
		xmlns:views="clr-namespace:LeafClient.Views"
		xmlns:pages="clr-namespace:LeafClient.Views.Pages"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="850"
        x:Class="LeafClient.Views.MainWindow"
        Title="Leaf Client"
        Width="1400" Height="750"
        MinWidth="1200" MinHeight="700"
        Background="#0D1117"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="None"
		x:DataType="viewmodels:MainWindowViewModel"
		Icon="/Assets/Leaf.png">

	<!-- Glass-style background brush overrides (scoped to MainWindow only).
	     These let the blurred bg.jpg + gradient overlay below show through the
	     large panel surfaces, matching the LoginWindow / GameOutputWindow look.
	     Dialogs, overlays, and other windows still use the opaque theme values. -->
	<Window.Resources>
		<SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#40000000"/>
		<SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#B0060C14"/>
		<SolidColorBrush x:Key="TertiaryBackgroundBrush" Color="#90060C14"/>

		<!-- Override the Fluent theme's MenuFlyoutPresenter resource keys so
		     that BOTH the top-level hamburger dropdown AND any nested
		     submenu popups (e.g. Support & Feedback → Join Discord / Suggest
		     / Common Questions) pick up the dark-gradient look. Without this,
		     submenus fall back to the default light Fluent surface and stand
		     out as a mismatched gray card. -->
		<LinearGradientBrush x:Key="MenuFlyoutPresenterBackground" StartPoint="0%,0%" EndPoint="0%,100%">
			<GradientStop Offset="0" Color="#0F1A24"/>
			<GradientStop Offset="1" Color="#080C14"/>
		</LinearGradientBrush>
		<SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="#1C2A38"/>
		<Thickness x:Key="MenuFlyoutPresenterBorderThemeThickness">1</Thickness>
		<Thickness x:Key="MenuFlyoutPresenterThemePadding">8</Thickness>
		<CornerRadius x:Key="OverlayCornerRadius">16</CornerRadius>
	</Window.Resources>

	<Window.Styles>
		<Style Selector="TextBlock.BlurredOnHover">
			<Setter Property="Effect">
				<BlurEffect Radius="4"/>
			</Setter>
			<Setter Property="Transitions">
				<Transitions>
					<EffectTransition Property="Effect" Duration="0:0:0.2" Easing="CubicEaseOut"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Panel.BlurredContainer:pointerover TextBlock.BlurredOnHover">
			<Setter Property="Effect" Value="{x:Null}"/>
		</Style>
		<Style Selector="Button.IconButton">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<ControlTemplate>
					<ContentPresenter Name="PART_ContentPresenter" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="Button.IconButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Button.IconButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Button.WindowButton">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.WindowButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
		</Style>
		<Style Selector="Button.CloseButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource ErrorHoverBrush}"/>
		</Style>
		<Style Selector="TextBlock.HeaderText">
			<Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>
		<!-- ══════════════════════════════════════════
		     Sidebar nav button animation
		     ══════════════════════════════════════════ -->

		<!-- Base state. Note: use "0.5,0.5" (not "50%,50%") for RenderTransformOrigin
		     so Avalonia parses it as a relative point and scales around the true center. -->
		<Style Selector="Border.SidebarIcon">
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
			<Setter Property="RenderTransform" Value="scale(1.0)"/>
			<Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
			<Setter Property="Transitions">
				<Transitions>
					<!-- Spring-style scale for that satisfying "click into place" feel. -->
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.35">
						<TransformOperationsTransition.Easing>
							<BackEaseOut/>
						</TransformOperationsTransition.Easing>
					</TransformOperationsTransition>
					<BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.28">
						<BoxShadowsTransition.Easing>
							<CubicEaseOut/>
						</BoxShadowsTransition.Easing>
					</BoxShadowsTransition>
					<BrushTransition Property="Background" Duration="0:0:0.22"/>
				</Transitions>
			</Setter>
		</Style>

		<!-- Icon image: opacity + scale with spring return, plus a drop shadow that
		     builds in on hover for a "lifted off the button" feel. Selector uses
		     descendant (space, not >) so it matches Images nested inside Grids too. -->
		<Style Selector="Border.SidebarIcon Image">
			<Setter Property="Opacity" Value="0.72"/>
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
			<Setter Property="RenderTransform" Value="scale(1.0)"/>
			<Setter Property="Transitions">
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.22"/>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.40">
						<TransformOperationsTransition.Easing>
							<BackEaseOut/>
						</TransformOperationsTransition.Easing>
					</TransformOperationsTransition>
				</Transitions>
			</Setter>
		</Style>

		<!-- Hover: subtle scale + glass tint + soft GREEN glow (brand-matched),
		     icon scales up + brightens to 100%. The glow is tinted to match the
		     selection indicator and LAUNCH GAME button. -->
		<Style Selector="Border.SidebarIcon:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.08)"/>
			<Setter Property="Background" Value="#2AFFFFFF"/>
			<Setter Property="BoxShadow" Value="0 4 22 0 #554CAF50, 0 2 8 0 #60000000"/>
		</Style>
		<Style Selector="Border.SidebarIcon:pointerover Image">
			<Setter Property="Opacity" Value="1.0"/>
			<Setter Property="RenderTransform" Value="scale(1.12)"/>
		</Style>

		<!-- Pressed: dip back for tactile click. Fast, snappy. -->
		<Style Selector="Border.SidebarIcon:pressed">
			<Setter Property="RenderTransform" Value="scale(0.93)"/>
			<Setter Property="BoxShadow" Value="0 2 6 0 #40000000"/>
		</Style>
		<Style Selector="Border.SidebarIcon:pressed Image">
			<Setter Property="RenderTransform" Value="scale(0.90)"/>
		</Style>
		<!-- Playing As avatar hover animation -->
		<Style Selector="Image.PlayingAsAvatar">
			<Setter Property="Margin" Value="0,0,0,0" />
			<Setter Property="Transitions">
				<Transitions>
					<ThicknessTransition Property="Margin" Duration="0:0:0.18">
						<ThicknessTransition.Easing>
							<CubicEaseOut/>
						</ThicknessTransition.Easing>
					</ThicknessTransition>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button#PlayingAsButton">
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.15"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button#PlayingAsButton:pointerover">
			<Setter Property="Background" Value="#15FFFFFF"/>
		</Style>
		<Style Selector="Button#PlayingAsButton:pointerover Image.PlayingAsAvatar">
			<Setter Property="Margin" Value="0,-3,0,3" />
		</Style>

		<Style Selector="MenuFlyoutPresenter">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundColor}" />
			<Setter Property="BorderBrush" Value="{DynamicResource PrimaryBorderBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="Padding" Value="6" />
		</Style>


		<!-- ═══════════════════════════════════════════════════════════════
		     Modern MenuFlyout (hamburger dropdown) — dark gradient card
		     with purple accent hover. Matches the main-window accent bar
		     style used by the settings page TabItems.
		     ═══════════════════════════════════════════════════════════════ -->
		<Style Selector="MenuFlyoutPresenter">
			<Setter Property="Padding" Value="8"/>
			<Setter Property="MinWidth" Value="240"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#1C2A38"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Background">
				<Setter.Value>
					<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
						<GradientStop Offset="0" Color="#0F1A24"/>
						<GradientStop Offset="1" Color="#080C14"/>
					</LinearGradientBrush>
				</Setter.Value>
			</Setter>
		</Style>

		<Style Selector="MenuItem">
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="12,10"/>
			<Setter Property="Margin" Value="2,2"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="#CBD5E1"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="MenuItem /template/ Border#PART_LayoutRoot">
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.18"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
			<Setter Property="Background" Value="#1A9333EA"/>
		</Style>
		<Style Selector="MenuItem:pointerover">
			<Setter Property="Foreground" Value="#FFFFFF"/>
		</Style>
		<Style Selector="MenuItem:pointerover Path">
			<Setter Property="Stroke" Value="#C4B5FD"/>
		</Style>
		<Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
			<Setter Property="Background" Value="#1A9333EA"/>
		</Style>
		<Style Selector="MenuItem:pressed /template/ Border#PART_LayoutRoot">
			<Setter Property="Background" Value="#309333EA"/>
		</Style>
		<Style Selector="MenuItem:pressed">
			<Setter Property="Foreground" Value="#FFFFFF"/>
		</Style>

		<Style Selector="Separator">
			<Setter Property="Background" Value="#152030"/>
			<Setter Property="Height" Value="1"/>
			<Setter Property="Margin" Value="8,6"/>
			<Setter Property="Opacity" Value="0.9"/>
		</Style>

		<!-- Profile Overlay tab button styles -->
		<!-- ═══ Profile Overlay: Side Nav Buttons ═══ -->
		<Style Selector="Button.PONav">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Foreground" Value="#4B5563"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Width" Value="58"/>
			<Setter Property="Height" Value="54"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="CornerRadius" Value="14"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.2"/>
					<BrushTransition Property="Foreground" Duration="0:0:0.2"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.PONav:pointerover">
			<Setter Property="Background" Value="#0AFFFFFF"/>
			<Setter Property="Foreground" Value="#9CA3AF"/>
		</Style>
		<Style Selector="Button.PONav:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Button.PONav:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Button.PONavActive">
			<Setter Property="Background" Value="#0FFFFFFF"/>
			<Setter Property="Foreground" Value="#B080FF"/>
		</Style>
		<!-- ═══ Profile Overlay: Preset Cards ═══ -->
		<Style Selector="Border.POPresetCard">
			<Setter Property="Background" Value="#0F1A24"/>
			<Setter Property="BorderBrush" Value="#1C2A38"/>
			<Setter Property="BorderThickness" Value="1.5"/>
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.2"/>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Border.POPresetCard:pointerover">
			<Setter Property="Background" Value="#142230"/>
			<Setter Property="BorderBrush" Value="#2A3F52"/>
			<Setter Property="RenderTransform" Value="scale(1.012)"/>
		</Style>
		<!-- ═══ Profile Overlay: Tab Content Fade ═══ -->
		<Style Selector="StackPanel.POTabContent">
			<Setter Property="Transitions">
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
				</Transitions>
			</Setter>
		</Style>


	<!-- ColorBtn: custom template that keeps the button's Background on hover/pressed
	     (Avalonia's default template replaces it with a gray).
	     Includes PART_Shimmer — a gradient stripe animated via C# PointerEntered. -->
	<Style Selector="Button.ColorBtn">
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="Template">
			<ControlTemplate>
				<Border Name="PART_Border"
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						CornerRadius="{TemplateBinding CornerRadius}"
						ClipToBounds="True">
					<Grid>
						<ContentPresenter Name="PART_ContentPresenter"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  Padding="{TemplateBinding Padding}"
										  Background="Transparent"
										  HorizontalContentAlignment="Center"
										  VerticalContentAlignment="Center"/>
						<!-- Shimmer overlay — full-width, gradient offsets animated in C# to sweep left→right -->
						<Border Name="PART_Shimmer"
								IsHitTestVisible="False"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"/>
					</Grid>
				</Border>
			</ControlTemplate>
		</Setter>
	</Style>

	<!-- ── Lift + Glow button animations ── -->
	<!-- LiftBtn: smooth upward translate on hover via RenderTransform -->
	<Style Selector="Button.LiftBtn">
		<Setter Property="RenderTransform" Value="translateY(0px)"/>
		<Setter Property="Transitions">
			<Transitions>
				<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
			</Transitions>
		</Setter>
	</Style>
	<Style Selector="Button.LiftBtn:pointerover">
		<Setter Property="RenderTransform" Value="translateY(-5px)"/>
	</Style>
	<Style Selector="Button.LiftBtn:pressed">
		<Setter Property="RenderTransform" Value="translateY(-2px)"/>
	</Style>

	<!-- GlowGreen: green glow shadow + scale spring for primary green buttons.
	     Declared after LiftBtn so its RenderTransform wins on buttons with both classes. -->
	<Style Selector="Button.GlowGreen">
		<Setter Property="Effect">
			<DropShadowEffect BlurRadius="8" Color="#2A4CAF50" OffsetX="0" OffsetY="0"/>
		</Setter>
		<Setter Property="RenderTransform" Value="scale(1) translateY(0)"/>
		<Setter Property="Transitions">
			<Transitions>
				<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.4">
					<TransformOperationsTransition.Easing>
						<SplineEasing X1="0.22" Y1="1.0" X2="0.36" Y2="1.0"/>
					</TransformOperationsTransition.Easing>
				</TransformOperationsTransition>
			</Transitions>
		</Setter>
	</Style>
	<Style Selector="Button.GlowGreen:pointerover">
		<Setter Property="Effect">
			<DropShadowEffect BlurRadius="32" Color="#AA4CAF50" OffsetX="0" OffsetY="8"/>
		</Setter>
		<Setter Property="RenderTransform" Value="scale(1.05) translateY(-3px)"/>
	</Style>
	<Style Selector="Button.GlowGreen:pressed">
		<Setter Property="RenderTransform" Value="scale(0.97) translateY(-1px)"/>
	</Style>

	<!-- GlowAccent: accent-purple glow for New Profile / main action buttons -->
	<Style Selector="Button.GlowAccent">
		<Setter Property="Effect">
			<DropShadowEffect BlurRadius="6" Color="#20000000" OffsetX="0" OffsetY="0"/>
		</Setter>
		<Setter Property="Transitions">
			<Transitions>
				<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
			</Transitions>
		</Setter>
	</Style>
	<Style Selector="Button.GlowAccent:pointerover">
		<Setter Property="Effect">
			<DropShadowEffect BlurRadius="26" Color="#A07B2CBF" OffsetX="0" OffsetY="0"/>
		</Setter>
		<Setter Property="RenderTransform" Value="translateY(-5px)"/>
	</Style>
	<Style Selector="Button.GlowAccent:pressed">
		<Setter Property="RenderTransform" Value="translateY(-2px)"/>
	</Style>

	<!-- ── Global: ComboBox – kill all border chrome ── -->
	<Style Selector="ComboBox">
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
	</Style>
	<Style Selector="ComboBox /template/ Border#Background">
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
	</Style>
	<Style Selector="ComboBox:pointerover /template/ Border#Background">
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
	</Style>
	<Style Selector="ComboBox:focus /template/ Border#Background">
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
	</Style>

	<!-- ── Global: Button ContentPresenter – kill default gray hover/pressed backgrounds ── -->
	<Style Selector="Button /template/ ContentPresenter">
		<Setter Property="Background" Value="Transparent"/>
	</Style>
	<Style Selector="Button:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="Transparent"/>
	</Style>
	<Style Selector="Button:pressed /template/ ContentPresenter">
		<Setter Property="Background" Value="Transparent"/>
	</Style>

	<!-- ── Global: TextBox – freeze border so hover/focus never changes colour ── -->
	<Style Selector="TextBox /template/ Border#PART_BorderElement">
		<Setter Property="BorderBrush" Value="{DynamicResource PrimaryBorderBrush}"/>
	</Style>
	<Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
		<Setter Property="BorderBrush" Value="{DynamicResource PrimaryBorderBrush}"/>
	</Style>
	<Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
		<Setter Property="BorderBrush" Value="{DynamicResource PrimaryBorderBrush}"/>
	</Style>
	<Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
		<Setter Property="BorderBrush" Value="{DynamicResource PrimaryBorderBrush}"/>
	</Style>

	<!-- GlowRed: red glow for delete/destructive action buttons -->
	<Style Selector="Button.GlowRed">
		<Setter Property="Effect">
			<DropShadowEffect BlurRadius="6" Color="#20000000" OffsetX="0" OffsetY="0"/>
		</Setter>
		<Setter Property="Transitions">
			<Transitions>
				<EffectTransition Property="Effect" Duration="0:0:0.35" Easing="CubicEaseOut"/>
				<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
			</Transitions>
		</Setter>
	</Style>
	<Style Selector="Button.GlowRed:pointerover">
		<Setter Property="Effect">
			<DropShadowEffect BlurRadius="26" Color="#A0FF5722" OffsetX="0" OffsetY="0"/>
		</Setter>
		<Setter Property="RenderTransform" Value="translateY(-5px)"/>
	</Style>
	<Style Selector="Button.GlowRed:pressed">
		<Setter Property="RenderTransform" Value="translateY(-2px)"/>
	</Style>

	<!-- ── ToggleSwitch: Built-in Fluent theme with purple accent ── -->
	<Style Selector="ToggleSwitch">
		<Setter Property="OffContent" Value="{x:Null}"/>
		<Setter Property="OnContent" Value="{x:Null}"/>
		<Setter Property="Cursor" Value="Hand"/>
		<Style.Resources>
			<SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#7B2CBF"/>
			<SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#6A24A8"/>
			<SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#5A1E8F"/>
			<SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="#7B2CBF"/>
			<SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="#6A24A8"/>
			<SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="#5A1E8F"/>
		</Style.Resources>
	</Style>

	<!-- ── Modern Slider: Accent-colored knob with smooth animation ── -->
	<Style Selector="Slider /template/ Thumb">
		<Setter Property="Width" Value="16"/>
		<Setter Property="Height" Value="16"/>
		<Setter Property="Template">
			<ControlTemplate>
				<Border Background="{DynamicResource PrimaryAccentBrush}"
						CornerRadius="8" Width="16" Height="16"
						BoxShadow="0 1 4 0 #50000000"/>
			</ControlTemplate>
		</Setter>
	</Style>
	<Style Selector="Slider /template/ Thumb:pointerover">
		<Setter Property="Template">
			<ControlTemplate>
				<Border Background="{DynamicResource PrimaryAccentBrush}"
						CornerRadius="9" Width="18" Height="18"
						BoxShadow="0 2 6 0 #50000000"
						Opacity="0.9"/>
			</ControlTemplate>
		</Setter>
	</Style>

	</Window.Styles>

	<Grid x:Name="MainRootGrid" ClipToBounds="False">

		<!-- ══════════════════════════════════════════
		     LAYER 1 — Blurred background image (matches LoginWindow / GameOutputWindow)
		     ══════════════════════════════════════════ -->
		<Image x:Name="BgImage"
		       Source="/Assets/bg.jpg"
		       Stretch="UniformToFill"
		       RenderTransformOrigin="0.5,0.5"
		       IsHitTestVisible="False">
			<Image.Effect>
				<BlurEffect Radius="5"/>
			</Image.Effect>
			<Image.RenderTransform>
				<ScaleTransform ScaleX="1.18" ScaleY="1.18"/>
			</Image.RenderTransform>
		</Image>

		<!-- ══════════════════════════════════════════
		     LAYER 2 — Dark gradient overlay (matches LoginWindow / GameOutputWindow)
		     ══════════════════════════════════════════ -->
		<Border IsHitTestVisible="False">
			<Border.Background>
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
					<GradientStop Color="#B8000000" Offset="0"/>
					<GradientStop Color="#92030A16" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
		</Border>

		<Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,12,0,0"
        Background="{DynamicResource SecondaryBackgroundBrush}"
        CornerRadius="15" Padding="12,6"
        BoxShadow="0 4 15 0 #40000000"
        ZIndex="100">
			<Border.Transitions>
				<Transitions>
					<DoubleTransition Property="(TranslateTransform.X)" Duration="0:0:0.4" Easing="CubicEaseOut"/>
					<ThicknessTransition Property="Margin" Duration="0:0:0.3" Easing="CubicEaseOut"/>
				</Transitions>
			</Border.Transitions>

			<Grid>
				<!-- Selection indicator: soft leaf-green gradient matches the LAUNCH GAME
				     button and the Leaf Client brand. Subtle green glow gives it presence
				     without overpowering the glass background. -->
				<Border x:Name="SelectionIndicator" Width="50" Height="50"
						CornerRadius="10" HorizontalAlignment="Left" VerticalAlignment="Center"
						Margin="0,0,0,0" Opacity="0.55"
						RenderTransformOrigin="0.5,0.5"
						RenderTransform="scale(1.0)">
					<Border.Background>
						<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
							<GradientStop Color="#5CCF6B" Offset="0"/>
							<GradientStop Color="#2E8B4A" Offset="1"/>
						</LinearGradientBrush>
					</Border.Background>
					<Border.BoxShadow>
						0 0 18 0 #4000E676
					</Border.BoxShadow>
					<Border.Transitions>
						<Transitions>
							<ThicknessTransition Property="Margin" Duration="0:0:0.3" Easing="CubicEaseOut"/>
							<!-- Match the SidebarIcon spring scale so the selection highlight
							     expands and settles in lockstep with the selected button. -->
							<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.35">
								<TransformOperationsTransition.Easing>
									<BackEaseOut/>
								</TransformOperationsTransition.Easing>
							</TransformOperationsTransition>
						</Transitions>
					</Border.Transitions>
				</Border>

				<StackPanel Orientation="Horizontal" Spacing="10">
					<!-- Logo Removed -->

					<Border x:Name="GameButton" Classes="SidebarIcon" Width="50" Height="50" Background="{DynamicResource SidebarButtonBackgroundBrush}" CornerRadius="10" Cursor="Hand"
							RenderTransformOrigin="0.5,0.5" RenderTransform="scale(1.0)"
							PointerPressed="OnNavButtonClick" PointerEntered="OnSidebarButtonPointerEntered" PointerExited="OnSidebarButtonPointerExited" Tag="0">
						<Image Source="/Assets/icon-game.png" Width="28" Height="28"/>
					</Border>

					<Border x:Name="VersionsButton" Classes="SidebarIcon" Width="50" Height="50" Background="{DynamicResource SidebarButtonBackgroundBrush}" CornerRadius="10" Cursor="Hand"
							RenderTransformOrigin="0.5,0.5" RenderTransform="scale(1.0)"
							PointerPressed="OnNavButtonClick" PointerEntered="OnSidebarButtonPointerEntered" PointerExited="OnSidebarButtonPointerExited" Tag="1">
						<Image Source="/Assets/icon-versions.png" Width="28" Height="28"/>
					</Border>

					<Border x:Name="ServersButton" Classes="SidebarIcon" Width="50" Height="50" Background="{DynamicResource SidebarButtonBackgroundBrush}" CornerRadius="10" Cursor="Hand"
							RenderTransformOrigin="0.5,0.5" RenderTransform="scale(1.0)"
							PointerPressed="OnNavButtonClick" PointerEntered="OnSidebarButtonPointerEntered" PointerExited="OnSidebarButtonPointerExited" Tag="2">
						<Image Source="/Assets/icon-servers.png" Width="28" Height="28"/>
					</Border>

					<Border x:Name="ModsButton" Classes="SidebarIcon" Width="50" Height="50" Background="{DynamicResource SidebarButtonBackgroundBrush}" CornerRadius="10" Cursor="Hand"
							RenderTransformOrigin="0.5,0.5" RenderTransform="scale(1.0)"
							PointerPressed="OnNavButtonClick" PointerEntered="OnSidebarButtonPointerEntered" PointerExited="OnSidebarButtonPointerExited" Tag="3">
						<Image Source="/Assets/icon-mods.png" Width="28" Height="28"/>
					</Border>

					<Border x:Name="CosmeticsButton" Classes="SidebarIcon" Width="50" Height="50" Background="{DynamicResource SidebarButtonBackgroundBrush}" CornerRadius="10" Cursor="Hand"
							RenderTransformOrigin="0.5,0.5" RenderTransform="scale(1.0)"
							PointerPressed="OnNavButtonClick" PointerEntered="OnSidebarButtonPointerEntered" PointerExited="OnSidebarButtonPointerExited" Tag="6">
						<Image Source="/Assets/icon-cosmetics.png" Width="28" Height="28"
							   Stretch="Uniform"
							   HorizontalAlignment="Center" VerticalAlignment="Center"
							   Margin="0,0,4,0"/>
					</Border>
					<!-- Store button -->
					<Border x:Name="StoreButton" Classes="SidebarIcon" Width="50" Height="50" Background="{DynamicResource SidebarButtonBackgroundBrush}" CornerRadius="10" Cursor="Hand"
							RenderTransformOrigin="0.5,0.5" RenderTransform="scale(1.0)"
							PointerPressed="OnNavButtonClick" PointerEntered="OnSidebarButtonPointerEntered" PointerExited="OnSidebarButtonPointerExited" Tag="7">
						<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
							<Image Source="/Assets/icon-store.png" Width="28" Height="28"
								   Stretch="Uniform"
								   HorizontalAlignment="Center" VerticalAlignment="Center"
								   Margin="0,0,4,0"/>
							<!-- Notification dot: absolutely positioned in top-right, no layout impact. -->
							<Border Width="7" Height="7" CornerRadius="4"
									HorizontalAlignment="Right" VerticalAlignment="Top"
									Margin="0,5,5,0"
									IsHitTestVisible="False">
								<Border.Background>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="#F59E0B" Offset="0"/>
										<GradientStop Color="#EF4444" Offset="1"/>
									</LinearGradientBrush>
								</Border.Background>
							</Border>
						</Grid>
					</Border>
					<!-- Screenshots button — gallery icon from icons8 -->
					<Border x:Name="ScreenshotsButton" Classes="SidebarIcon" Width="50" Height="50" Background="{DynamicResource SidebarButtonBackgroundBrush}" CornerRadius="10" Cursor="Hand"
							RenderTransformOrigin="0.5,0.5" RenderTransform="scale(1.0)"
							PointerPressed="OnNavButtonClick" PointerEntered="OnSidebarButtonPointerEntered" PointerExited="OnSidebarButtonPointerExited" Tag="8">
						<Image Source="/Assets/icons8-gallery-48.png" Width="28" Height="28"
							   Stretch="Uniform"
							   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
					<Border x:Name="SettingsButton" Classes="SidebarIcon" Width="50" Height="50" Background="{DynamicResource SidebarButtonBackgroundBrush}" CornerRadius="10" Cursor="Hand"
							RenderTransformOrigin="0.5,0.5" RenderTransform="scale(1.0)"
							PointerPressed="OnNavButtonClick" PointerEntered="OnSidebarButtonPointerEntered" PointerExited="OnSidebarButtonPointerExited" Tag="4">
						<Image Source="/Assets/icon-settings.png" Width="28" Height="28"
							   Stretch="Uniform"
							   HorizontalAlignment="Center" VerticalAlignment="Center"
							   Margin="0,0,5,0"/>
					</Border>
				</StackPanel>
			</Grid>
		</Border>


		<!-- Main Content Area -->
		<Grid x:Name="MainContentGrid" Margin="0">
			<Grid.RowDefinitions>
				<RowDefinition Height="60"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="60"/>
			</Grid.RowDefinitions>

			<!-- Top Header Bar -->
			<Border x:Name="TopHeaderBorder" Grid.Row="0" Background="{DynamicResource TertiaryBackgroundBrush}" BorderBrush="{DynamicResource PrimaryBorderBrush}" BorderThickness="0,0,0,1">
				<Grid ColumnDefinitions="Auto,*,Auto">
					<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Margin="20,0">
						<Image Source="/Assets/LeafRebrandedTransparent.png" Width="32" Height="32" RenderOptions.BitmapInterpolationMode="HighQuality"/>
						<Button Classes="IconButton" Content="Leaf Client" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
						<Button Classes="IconButton" Width="24" Height="24" CornerRadius="4" Click="OpenWebsite" Margin="12,0,0,0">
							<Image Source="/Assets/32website.png" Width="16" Height="16"/>
						</Button>
						<Button Classes="IconButton" Width="24" Height="24" CornerRadius="4" Click="OpenDiscord">
							<Image Source="/Assets/32discord.png" Width="16" Height="16"/>
						</Button>
						<Button Classes="IconButton" Width="24" Height="24" CornerRadius="4" Click="OpenInstagram">
							<Image Source="/Assets/icons8-instagram-32.png" Width="16" Height="16"/>
						</Button>
					</StackPanel>

					<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Margin="10,0,10,0">

						<!-- Leafs Currency Widget -->
						<Border x:Name="LeafsCurrencyWidget" IsVisible="False"
								Background="#0AFFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1"
								CornerRadius="8" Padding="9,4" VerticalAlignment="Center">
							<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
								<TextBlock Text="🍃" FontSize="13" VerticalAlignment="Center"/>
								<TextBlock x:Name="LeafsBalanceText" Text="0"
										   Foreground="#4ADE80" FontWeight="Bold" FontSize="12"
										   VerticalAlignment="Center"/>
							</StackPanel>
						</Border>

						<!-- Playing As Button (Moved Here) -->
						<Button x:Name="PlayingAsButton"
								Background="Transparent"
								BorderThickness="0"
								CornerRadius="8"
								Padding="8,4"
								Margin="0,0,10,0"
								VerticalAlignment="Center"
								Cursor="Hand"
								Click="OnAccountButtonClick">
							<Grid ColumnDefinitions="Auto,Auto">
								<Border Width="28" Height="28" CornerRadius="4" ClipToBounds="True" Margin="0,0,8,0">
									<Image x:Name="PlayingAsImage"
										   Source=""
										   Stretch="UniformToFill"
										   HorizontalAlignment="Center"
										   VerticalAlignment="Top"/>
								</Border>
								<StackPanel Grid.Column="1" VerticalAlignment="Center">
									<TextBlock Text="Playing as" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="10"/>
									<TextBlock x:Name="PlayingAsUsername" Text="ZIADKY" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="12"/>
								</StackPanel>
							</Grid>
						</Button>

						<!-- Window Controls -->
						<Button Classes="WindowButton" Width="40" Height="40" CornerRadius="8">
							<Button.Flyout>
								<MenuFlyout Placement="BottomEdgeAlignedLeft">
									<MenuItem Header="Game Output" Click="OpenGameOutput">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M4,6 L8,12 L4,18 M11,18 L20,18"/>
										</MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="Open Logs" Click="OpenLauncherLogsFolder">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M3,8 L3,18 L21,18 L21,10 L12,10 L10,8 Z"/>
										</MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="Open Mods" Click="OpenModsFolder">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M3,8 L3,18 L21,18 L21,10 L12,10 L10,8 Z"/>
										</MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="Open Shaders" Click="OpenShadersFolder">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M3,8 L3,18 L21,18 L21,10 L12,10 L10,8 Z"/>
										</MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="Open Resource Packs" Click="OpenResourcePacksFolder">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M3,8 L3,18 L21,18 L21,10 L12,10 L10,8 Z"/>
										</MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="Settings" Click="OpenSettingsFromMenu">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M12,15 A3,3 0 1 1 12,9 A3,3 0 1 1 12,15 Z M12,3 L12,5 M12,19 L12,21 M19.07,4.93 L17.66,6.34 M6.34,17.66 L4.93,19.07 M21,12 L19,12 M5,12 L3,12 M19.07,19.07 L17.66,17.66 M6.34,6.34 L4.93,4.93"/>
										</MenuItem.Icon>
									</MenuItem>
									<Separator/>
									<MenuItem Header="Support &amp; Feedback">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M4,14 A8,8 0 0 1 20,14 M4,14 L4,17 A2,2 0 0 0 6,19 L8,19 L8,12 L6,12 A2,2 0 0 0 4,14 Z M20,14 L20,17 A2,2 0 0 1 18,19 L16,19 L16,12 L18,12 A2,2 0 0 1 20,14 Z"/>
										</MenuItem.Icon>
										<MenuItem Header="Join Discord" Click="OpenDiscord"/>
										<MenuItem Header="Suggest / Report" Click="OpenFeedbackOverlay" Tag="Feature"/>
										<MenuItem Header="Common Questions" Click="OpenCommonQuestions"/>
									</MenuItem>
									<Separator/>
									<MenuItem Header="About Leaf Client" Click="OpenAboutLeafClient">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M12,3 A9,9 0 1 1 12,21 A9,9 0 1 1 12,3 Z M12,8 L12,8.01 M12,11 L12,17"/>
										</MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="Check for Updates" Click="CheckForUpdatesManual">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M20,11 A8,8 0 1 0 12,19 M20,5 L20,11 L14,11"/>
										</MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="Legal Info">
										<MenuItem.Icon>
											<Path Width="16" Height="16" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" Data="M6,3 L14,3 L20,9 L20,21 L6,21 Z M14,3 L14,9 L20,9 M9,14 L17,14 M9,17 L15,17"/>
										</MenuItem.Icon>
										<MenuItem Header="Licenses" Click="OpenLicenses"/>
										<MenuItem Header="Privacy Policy" Click="OpenPrivacyPolicy"/>
										<MenuItem Header="Terms of Service" Click="OpenTermsOfService"/>
										<MenuItem Header="Contact" Click="OpenContact"/>
									</MenuItem>
								</MenuFlyout>
							</Button.Flyout>
							<TextBlock Text="☰" Foreground="{DynamicResource WindowButtonForegroundBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Button>
						<Button Classes="WindowButton" Width="40" Height="40" CornerRadius="8" Click="MinimizeWindow">
							<TextBlock Text="─" Foreground="{DynamicResource WindowButtonForegroundBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5"/>
						</Button>
						<Button Classes="WindowButton" Width="40" Height="40" CornerRadius="8" Click="MaximizeWindow">
							<TextBlock Text="□" Foreground="{DynamicResource WindowButtonForegroundBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Button>
						<Button Classes="WindowButton CloseButton" Width="40" Height="40" CornerRadius="8" Click="CloseWindow">
							<TextBlock Text="✕" Foreground="{DynamicResource WindowButtonForegroundBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Button>
					</StackPanel>
				</Grid>
			</Border>

			<!-- MOTD + Quick Play Bar -->
			<StackPanel Grid.Row="1">

				<!-- MOTD Banner -->
				<Border x:Name="MotdBanner"
						IsVisible="False"
						HorizontalAlignment="Stretch"
						Margin="0,16,0,0"
						Background="#22FFFFFF"
						BorderBrush="#30FFFFFF"
						BorderThickness="0,1,0,1"
						Padding="20,8">
					<TextBlock x:Name="MotdTextBlock"
							   Text=""
							   Foreground="White"
							   FontSize="13"
							   FontWeight="SemiBold"
							   HorizontalAlignment="Center"
							   TextAlignment="Center"
							   VerticalAlignment="Center"
							   TextWrapping="Wrap"
							   Opacity="0.95"
							   LetterSpacing="0.3"/>
				</Border>

				<!-- Quick Play Bar -->
				<Border Background="Transparent" Padding="20,0">
				<Grid>
					<!-- Outer glass card: very transparent so the window's blurred background
					     shows through it instead of appearing as a flat gray panel.
					     A thin bright border keeps the card legible as a distinct surface. -->
					<Border CornerRadius="12"
							Padding="14,12,14,12"
							HorizontalAlignment="Left"
							VerticalAlignment="Center"
							BorderThickness="1"
							Margin="0,8,0,0">
						<Border.Background>
							<SolidColorBrush Color="#38000000"/>
						</Border.Background>
						<Border.BorderBrush>
							<SolidColorBrush Color="#30FFFFFF"/>
						</Border.BorderBrush>
						<Border.BoxShadow>
							0 4 18 0 #40000000
						</Border.BoxShadow>
						<StackPanel Orientation="Horizontal" Spacing="18">
							<!-- "QUICK PLAY" label as plain text, no background pill. -->
							<TextBlock Text="QUICK PLAY"
									   Foreground="#FFFFFFFF"
									   FontWeight="Bold"
									   FontSize="13"
									   LetterSpacing="1"
									   VerticalAlignment="Center"
									   Margin="6,0,0,0"/>

							<!-- Dynamic server buttons will be added here -->
							<StackPanel x:Name="QuickPlayServersContainer"
										Orientation="Horizontal"
										Spacing="8"/>
						</StackPanel>
					</Border>
				</Grid>
			</Border>

			</StackPanel>

			<!-- Main Content Grid -->
			<Grid Grid.Row="2" Margin="20,0,20,20">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<Grid Grid.Column="0">

					<!-- HOME PAGE -->
					<Grid x:Name="GamePage" IsVisible="True">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2.5*"/>
							<!-- Left: Launch Hero -->
							<ColumnDefinition Width="25"/>
							<!-- Spacing -->
							<ColumnDefinition Width="1*"/>
							<!-- Right: Sidebar -->
						</Grid.ColumnDefinitions>

						<!-- 1. LEFT: HERO LAUNCH SECTION -->
						<!-- Added Top Margin to separate from Quick Play -->
						<!-- Added BorderBrush/Thickness -->
						<Border x:Name="LaunchSection" Grid.Column="0"
		CornerRadius="20"
		ClipToBounds="True"
		Margin="0,20,0,0"
		BorderBrush="{DynamicResource PrimaryBorderBrush}"
		BorderThickness="1"
		PointerEntered="OnLaunchSectionPointerEntered"
		PointerExited="OnLaunchSectionPointerExited"
	PointerMoved="OnLaunchSectionPointerMoved">
							<Border.BoxShadow>
								0 10 30 0 #30000000
							</Border.BoxShadow>
							<Grid>
								<Image x:Name="LaunchBgImage" Source="/Assets/bg.jpg" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5">
									<Image.Effect>
										<BlurEffect Radius="4"/>
									</Image.Effect>
									<Image.RenderTransform>
										<TransformGroup>
											<ScaleTransform ScaleX="1.14" ScaleY="1.14"/>
											<TranslateTransform X="0" Y="0"/>
										</TransformGroup>
									</Image.RenderTransform>
								</Image>

								<!-- Darken overlay so the logo + LAUNCH button pop against the blurred scene,
								     and the card reads as a distinct panel on top of the outer window bg. -->
								<Border IsHitTestVisible="False">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
											<GradientStop Color="#80000000" Offset="0"/>
											<GradientStop Color="#66030A16" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
								</Border>

								<Canvas x:Name="ParticleLayer" IsHitTestVisible="False"/>

								<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="25">

									<!-- Logo icon + LEAF CLIENT text side by side -->
									<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
										<Image Source="/Assets/LeafRebrandedTransparent.png" Width="72" Height="72" VerticalAlignment="Center" Stretch="Uniform" Margin="0,0,-44,0">
											<Image.Effect>
												<DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.7" OffsetX="0" OffsetY="2"/>
											</Image.Effect>
										</Image>
										<Image Source="/Assets/logo_text.png" Width="210" Height="55" Stretch="Uniform" VerticalAlignment="Center">
											<Image.Effect>
												<DropShadowEffect BlurRadius="6" Color="Black" Opacity="0.7" OffsetX="0" OffsetY="2"/>
											</Image.Effect>
										</Image>
									</StackPanel>

									<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
										<Ellipse x:Name="OnlineStatusDot" Width="12" Height="12" Fill="#00FF00">
											<Ellipse.Effect>
												<DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.5" OffsetX="1" OffsetY="1"/>
											</Ellipse.Effect>
										</Ellipse>
										<TextBlock x:Name="OnlineCountTextBlock" Text="Checking.." Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center">
											<TextBlock.Effect>
												<DropShadowEffect BlurRadius="2" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1"/>
											</TextBlock.Effect>
										</TextBlock>
									</StackPanel>

									<Button x:Name="LaunchGameButton" Classes="ColorBtn LiftBtn"
											BorderThickness="0"
											CornerRadius="14"
											Width="480"
											Height="64"
											Cursor="Hand"
											HorizontalAlignment="Center"
											Margin="0,15,0,0">
										<Button.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#4CAF50" Offset="0"/>
												<GradientStop Color="#2E7D32" Offset="1"/>
											</LinearGradientBrush>
										</Button.Background>
										<StackPanel Spacing="2">
											<TextBlock Text="LAUNCH GAME"
													   Foreground="White"
													   FontWeight="Black"
													   FontSize="24"
													   LetterSpacing="1"
													   HorizontalAlignment="Center">
												<TextBlock.Effect>
													<DropShadowEffect BlurRadius="2" Color="#40000000" OffsetX="1" OffsetY="1"/>
												</TextBlock.Effect>
											</TextBlock>
										</StackPanel>
									</Button>
									
									<TextBlock x:Name="GameWindowPendingText"
           Text="Game process started. The window may take a few moments to appear."
           Foreground="#AAAAAA"
           FontSize="11"
           HorizontalAlignment="Center"
           Margin="0,8,0,-5"
           IsVisible="False"/>

									<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
										<Image Source="/Assets/LeafRebrandedTransparent.png" Width="14" Height="14"/>
										<TextBlock x:Name="LaunchVersionText"
												   Text="Leaf Client 1.21.4 with Fabric"
												   Foreground="White"
												   FontWeight="SemiBold"
												   FontSize="13">
											<TextBlock.Effect>
												<DropShadowEffect BlurRadius="3" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1"/>
											</TextBlock.Effect>
										</TextBlock>
									</StackPanel>

									<StackPanel x:Name="LaunchProgressPanel" Spacing="8" HorizontalAlignment="Center" IsVisible="False">
										<ProgressBar x:Name="LaunchProgressBar" Width="300" Height="6" Foreground="#4CAF50" Background="#40000000"/>
										<TextBlock x:Name="LaunchProgressText" Text="Ready" Foreground="White" FontSize="12" HorizontalAlignment="Center">
											<TextBlock.Effect>
												<DropShadowEffect Color="Black" BlurRadius="2" OffsetX="1" OffsetY="1"/>
											</TextBlock.Effect>
										</TextBlock>
									</StackPanel>

									<Border x:Name="LaunchErrorBanner" Background="#D32F2F" CornerRadius="8" Padding="15,10" IsVisible="False">
										<Grid ColumnDefinitions="*,Auto">
											<TextBlock x:Name="LaunchErrorBannerText" Text="Error" Foreground="White" FontWeight="Bold"/>
											<Button x:Name="LaunchErrorBannerCloseButton" Grid.Column="1" Content="✕" Background="Transparent" Foreground="White" Margin="10,0,0,0"/>
										</Grid>
									</Border>
								</StackPanel>

								<!-- NEW: Cancel Launch Button (Bottom Right of Banner) -->
								<Button x:Name="CancelLaunchButton"
										HorizontalAlignment="Right"
										VerticalAlignment="Bottom"
										Margin="0,0,20,20"
										Background="#CC000000"
										BorderBrush="#FF5555"
										BorderThickness="1"
										CornerRadius="8"
										Padding="12,6"
										Cursor="Hand"
										IsVisible="False"
										Click="CancelLaunchButton_Click">
									<StackPanel Orientation="Horizontal" Spacing="6">
										<TextBlock Text="✕" Foreground="#FF5555" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
										<TextBlock Text="CANCEL" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
									</StackPanel>
									<Button.Styles>
										<Style Selector="Button:pointerover /template/ ContentPresenter">
											<Setter Property="Background" Value="#E6000000"/>
											<Setter Property="BorderBrush" Value="#FF7777"/>
										</Style>
									</Button.Styles>
								</Button>

							</Grid>
						</Border>

						<!-- 2. RIGHT: SIDEBAR COLUMN (News only — stats now live in the footer bar) -->
						<Grid Grid.Column="2">
							<Grid.RowDefinitions>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<!-- News Feed -->
							<Grid Grid.Row="0" x:Name="NewsSectionGrid">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="*"/>
									<RowDefinition Height="*"/>
								</Grid.RowDefinitions>

								<TextBlock Text="LATEST UPDATES" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="ExtraBold" FontSize="14" Margin="5,0,0,10" Opacity="0.7"/>

								<!-- News Item 1 — now shows the UI & UX Overhaul announcement -->
								<Border Grid.Row="1" Background="{DynamicResource CardBackgroundColor}" CornerRadius="16" ClipToBounds="True" Cursor="Hand" Margin="0,0,0,15" PointerEntered="OnNewsItem1PointerEntered" PointerExited="OnNewsItem1PointerExited">
									<Grid>
										<Image x:Name="NewsItem1Image" Source="/Assets/NewLookNewFeelBanner.jpg" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5">
											<Image.RenderTransform>
												<ScaleTransform ScaleX="1" ScaleY="1"/>
											</Image.RenderTransform>
										</Image>

										<StackPanel VerticalAlignment="Bottom" Margin="15">
											<!-- MAJOR UPDATE badge: smooth animated purple gradient.
											     Brush is assigned from code-behind on init and the C#
											     animation loop mutates its GradientStops' Colors over
											     time for a breathing/shifting purple effect. -->
											<Border x:Name="MajorUpdateBadge" CornerRadius="4" HorizontalAlignment="Left" Padding="7,2,7,2" Margin="0,0,0,5">
												<Border.Background>
													<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
														<GradientStop Color="#7B1FA2" Offset="0"/>
														<GradientStop Color="#CE93D8" Offset="1"/>
													</LinearGradientBrush>
												</Border.Background>
												<TextBlock Text="MAJOR UPDATE" Foreground="White" FontSize="9" FontWeight="Bold"/>
											</Border>
											<TextBlock Text="UI &amp; UX Overhaul" Foreground="White" FontWeight="Bold" FontSize="16">
												<TextBlock.Effect>
													<DropShadowEffect Color="Black" BlurRadius="2" Opacity="0.8" OffsetX="1" OffsetY="1"/>
												</TextBlock.Effect>
											</TextBlock>
											<TextBlock Text="A brand new look on Leaf Client" Foreground="#EEEEEE" FontSize="11">
												<TextBlock.Effect>
													<DropShadowEffect Color="Black" BlurRadius="2" Opacity="0.8" OffsetX="1" OffsetY="1"/>
												</TextBlock.Effect>
											</TextBlock>
										</StackPanel>
									</Grid>
								</Border>

								<!-- News Item 2 — now shows the Leaf+ subscription card -->
								<Border Grid.Row="2" Background="{DynamicResource CardBackgroundColor}" CornerRadius="16" ClipToBounds="True" Cursor="Hand" PointerEntered="OnNewsItem2PointerEntered" PointerExited="OnNewsItem2PointerExited">
									<Grid>
										<Image x:Name="NewsItem2Image" Source="/Assets/LeafPlusLauncherBanner.jpg" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5">
											<Image.RenderTransform>
												<ScaleTransform ScaleX="1" ScaleY="1"/>
											</Image.RenderTransform>
										</Image>

										<StackPanel VerticalAlignment="Bottom" Margin="15">
											<Border CornerRadius="4" HorizontalAlignment="Left" Padding="7,2,7,2" Margin="0,0,0,5">
												<Border.Background>
													<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
														<GradientStop Color="#7B1FA2" Offset="0"/>
														<GradientStop Color="#CE93D8" Offset="1"/>
													</LinearGradientBrush>
												</Border.Background>
												<TextBlock Text="SUBSCRIPTION" Foreground="White" FontSize="9" FontWeight="Bold"/>
											</Border>
											<TextBlock Text="Leaf+ just for you" Foreground="White" FontWeight="Bold" FontSize="16">
												<TextBlock.Effect>
													<DropShadowEffect Color="Black" BlurRadius="2" Opacity="0.8" OffsetX="1" OffsetY="1"/>
												</TextBlock.Effect>
											</TextBlock>
											<TextBlock Text="Become a supporter in Leaf's early stages, and get a collection of OG cosmetics before they go off sale"
													   Foreground="#EEEEEE" FontSize="11" TextWrapping="Wrap" Margin="0,2,15,0">
												<TextBlock.Effect>
													<DropShadowEffect Color="Black" BlurRadius="2" Opacity="0.8" OffsetX="1" OffsetY="1"/>
												</TextBlock.Effect>
											</TextBlock>
										</StackPanel>
									</Grid>
								</Border>
							</Grid>
						</Grid>
					</Grid>

					<Grid x:Name="VersionsPage" IsVisible="False">

						<!-- Profiles Page -->
						<Border Background="{DynamicResource TertiaryBackgroundBrush}" CornerRadius="18" Padding="30">
							<Grid RowDefinitions="Auto,*">

								<!-- Header -->
								<Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
									<StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
										<StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
											<Border Width="3" Height="22" CornerRadius="2" VerticalAlignment="Center">
												<Border.Background>
													<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
														<GradientStop Offset="0" Color="#9333EA"/>
														<GradientStop Offset="1" Color="#6D28D9"/>
													</LinearGradientBrush>
												</Border.Background>
											</Border>
											<TextBlock Text="PROFILES"
													   Foreground="#E5E7EB" FontWeight="Black"
													   FontSize="20" LetterSpacing="1.5" VerticalAlignment="Center"/>
										</StackPanel>
										<TextBlock Text="Each profile keeps its own version, mods and memory settings."
												   Foreground="#6B7280"
												   FontSize="12" Margin="0,4,0,0"/>
									</StackPanel>
									<Border Grid.Column="1" x:Name="NewProfileButton"
											CornerRadius="12" Padding="18,11"
											VerticalAlignment="Center" Cursor="Hand"
											PointerPressed="OnNewProfileClickBorder"
											BoxShadow="0 6 18 0 #6A7B2CBF"
											RenderTransformOrigin="0.5,0.5"
											RenderTransform="scale(1.0)">
										<Border.Background>
											<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
												<GradientStop Color="#9333EA" Offset="0"/>
												<GradientStop Color="#7B2CBF" Offset="0.55"/>
												<GradientStop Color="#6B21A8" Offset="1"/>
											</LinearGradientBrush>
										</Border.Background>
										<Border.Transitions>
											<Transitions>
												<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
											</Transitions>
										</Border.Transitions>
										<StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
											<Border Width="20" Height="20" CornerRadius="10"
													Background="#33FFFFFF" VerticalAlignment="Center">
												<TextBlock Text="+" FontSize="16" FontWeight="Black" Foreground="White"
														   HorizontalAlignment="Center" VerticalAlignment="Center"
														   Margin="0,-2,0,0"/>
											</Border>
											<TextBlock Text="NEW PROFILE" FontSize="12" FontWeight="Bold"
													   Foreground="White" LetterSpacing="1" VerticalAlignment="Center"/>
										</StackPanel>
									</Border>
								</Grid>

								<!-- Profiles List -->
								<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
									<StackPanel Spacing="0">
										<StackPanel x:Name="ProfilesListPanel" Spacing="10"/>

										<!-- Empty State -->
										<Border x:Name="NoProfilesMessage"
												Background="{DynamicResource CardBackgroundColor}"
												CornerRadius="16" Padding="48"
												IsVisible="True">
											<StackPanel Spacing="14" HorizontalAlignment="Center">
												<TextBlock Text="🎮" FontSize="36" HorizontalAlignment="Center"/>
												<TextBlock Text="No profiles yet"
														   Foreground="{DynamicResource PrimaryForegroundBrush}"
														   FontWeight="Bold" FontSize="18"
														   HorizontalAlignment="Center"/>
												<TextBlock Text="Create a profile to manage different Minecraft versions and mod configurations."
														   Foreground="{DynamicResource SecondaryForegroundBrush}"
														   FontSize="13" TextWrapping="Wrap"
														   HorizontalAlignment="Center"
														   TextAlignment="Center"
														   MaxWidth="380"/>
											</StackPanel>
										</Border>
									</StackPanel>
								</ScrollViewer>

							</Grid>
						</Border>

						<!-- Legacy version controls (hidden, referenced from code-behind) -->
						<Grid IsVisible="False">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="400"/>
							</Grid.ColumnDefinitions>
							<StackPanel Grid.Column="0">
								<StackPanel x:Name="MajorVersionsStackPanel" Spacing="20"/>
							</StackPanel>
							<Border x:Name="VersionDetailsSidebar" Grid.Column="1" IsVisible="False">
								<StackPanel>
									<TextBlock x:Name="VersionTitle" Text=""/>
									<Border x:Name="VersionBannerContainer" Height="1">
										<Image x:Name="VersionBanner" Source="/Assets/mcversionsbanner.jpg"/>
									</Border>
									<ComboBox x:Name="VersionDropdown">
										<ComboBox.ItemTemplate>
											<DataTemplate x:DataType="views:VersionInfo">
												<TextBlock Text="{Binding DisplayVersion}"/>
											</DataTemplate>
										</ComboBox.ItemTemplate>
									</ComboBox>
									<TextBlock x:Name="VersionType" Text=""/>
									<TextBlock x:Name="VersionLoader" Text=""/>
									<TextBlock x:Name="VersionDate" Text=""/>
									<TextBlock x:Name="VersionDescription" Text=""/>
									<TextBlock x:Name="VersionOptiFineSupport" Text=""/>
									<Button x:Name="AddonFabricButton" Click="OnAddonFabricClick">
										<Border x:Name="AddonFabricBg" Width="1" Height="1"/>
									</Button>
									<Button x:Name="AddonVanillaButton" Click="OnAddonVanillaClick">
										<Border x:Name="AddonVanillaBg" Width="1" Height="1"/>
									</Button>
								</StackPanel>
							</Border>
						</Grid>

					</Grid>

					<!-- Servers Page -->
					<Grid x:Name="ServersPage" IsVisible="False">
						<Border Background="{DynamicResource TertiaryBackgroundBrush}" CornerRadius="18" Padding="0">
							<Grid RowDefinitions="Auto,*">

								<!-- Header bar -->
								<Border Grid.Row="0"
										Background="{DynamicResource SecondaryBackgroundBrush}"
										CornerRadius="18,18,0,0"
										BorderBrush="{DynamicResource PrimaryBorderBrush}"
										BorderThickness="0,0,0,1"
										Padding="28,18">
									<Grid ColumnDefinitions="*,Auto,Auto">
										<StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
											<StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
												<Border Width="3" Height="22" CornerRadius="2" VerticalAlignment="Center">
													<Border.Background>
														<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
															<GradientStop Offset="0" Color="#9333EA"/>
															<GradientStop Offset="1" Color="#6D28D9"/>
														</LinearGradientBrush>
													</Border.Background>
												</Border>
												<TextBlock Text="SERVERS"
														   Foreground="#E5E7EB" FontWeight="Black"
														   FontSize="20" LetterSpacing="1.5" VerticalAlignment="Center"/>
											</StackPanel>
											<TextBlock Text="Join your favorite worlds"
													   Foreground="#6B7280"
													   FontSize="12" Margin="0,4,0,0"/>
										</StackPanel>
										<Button Grid.Column="1"
												Classes="LiftBtn"
												Background="{DynamicResource HoverBackgroundBrush}"
												Foreground="{DynamicResource PrimaryForegroundBrush}"
												BorderThickness="1"
												BorderBrush="{DynamicResource PrimaryBorderBrush}"
												CornerRadius="9" Padding="16,9" FontWeight="SemiBold"
												Cursor="Hand" Margin="0,0,10,0"
												Click="RefreshServersButton_Click">
											<StackPanel Orientation="Horizontal" Spacing="7">
												<TextBlock Text="🔄" FontSize="13"/>
												<TextBlock Text="Refresh" FontSize="13"/>
											</StackPanel>
										</Button>
										<Button Grid.Column="2"
												Classes="LiftBtn GlowAccent"
												Background="{DynamicResource PrimaryAccentBrush}"
												Foreground="{DynamicResource AccentButtonForegroundBrush}"
												BorderThickness="0" CornerRadius="9"
												Padding="16,9" FontWeight="Bold" Cursor="Hand"
												Click="AddServerButton_Click">
											<StackPanel Orientation="Horizontal" Spacing="7">
												<TextBlock Text="+" FontSize="16" FontWeight="Bold"/>
												<TextBlock Text="Add Server" FontSize="13"/>
											</StackPanel>
										</Button>
									</Grid>
								</Border>

								<!-- Scrollable body -->
								<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,24,28,28">
									<StackPanel Spacing="28">

										<!-- FEATURED SERVERS -->
										<StackPanel Spacing="14">
											<StackPanel Orientation="Horizontal" Spacing="10">
												<TextBlock Text="FEATURED SERVERS" FontSize="11" FontWeight="Bold"
														   LetterSpacing="1.5"
														   Foreground="{DynamicResource SecondaryForegroundBrush}"
														   VerticalAlignment="Center"/>
												<Border Background="{DynamicResource PrimaryAccentBrush}"
														CornerRadius="4" Padding="6,2">
													<TextBlock Text="Official" FontSize="9" FontWeight="Bold" Foreground="White"/>
												</Border>
											</StackPanel>

											<!-- Featured servers will be populated dynamically here -->
											<StackPanel x:Name="FeaturedServersPanel" Orientation="Vertical" HorizontalAlignment="Stretch" Spacing="12"/>
										</StackPanel>

										<!-- YOUR SERVERS -->
										<StackPanel Spacing="14">
											<TextBlock Text="YOUR SERVERS" FontSize="11" FontWeight="Bold"
													   LetterSpacing="1.5"
													   Foreground="{DynamicResource SecondaryForegroundBrush}"/>
											<StackPanel x:Name="ServersWrapPanel" Orientation="Vertical" HorizontalAlignment="Stretch" Spacing="0"/>
											<Border x:Name="NoServersMessage" Background="{DynamicResource CardBackgroundColor}"
													CornerRadius="12" Padding="32,24" IsVisible="True">
												<StackPanel Spacing="10" HorizontalAlignment="Center">
													<TextBlock Text="🌐" FontSize="36" HorizontalAlignment="Center" Opacity="0.4"/>
													<TextBlock Text="No custom servers yet" Foreground="{DynamicResource PrimaryForegroundBrush}"
															   FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
													<TextBlock Text="Hit Add Server to save a server address"
															   Foreground="{DynamicResource SecondaryForegroundBrush}"
															   FontSize="12" HorizontalAlignment="Center"/>
												</StackPanel>
											</Border>
										</StackPanel>

									</StackPanel>
								</ScrollViewer>
							</Grid>
						</Border>
					</Grid>

										<Grid x:Name="ModsPage" IsVisible="False">
						<Border CornerRadius="18" ClipToBounds="True">
							<Border.Background>
								<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
									<GradientStop Offset="0" Color="#0D1520"/>
									<GradientStop Offset="0.5" Color="#0A1018"/>
									<GradientStop Offset="1" Color="#080C14"/>
								</LinearGradientBrush>
							</Border.Background>

							<Grid RowDefinitions="Auto,Auto,*" Margin="24,24,24,24">

								<!-- Row 0: accent-bar header + action buttons -->
								<Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,0,0,14" VerticalAlignment="Center">
									<Border Grid.Column="0" Width="3" Height="22" CornerRadius="2" Margin="0,0,14,0" VerticalAlignment="Center">
										<Border.Background>
											<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
												<GradientStop Offset="0" Color="#9333EA"/>
												<GradientStop Offset="1" Color="#6D28D9"/>
											</LinearGradientBrush>
										</Border.Background>
									</Border>
									<TextBlock Grid.Column="1" x:Name="ModsPageTitle" Text="MODS"
											   Foreground="#E5E7EB" FontWeight="Black"
											   FontSize="20" LetterSpacing="1.5" VerticalAlignment="Center"/>
									<TextBlock Grid.Column="2" x:Name="ModsPageSubtitle"
											   Text="Manage installed mods and resource packs"
											   Foreground="#4B5563" FontSize="11" FontWeight="SemiBold"
											   VerticalAlignment="Center" Margin="14,4,0,0"/>
									<Button Grid.Column="3" x:Name="ModsAddLocalBtn"
											   Background="#0F1A24" Foreground="#E5E7EB" BorderBrush="#1C2A38"
											   BorderThickness="1" CornerRadius="10" Padding="14,8" FontWeight="Bold"
											   FontSize="11" Cursor="Hand" Margin="0,0,8,0" Click="AddLocalMods_Click">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x1F4C1;" FontSize="12" VerticalAlignment="Center"/>
											<TextBlock Text="ADD LOCAL" LetterSpacing="0.8" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button Grid.Column="4" x:Name="ModsBrowseBtn"
											   Foreground="White" BorderThickness="0" CornerRadius="10"
											   Padding="14,8" FontWeight="Bold" FontSize="11" Cursor="Hand"
											   Click="OpenModBrowser">
										<Button.Background>
											<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
												<GradientStop Offset="0" Color="#9333EA"/>
												<GradientStop Offset="1" Color="#6D28D9"/>
											</LinearGradientBrush>
										</Button.Background>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="+" FontSize="14" FontWeight="Black" VerticalAlignment="Center"/>
											<TextBlock Text="BROWSE MODS" LetterSpacing="0.8" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
								</Grid>

								<!-- Row 1: pill tab switcher -->
								<StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,0,0,14">
									<Border x:Name="ModsTab_Mods" Tag="mods" CornerRadius="14" Padding="14,8,14,6"
											   Background="#9333EA" Cursor="Hand" PointerPressed="OnModsTabTapped">
										<TextBlock Text="Mods" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
									</Border>
									<Border x:Name="ModsTab_Rp" Tag="rp" CornerRadius="14" Padding="14,8,14,6"
											   Background="#0F1A24" BorderBrush="#1C2A38" BorderThickness="1"
											   Cursor="Hand" PointerPressed="OnModsTabTapped">
										<TextBlock Text="Resource Packs" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
									</Border>
								</StackPanel>

								<!-- Row 2: content — Mods scroll view OR embedded ResourcePacksPageView -->
								<Grid Grid.Row="2">
									<ScrollViewer x:Name="ModsContent" VerticalScrollBarVisibility="Auto">
										<StackPanel Spacing="20">
											<Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="20" Margin="0,20,0,0">
												<Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
													<!-- Icon -->
													<Border Grid.Column="0" Grid.Row="0" Background="{DynamicResource PrimaryAccentBrush}" Width="48" Height="48" CornerRadius="8" Margin="0,0,15,0">
														<TextBlock Text="✨" Foreground="{DynamicResource AccentButtonForegroundBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
													</Border>

													<!-- Title + subtitle -->
													<StackPanel Grid.Column="1" Grid.Row="0" Spacing="5" VerticalAlignment="Center">
														<TextBlock Text="OptiFine for Fabric Modpack" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
														<TextBlock Text="50+ Comprehensive graphics and performance enhancements mods." Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>

													<!-- Toggle -->
													<ToggleSwitch x:Name="OptiFineToggle" Grid.Column="2" Grid.Row="0" IsChecked="False" Margin="15,0"/>

													<!-- Info message -->
													<TextBlock x:Name="ModsInfoText"
											   Grid.Column="1" Grid.Row="1"
											   Grid.ColumnSpan="2"
											   Text="This may be unstable."
											   Margin="0,6,0,0"
											   Foreground="{DynamicResource PrimaryForegroundBrush}"
											   FontSize="14"/>
												</Grid>
											</Border>

											<!-- Lithium Mod Entry - Always Required -->
											<Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="20">
												<Grid ColumnDefinitions="Auto,*,Auto">
													<Border Grid.Column="0" Background="{DynamicResource PrimaryAccentBrush}" Width="48" Height="48" CornerRadius="8" Margin="0,0,15,0">
														<TextBlock Text="⚡" Foreground="{DynamicResource AccentButtonForegroundBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
													</Border>
													<StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
														<TextBlock Text="Lithium" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
														<TextBlock Text="Game logic optimization — always included" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="15,0" VerticalAlignment="Center">
														<TextBlock Text="✓" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
														<TextBlock Text="Required" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="12" VerticalAlignment="Center"/>
													</StackPanel>
												</Grid>
											</Border>

											<!-- Sodium Mod Entry - Always Required -->
											<Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="20">
												<Grid ColumnDefinitions="Auto,*,Auto">
													<Border Grid.Column="0" Background="{DynamicResource PrimaryAccentBrush}" Width="48" Height="48" CornerRadius="8" Margin="0,0,15,0">
														<TextBlock Text="🚀" Foreground="{DynamicResource AccentButtonForegroundBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
													</Border>
													<StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
														<TextBlock Text="Sodium" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
														<TextBlock Text="High-performance rendering engine — always included" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="15,0" VerticalAlignment="Center">
														<TextBlock Text="✓" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
														<TextBlock Text="Required" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="12" VerticalAlignment="Center"/>
													</StackPanel>
												</Grid>
											</Border>

											<!-- FerriteCore Mod Entry - Always Required -->
											<Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="20">
												<Grid ColumnDefinitions="Auto,*,Auto">
													<Border Grid.Column="0" Background="{DynamicResource PrimaryAccentBrush}" Width="48" Height="48" CornerRadius="8" Margin="0,0,15,0">
														<TextBlock Text="🧲" Foreground="{DynamicResource AccentButtonForegroundBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
													</Border>
													<StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
														<TextBlock Text="FerriteCore" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
														<TextBlock Text="Reduces memory usage and improves GC performance — always included" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="15,0" VerticalAlignment="Center">
														<TextBlock Text="✓" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
														<TextBlock Text="Required" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="12" VerticalAlignment="Center"/>
													</StackPanel>
												</Grid>
											</Border>

											<!-- ImmediatelyFast Mod Entry - Always Required -->
											<Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="20">
												<Grid ColumnDefinitions="Auto,*,Auto">
													<Border Grid.Column="0" Background="{DynamicResource PrimaryAccentBrush}" Width="48" Height="48" CornerRadius="8" Margin="0,0,15,0">
														<TextBlock Text="⚡" Foreground="{DynamicResource AccentButtonForegroundBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
													</Border>
													<StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
														<TextBlock Text="ImmediatelyFast" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
														<TextBlock Text="Optimizes HUD, UI and entity rendering — always included" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="15,0" VerticalAlignment="Center">
														<TextBlock Text="✓" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
														<TextBlock Text="Required" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="12" VerticalAlignment="Center"/>
													</StackPanel>
												</Grid>
											</Border>

											<!-- EntityCulling Mod Entry - Always Required -->
											<Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="20">
												<Grid ColumnDefinitions="Auto,*,Auto">
													<Border Grid.Column="0" Background="{DynamicResource PrimaryAccentBrush}" Width="48" Height="48" CornerRadius="8" Margin="0,0,15,0">
														<TextBlock Text="👁" Foreground="{DynamicResource AccentButtonForegroundBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
													</Border>
													<StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
														<TextBlock Text="EntityCulling" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
														<TextBlock Text="Async entity visibility culling — always included" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="15,0" VerticalAlignment="Center">
														<TextBlock Text="✓" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
														<TextBlock Text="Required" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="12" VerticalAlignment="Center"/>
													</StackPanel>
												</Grid>
											</Border>

											<!-- ModernFix Mod Entry - Always Required -->
											<Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="20">
												<Grid ColumnDefinitions="Auto,*,Auto">
													<Border Grid.Column="0" Background="{DynamicResource PrimaryAccentBrush}" Width="48" Height="48" CornerRadius="8" Margin="0,0,15,0">
														<TextBlock Text="🔧" Foreground="{DynamicResource AccentButtonForegroundBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
													</Border>
													<StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
														<TextBlock Text="ModernFix" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
														<TextBlock Text="Fixes startup time, memory and tickrate bugs — always included" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="15,0" VerticalAlignment="Center">
														<TextBlock Text="✓" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
														<TextBlock Text="Required" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="12" VerticalAlignment="Center"/>
													</StackPanel>
												</Grid>
											</Border>

											<!-- ========== ADD USER MODS SECTION HERE ========== -->
											<StackPanel Margin="0,20,0,0" Spacing="10">
												<TextBlock Text="Installed Mods" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}"/>
												<Border x:Name="NoUserModsMessage" Background="{DynamicResource CardBackgroundColor}" CornerRadius="8" Padding="20" HorizontalAlignment="Stretch" IsVisible="False">
													<TextBlock Text="No mods installed. Browse and install mods from the mod browser above."
											   Foreground="{DynamicResource SecondaryForegroundBrush}" TextAlignment="Center"/>
												</Border>
												<StackPanel x:Name="UserModsPanel" Spacing="8"/>
											</StackPanel>
											<!-- ========== END USER MODS SECTION ========== -->

										</StackPanel>
									</ScrollViewer>
									<pages:ResourcePacksPageView x:Name="ResourcePacksPage" IsVisible="False"/>
								</Grid>

							</Grid>
						</Border>
					</Grid>
					<Grid x:Name="SettingsPage" IsVisible="False" ClipToBounds="False">
						<Border CornerRadius="18" ClipToBounds="True">
							<Border.Background>
								<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
									<GradientStop Offset="0" Color="#0D1520"/>
									<GradientStop Offset="0.5" Color="#0A1018"/>
									<GradientStop Offset="1" Color="#080C14"/>
								</LinearGradientBrush>
							</Border.Background>
							<TabControl TabStripPlacement="Left" Padding="0">
								<TabControl.Styles>
									<Style Selector="TabControl">
										<Setter Property="Template">
											<ControlTemplate>
												<Grid ColumnDefinitions="240,*">
													<Border Grid.Column="0" Background="#0A1218"
															BorderBrush="{DynamicResource PrimaryBorderBrush}" BorderThickness="0,0,1,0">
														<Grid RowDefinitions="Auto,*">
															<StackPanel Orientation="Horizontal" Spacing="12" Margin="25,28,0,22">
																<Border Width="3" Height="22" CornerRadius="2" VerticalAlignment="Center">
																	<Border.Background>
																		<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
																			<GradientStop Offset="0" Color="#9333EA"/>
																			<GradientStop Offset="1" Color="#6D28D9"/>
																		</LinearGradientBrush>
																	</Border.Background>
																</Border>
																<TextBlock Text="SETTINGS" Foreground="#E5E7EB" FontWeight="Black" FontSize="22" LetterSpacing="1.5" VerticalAlignment="Center"/>
															</StackPanel>
															<ScrollViewer Grid.Row="1">
																<ItemsPresenter Name="PART_ItemsPresenter" ItemsPanel="{TemplateBinding ItemsPanel}"/>
															</ScrollViewer>
														</Grid>
													</Border>
													<ScrollViewer Grid.Column="1" Background="Transparent" VerticalScrollBarVisibility="Auto">
														<ContentPresenter Name="PART_SelectedContentHost" Margin="30"
																		  Content="{TemplateBinding SelectedContent}"
																		  ContentTemplate="{TemplateBinding SelectedContentTemplate}"/>
													</ScrollViewer>
												</Grid>
											</ControlTemplate>
										</Setter>
									</Style>
									<Style Selector="TabItem">
										<Setter Property="FontSize" Value="13"/>
										<Setter Property="FontWeight" Value="SemiBold"/>
										<Setter Property="Foreground" Value="#9CA3AF"/>
										<Setter Property="Margin" Value="14,0,14,4"/>
										<Setter Property="Padding" Value="18,11,14,11"/>
										<Setter Property="MinHeight" Value="44"/>
										<Setter Property="CornerRadius" Value="10"/>
										<Setter Property="HorizontalContentAlignment" Value="Left"/>
										<Setter Property="Cursor" Value="Hand"/>
										<Setter Property="Template">
											<ControlTemplate>
												<Grid>
													<Border Name="PART_LayoutRoot"
																	Background="{TemplateBinding Background}"
																	CornerRadius="{TemplateBinding CornerRadius}"
																	Padding="{TemplateBinding Padding}">
														<Border.Transitions>
															<Transitions>
																<BrushTransition Property="Background" Duration="0:0:0.18"/>
															</Transitions>
														</Border.Transitions>
														<ContentPresenter Name="PART_ContentPresenter"
																		  Content="{TemplateBinding Header}"
																		  HorizontalAlignment="Left"
																		  VerticalAlignment="Center"/>
													</Border>
													<Border Name="PART_AccentBar" Width="3" Height="22"
																	CornerRadius="2" HorizontalAlignment="Left"
																	VerticalAlignment="Center" Margin="3,0,0,0"
																	Opacity="0" IsHitTestVisible="False">
														<Border.Background>
															<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
																<GradientStop Offset="0" Color="#9333EA"/>
																<GradientStop Offset="1" Color="#6D28D9"/>
															</LinearGradientBrush>
														</Border.Background>
														<Border.Transitions>
															<Transitions>
																<DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
															</Transitions>
														</Border.Transitions>
													</Border>
												</Grid>
											</ControlTemplate>
										</Setter>
									</Style>
									<Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
										<Setter Property="Background" Value="#0FFFFFFF"/>
										<Setter Property="Cursor" Value="Hand"/>
									</Style>
									<Style Selector="TabItem:pointerover">
										<Setter Property="Foreground" Value="#E5E7EB"/>
									</Style>
									<Style Selector="TabItem:pointerover /template/ Path">
										<Setter Property="Stroke" Value="#E5E7EB"/>
									</Style>
									<Style Selector="TabItem:selected">
										<Setter Property="Foreground" Value="#FFFFFF"/>
									</Style>
									<Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
										<Setter Property="Background" Value="#1A9333EA"/>
									</Style>
									<Style Selector="TabItem:selected /template/ Border#PART_AccentBar">
										<Setter Property="Opacity" Value="1"/>
									</Style>
									<Style Selector="TabItem:selected /template/ Path">
										<Setter Property="Stroke" Value="#C4B5FD"/>
									</Style>
								</TabControl.Styles>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M12,8 A4,4 0 1 1 12,16 A4,4 0 1 1 12,8 Z M12,2 L12,5 M12,19 L12,22 M4.22,4.22 L6.34,6.34 M17.66,17.66 L19.78,19.78 M2,12 L5,12 M19,12 L22,12 M4.22,19.78 L6.34,17.66 M17.66,6.34 L19.78,4.22"/>
											<TextBlock Text="General" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="25">
										<Border BorderBrush="#152030" BorderThickness="0,0,0,1" Padding="0,0,0,15">
											<TextBlock Text="GENERAL" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20"/>
										</Border>
										<Border Background="#0C1620" CornerRadius="12" Padding="20">
											<StackPanel Spacing="20">
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Launch on Startup" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Automatically start Leaf Client when your computer opens" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="LaunchOnStartupToggle" Grid.Column="1" IsChecked="False"/>
												</Grid>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Minimize to Tray" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Keep Leaf Client running in the background" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="MinimizeToTrayToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Discord Rich Presence" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Show what you're playing on Discord" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="DiscordRichPresenceToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Show Username in Discord" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Display your Minecraft username in Discord Rich Presence" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="ShowUsernameInDiscordRichPresenceToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Developer Test Mode" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Build and use local LeafClient mod JAR instead of downloading" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="TestModeToggle" Grid.Column="1" IsChecked="False"/>
												</Grid>
												<Border x:Name="TestModePathPanel" IsVisible="False" Background="#0C1620" CornerRadius="8" Padding="12">
													<StackPanel Spacing="6">
														<TextBlock Text="Mod Project Path" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="12" FontWeight="Bold"/>
														<TextBox x:Name="TestModePathBox"
																 Watermark="Path to LeafClientMod project..."
																 FontSize="12"
																 Background="{DynamicResource TertiaryBackgroundBrush}"
																 Foreground="{DynamicResource PrimaryForegroundBrush}"/>
													</StackPanel>
												</Border>
												<Separator Background="#152030"/>
												<StackPanel Spacing="10">
													<TextBlock Text="LAUNCHER VISIBILITY ON GAME LAUNCH" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
													<TextBlock Text="Select which option the Launcher should take after the game has launched" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													<StackPanel Orientation="Vertical" Spacing="8" Margin="0,5,0,0">
														<RadioButton x:Name="LauncherVisibilityKeepOpenRadio" GroupName="LauncherVisibility" IsChecked="True"
																	 Foreground="{DynamicResource PrimaryForegroundBrush}" Content="Keep Open">
															<RadioButton.Tag>
																<Border Background="{DynamicResource PrimaryAccentBrush}"
																		CornerRadius="4"
																		Padding="6,2"
																		Margin="5,0,0,0"
																		VerticalAlignment="Center">
																	<TextBlock Text="Recommended" FontWeight="Bold" FontSize="10"
																			   Foreground="{DynamicResource AccentButtonForegroundBrush}"/>
																</Border>
															</RadioButton.Tag>
														</RadioButton>
														<TextBlock Margin="25, -5, 0, 0" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"
																   Text="Launcher will remain open in background"/>
														<RadioButton x:Name="LauncherVisibilityHideRadio" GroupName="LauncherVisibility"
																	 Foreground="{DynamicResource PrimaryForegroundBrush}" Content="Hide"/>
														<TextBlock Margin="25, -5, 0, 0" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"
																   Text="Launcher will hide when the game instance spawns"/>
													</StackPanel>
												</StackPanel>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M4.5,16.5 L3,22 L8.5,20.5 M14.5,5.5 L18.5,9.5 M15,3 L21,3 L21,9 M21,3 L13.5,10.5 M14.5,11.5 L19,16 A2,2 0 0 1 19,18.5 L14.5,23 L4,23 A2,2 0 0 1 4,21 L4,18.5 L7.5,15 M7.5,4.5 A3,3 0 0 1 10.5,7.5 L10.5,10.5 A3,3 0 0 1 7.5,13.5 A3,3 0 0 1 4.5,10.5 L4.5,7.5 A3,3 0 0 1 7.5,4.5 Z"/>
											<TextBlock Text="Launch Options" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="25">
										<Border BorderBrush="#152030" BorderThickness="0,0,0,1" Padding="0,0,0,15">
											<TextBlock Text="LAUNCH OPTIONS" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20"/>
										</Border>
										<Border Background="#0C1620" CornerRadius="12" Padding="20">
											<StackPanel Spacing="20">

												<!-- Min RAM Slider -->
												<StackPanel Spacing="10">
													<Grid ColumnDefinitions="*,Auto">
														<StackPanel Grid.Column="0" Spacing="2">
															<TextBlock Text="Min. RAM Allocation" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
															<TextBlock Text="Minimum memory allocated to Minecraft" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
														</StackPanel>
														<TextBlock x:Name="MinRamValueText" Grid.Column="1" Text="1024 MB" Foreground="{DynamicResource PrimaryAccentBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
													</Grid>
													<Slider x:Name="MinRamSlider" Minimum="512" Maximum="16384" TickFrequency="512" IsSnapToTickEnabled="True"/>
												</StackPanel>

												<Separator Background="#152030"/>

												<!-- Max RAM Slider -->
												<StackPanel Spacing="10">
													<Grid ColumnDefinitions="*,Auto">
														<StackPanel Grid.Column="0" Spacing="2">
															<TextBlock Text="Max. RAM Allocation" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
															<TextBlock Text="Maximum memory allocated to Minecraft" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
														</StackPanel>
														<TextBlock x:Name="MaxRamValueText" Grid.Column="1" Text="8 GB" Foreground="{DynamicResource PrimaryAccentBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
													</Grid>
													<Slider x:Name="MaxRamSlider" Minimum="1024" Maximum="32768" TickFrequency="1024" IsSnapToTickEnabled="True"/>
												</StackPanel>

												<Separator Background="#152030"/>

												<!-- JVM Args -->
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="JVM Arguments" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Custom Java Virtual Machine arguments" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<Button x:Name="JvmArgumentsEditButton" Grid.Column="1" Background="{DynamicResource PrimaryAccentBrush}" Foreground="{DynamicResource AccentButtonForegroundBrush}" BorderThickness="0" CornerRadius="8" Padding="15,8" FontWeight="Bold" Cursor="Hand">
														<TextBlock Text="EDIT"/>
													</Button>
												</Grid>

												<Separator Background="#152030"/>

												<!-- Quick Join -->
												<StackPanel Spacing="10">
													<TextBlock Text="Custom Server Quick Join" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
													<Grid ColumnDefinitions="2*,*,Auto">
														<TextBox x:Name="QuickJoinServerAddressTextBox" Grid.Column="0" Watermark="playserver.com" Margin="0,0,10,0"/>
														<TextBox x:Name="QuickJoinServerPortTextBox" Grid.Column="1" Watermark="port" Foreground="{DynamicResource DisabledForegroundBrush}" Margin="0,0,10,0"/>
														<Button Grid.Column="2" Background="{DynamicResource PrimaryAccentBrush}" Foreground="{DynamicResource AccentButtonForegroundBrush}" BorderThickness="0" CornerRadius="8" Padding="15,8" FontWeight="Bold" Cursor="Hand">
															<TextBlock Text="SAVE"/>
														</Button>
													</Grid>
												</StackPanel>

												<Separator Background="#152030"/>

												<!-- Quick Launch -->
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Quick Launch" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<StackPanel Orientation="Horizontal" Spacing="5">
															<TextBlock Text="EXPERIMENTAL" Foreground="#FF9800" FontSize="10" FontWeight="Bold"/>
															<TextBlock Text="• Optional" Foreground="{DynamicResource DisabledForegroundBrush}" FontSize="10"/>
														</StackPanel>
													</StackPanel>
													<ToggleSwitch x:Name="QuickLaunchEnabledToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M3,5 L21,5 A1,1 0 0 1 22,6 L22,16 A1,1 0 0 1 21,17 L3,17 A1,1 0 0 1 2,16 L2,6 A1,1 0 0 1 3,5 Z M8,21 L16,21 M12,17 L12,21"/>
											<TextBlock Text="Resolution" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="25">
										<Border BorderBrush="#152030" BorderThickness="0,0,0,1" Padding="0,0,0,15">
											<TextBlock Text="GAME RESOLUTION" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20"/>
										</Border>
										<TextBlock Text="Set the resolution of the game instance" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="14"/>
										<Border Background="#0C1620" CornerRadius="12" Padding="20">
											<StackPanel Spacing="20">
												<Border Background="{DynamicResource HoverBackgroundBrush}" CornerRadius="10" Padding="12">
													<StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Left">
														<TextBlock Text="W" Foreground="{DynamicResource DisabledForegroundBrush}" FontSize="11" VerticalAlignment="Center"/>
														<TextBox x:Name="GameResolutionWidthTextBox" Text="1280" Width="80" HorizontalContentAlignment="Center" BorderThickness="0" Margin="0" VerticalAlignment="Center"/>
														<TextBlock Text="×" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
														<TextBlock Text="H" Foreground="{DynamicResource DisabledForegroundBrush}" FontSize="11" VerticalAlignment="Center"/>
														<TextBox x:Name="GameResolutionHeightTextBox" Text="720" Width="80" HorizontalContentAlignment="Center" BorderThickness="0" Margin="0" VerticalAlignment="Center"/>
													</StackPanel>
												</Border>
												<StackPanel Orientation="Horizontal" Spacing="10">
													<Button x:Name="SelectResolutionPresetButton" Content="Select a Preset" Background="{DynamicResource PrimaryAccentBrush}" Foreground="{DynamicResource AccentButtonForegroundBrush}" BorderThickness="0" CornerRadius="8" Padding="15,8" FontWeight="Bold" Cursor="Hand"/>
													<Button x:Name="VisualiseResolutionButton" Content="Visualise on Screen" Background="{DynamicResource HoverBackgroundBrush}" Foreground="{DynamicResource PrimaryForegroundBrush}" BorderThickness="0" CornerRadius="8" Padding="15,8" Cursor="Hand"/>
												</StackPanel>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Use Custom Resolution" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Enable to use the custom width and height above" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="UseCustomGameResolutionToggle" Grid.Column="1" IsChecked="False"/>
												</Grid>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Lock Aspect Ratio" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Maintain the width/height ratio when resizing the game window" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="LockGameAspectRatioToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M6,11 L10,11 M8,9 L8,13 M15,11 L15.01,11 M18,13 L18.01,13 M17.32,5 L6.68,5 A5,5 0 0 0 1.8,9.09 L0.31,15.59 A2,2 0 0 0 2.26,18 L2.5,18 A2,2 0 0 0 4.39,16.67 L5.23,13.5 L18.77,13.5 L19.61,16.67 A2,2 0 0 0 21.5,18 L21.74,18 A2,2 0 0 0 23.69,15.59 L22.2,9.09 A5,5 0 0 0 17.32,5 Z"/>
											<TextBlock Text="Game Options" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="25">
										<Border BorderBrush="#152030" BorderThickness="0,0,0,1" Padding="0,0,0,15">
											<StackPanel Spacing="5">
												<TextBlock Text="GAME OPTIONS" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20"/>
												<TextBlock Text="EXPERIMENTAL (SOME SETTINGS MAY NOT BE ACCURATE)" Foreground="#FF9800" FontSize="10" FontWeight="Bold"/>
											</StackPanel>
										</Border>
										<Border Background="#0C1620" CornerRadius="12" Padding="20">
											<StackPanel Spacing="20">
												<TextBlock Text="ACCESSIBILITY AND CONTROLS" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" FontWeight="Bold"/>
												<Grid ColumnDefinitions="*,*">
													<StackPanel Grid.Column="0" Spacing="10" Margin="0,0,10,0">
														<StackPanel Spacing="5">
															<TextBlock Text="Mouse Sensitivity" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
															<Slider x:Name="MouseSensitivitySlider" Value="0.5" Minimum="0" Maximum="1" Width="200" HorizontalAlignment="Left"/>
															<TextBlock x:Name="MouseSensitivityValueText" Text="0.5" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<Grid ColumnDefinitions="*,Auto">
															<TextBlock Grid.Column="0" Text="Auto Jump" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
															<ToggleSwitch x:Name="AutoJumpToggle" Grid.Column="1" IsChecked="False"/>
														</Grid>
														<Grid ColumnDefinitions="*,Auto">
															<TextBlock Grid.Column="0" Text="Toggle Sprint" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
															<ToggleSwitch x:Name="ToggleSprintToggle" Grid.Column="1" IsChecked="True"/>
														</Grid>
													</StackPanel>
													<StackPanel Grid.Column="1" Spacing="10" Margin="10,0,0,0">
														<StackPanel Spacing="5">
															<TextBlock Text="Scroll Sensitivity" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
															<Slider x:Name="ScrollSensitivitySlider" Value="1" Minimum="0.01" Maximum="10" Width="200" HorizontalAlignment="Left"/>
															<TextBlock x:Name="ScrollSensitivityValueText" Text="1" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<Grid ColumnDefinitions="*,Auto">
															<TextBlock Grid.Column="0" Text="Touchscreen" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
															<ToggleSwitch x:Name="TouchscreenToggle" Grid.Column="1" IsChecked="False"/>
														</Grid>
														<Grid ColumnDefinitions="*,Auto">
															<TextBlock Grid.Column="0" Text="Toggle Crouch" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
															<ToggleSwitch x:Name="ToggleCrouchToggle" Grid.Column="1" IsChecked="False"/>
														</Grid>
													</StackPanel>
												</Grid>
												<Grid ColumnDefinitions="*,Auto">
													<TextBlock Grid.Column="0" Text="Subtitles" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
													<ToggleSwitch x:Name="SubtitlesToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M12,2 L14,7 L19,7.5 L15.5,11.5 L16.5,17 L12,14.5 L7.5,17 L8.5,11.5 L5,7.5 L10,7 Z"/>
											<TextBlock Text="Rendering" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="25">
										<Border BorderBrush="#152030" BorderThickness="0,0,0,1" Padding="0,0,0,15">
											<TextBlock Text="RENDERING" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20"/>
										</Border>
										<Border Background="#0C1620" CornerRadius="12" Padding="20">
											<StackPanel Spacing="20">
												<TextBlock Text="VISUALS" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" FontWeight="Bold"/>
												<Grid ColumnDefinitions="*,*">
													<StackPanel Grid.Column="0" Spacing="15" Margin="0,0,10,0">
														<StackPanel Spacing="5">
															<TextBlock Text="Render Distance" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
															<Slider x:Name="RenderDistanceSlider" Value="32" Minimum="2" Maximum="64" Width="200" HorizontalAlignment="Left"/>
															<TextBlock x:Name="RenderDistanceValueText" Text="32 chunks" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<StackPanel Spacing="5">
															<TextBlock Text="Simulation Distance" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
															<Slider x:Name="SimulationDistanceSlider" Value="32" Minimum="5" Maximum="64" Width="200" HorizontalAlignment="Left"/>
															<TextBlock x:Name="SimulationDistanceValueText" Text="32 chunks" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<StackPanel Spacing="5">
															<TextBlock Text="Entity Distance" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
															<Slider x:Name="EntityDistanceSlider" Value="1" Minimum="0.5" Maximum="5" Width="200" HorizontalAlignment="Left"/>
															<TextBlock x:Name="EntityDistanceValueText" Text="100%" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
													</StackPanel>
													<StackPanel Grid.Column="1" Spacing="15" Margin="10,0,0,0">
														<StackPanel Spacing="5">
															<TextBlock Text="Max FPS" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
															<TextBlock Text="Set to 0 for unlimited FPS" Foreground="{DynamicResource DisabledForegroundBrush}" FontSize="10" Margin="0, -5, 0, 0"/>
															<Slider x:Name="MaxFpsSlider" Value="0" Minimum="0" Maximum="260" Width="200" HorizontalAlignment="Left"/>
															<TextBlock x:Name="MaxFpsValueText" Text="Unlimited" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<Grid ColumnDefinitions="*,Auto">
															<TextBlock Grid.Column="0" Text="VSync" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
															<ToggleSwitch x:Name="VSyncToggle" Grid.Column="1" IsChecked="False"/>
														</Grid>
														<Grid ColumnDefinitions="*,Auto">
															<TextBlock Grid.Column="0" Text="Fullscreen" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
															<ToggleSwitch x:Name="FullscreenToggle" Grid.Column="1" IsChecked="False"/>
														</Grid>
													</StackPanel>
												</Grid>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,*">
													<StackPanel Grid.Column="0" Spacing="10" Margin="0,0,10,0">
														<Grid ColumnDefinitions="*,Auto">
															<TextBlock Grid.Column="0" Text="Entity Shadows" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
															<ToggleSwitch x:Name="EntityShadowsToggle" Grid.Column="1" IsChecked="True"/>
														</Grid>
														<Grid ColumnDefinitions="*,Auto">
															<TextBlock Grid.Column="0" Text="High Contrast" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
															<ToggleSwitch x:Name="HighContrastToggle" Grid.Column="1" IsChecked="False"/>
														</Grid>
													</StackPanel>
													<StackPanel Grid.Column="1" Spacing="10" Margin="10,0,0,0">
														<StackPanel Spacing="5">
															<TextBlock Text="Render Clouds" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
															<ComboBox x:Name="RenderCloudsComboBox" SelectedIndex="1" MinWidth="150">
																<ComboBoxItem Content="Off"/>
																<ComboBoxItem Content="Fast"/>
																<ComboBoxItem Content="Fancy"/>
															</ComboBox>
														</StackPanel>
													</StackPanel>
												</Grid>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M12,12 C14.2,12 16,10.2 16,8 C16,5.8 14.2,4 12,4 C9.8,4 8,5.8 8,8 C8,10.2 9.8,12 12,12 Z M12,14 C9.3,14 4,15.3 4,18 L4,20 L20,20 L20,18 C20,15.3 14.7,14 12,14 Z"/>
											<TextBlock Text="Player" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="25">
										<Border BorderBrush="#152030" BorderThickness="0,0,0,1" Padding="0,0,0,15">
											<TextBlock Text="PLAYER SETTINGS" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20"/>
										</Border>
										<Border Background="#0C1620" CornerRadius="12" Padding="20">
											<StackPanel Spacing="15">
												<WrapPanel Orientation="Horizontal" ItemWidth="180">
													<StackPanel Spacing="10" Margin="0,0,15,15">
														<TextBlock Text="Hat" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
														<ToggleSwitch x:Name="PlayerHatToggle" IsChecked="True"/>
													</StackPanel>
													<StackPanel Spacing="10" Margin="0,0,15,15">
														<TextBlock Text="Cape" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
														<ToggleSwitch x:Name="PlayerCapeToggle" IsChecked="True"/>
													</StackPanel>
													<StackPanel Spacing="10" Margin="0,0,15,15">
														<TextBlock Text="Jacket" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
														<ToggleSwitch x:Name="PlayerJacketToggle" IsChecked="True"/>
													</StackPanel>
													<StackPanel Spacing="10" Margin="0,0,15,15">
														<TextBlock Text="Left Sleeve" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
														<ToggleSwitch x:Name="PlayerLeftSleeveToggle" IsChecked="True"/>
													</StackPanel>
													<StackPanel Spacing="10" Margin="0,0,15,15">
														<TextBlock Text="Right Sleeve" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
														<ToggleSwitch x:Name="PlayerRightSleeveToggle" IsChecked="True"/>
													</StackPanel>
													<StackPanel Spacing="10" Margin="0,0,15,15">
														<TextBlock Text="Left Pant" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
														<ToggleSwitch x:Name="PlayerLeftPantToggle" IsChecked="True"/>
													</StackPanel>
													<StackPanel Spacing="10" Margin="0,0,15,15">
														<TextBlock Text="Right Pant" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
														<ToggleSwitch x:Name="PlayerRightPantToggle" IsChecked="True"/>
													</StackPanel>
												</WrapPanel>
												<Separator Background="#152030"/>
												<StackPanel Spacing="10">
													<TextBlock Text="Main Hand" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="13"/>
													<ComboBox x:Name="PlayerMainHandComboBox" SelectedIndex="1" MinWidth="150">
														<ComboBoxItem Content="Left"/>
														<ComboBoxItem Content="Right"/>
													</ComboBox>
												</StackPanel>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M12,2 A10,10 0 1 0 12,22 A2,2 0 0 0 14,20 A2,2 0 0 1 16,18 L18,18 A4,4 0 0 0 22,14 A10,10 0 0 0 12,2 Z M7.5,10.5 A1.5,1.5 0 1 1 7.5001,10.5 Z M12,7 A1.5,1.5 0 1 1 12.0001,7 Z M16.5,10.5 A1.5,1.5 0 1 1 16.5001,10.5 Z M7.5,15 A1.5,1.5 0 1 1 7.5001,15 Z"/>
											<TextBlock Text="Appearance" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="25">
										<Border BorderBrush="#152030" BorderThickness="0,0,0,1" Padding="0,0,0,15">
											<TextBlock Text="APPEARANCE" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20"/>
										</Border>
										<Border Background="#0C1620" CornerRadius="12" Padding="20">
											<StackPanel Spacing="20">
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Theme" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Choose your preferred theme" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ComboBox x:Name="ThemeComboBox" Grid.Column="1" SelectedIndex="0" MinWidth="120">
														<ComboBoxItem Content="Dark"/>
														<ComboBoxItem Content="Light"/>
														<ComboBoxItem Content="Auto"/>
													</ComboBox>
												</Grid>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Nature Theme" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Enable falling leaves and nature overlay" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="NatureThemeToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Animations" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Enable interface animations" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="AnimationsEnabledToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M21,12 A9,9 0 0 1 3,12 A9,9 0 0 1 21,12 Z M12,7 L12,13 L16,15"/>
											<TextBlock Text="Updates" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="25">
										<Border BorderBrush="#152030" BorderThickness="0,0,0,1" Padding="0,0,0,15">
											<TextBlock Text="NOTIFICATIONS &amp; UPDATES" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20"/>
										</Border>
										<Border Background="#0C1620" CornerRadius="12" Padding="20">
											<StackPanel Spacing="20">
												<StackPanel Spacing="10">
													<TextBlock Text="GAME UPDATE DELIVERY" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
													<TextBlock Text="Select when you'd like to receive launcher updates" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													<StackPanel Orientation="Vertical" Spacing="8" Margin="0,5,0,0">
														<RadioButton x:Name="UpdateDeliveryNormalRadio" GroupName="UpdateDelivery" IsChecked="True"
																	 Foreground="{DynamicResource PrimaryForegroundBrush}" Content="Normal">
															<RadioButton.Tag>
																<Border Background="{DynamicResource PrimaryAccentBrush}"
																		CornerRadius="4"
																		Padding="6,2"
																		Margin="5,0,0,0"
																		VerticalAlignment="Center">
																	<TextBlock Text="Recommended" FontWeight="Bold" FontSize="10"
																			   Foreground="{DynamicResource AccentButtonForegroundBrush}"/>
																</Border>
															</RadioButton.Tag>
														</RadioButton>
														<TextBlock Margin="25, -5, 0, 0" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"
																   Text="You will receive updates with the masses!"/>
														<RadioButton x:Name="UpdateDeliveryEarlyRadio" GroupName="UpdateDelivery"
																	 Foreground="{DynamicResource PrimaryForegroundBrush}" Content="Early (Opt-In)"/>
														<TextBlock Margin="25, -5, 0, 0" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"
																   Text="You will receive updates earlier than usual, may come with the occasional bug!"/>
														<RadioButton x:Name="UpdateDeliveryLateRadio" GroupName="UpdateDelivery"
																	 Foreground="{DynamicResource PrimaryForegroundBrush}" Content="Late (Opt-Out)"/>
														<TextBlock Margin="25, -5, 0, 0" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"
																   Text="You will receive updates later than usual... slow and steady wins the race right?"/>
													</StackPanel>
												</StackPanel>
												<Separator Background="#152030"/>
												<StackPanel Spacing="10">
													<TextBlock Text="CLOSING NOTIFICATIONS" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
													<TextBlock Text="Whether the Launcher will notify you that it is still in the background" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													<StackPanel Orientation="Vertical" Spacing="8" Margin="0,5,0,0">
														<RadioButton x:Name="ClosingNotificationsAlwaysRadio" GroupName="ClosingNotifications"
																	 Foreground="{DynamicResource PrimaryForegroundBrush}" Content="Always"/>
														<TextBlock Margin="25, -5, 0, 0" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"
																   Text="Always notify when the launcher is still running after closing all windows"/>
														<RadioButton x:Name="ClosingNotificationsJustOnceRadio" GroupName="ClosingNotifications" IsChecked="True"
																	 Foreground="{DynamicResource PrimaryForegroundBrush}" Content="Just once">
															<RadioButton.Tag>
																<Border Background="{DynamicResource PrimaryAccentBrush}"
																		CornerRadius="4"
																		Padding="6,2"
																		Margin="5,0,0,0"
																		VerticalAlignment="Center">
																	<TextBlock Text="Recommended" FontWeight="Bold" FontSize="10"
																			   Foreground="{DynamicResource AccentButtonForegroundBrush}"/>
																</Border>
															</RadioButton.Tag>
														</RadioButton>
														<TextBlock Margin="25, -5, 0, 0" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"
																   Text="Notify once per session when the launcher is still running after closing all windows"/>
														<RadioButton x:Name="ClosingNotificationsNeverRadio" GroupName="ClosingNotifications"
																	 Foreground="{DynamicResource PrimaryForegroundBrush}" Content="Never"/>
														<TextBlock Margin="25, -5, 0, 0" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"
																   Text="Don't notify when the launcher continues running after closing all windows"/>
													</StackPanel>
												</StackPanel>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="Update Notifications" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Whether to send a notification when a new version of the Launcher is available for install" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="EnableUpdateNotificationsToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
												<Separator Background="#152030"/>
												<Grid ColumnDefinitions="*,Auto">
													<StackPanel Grid.Column="0" Spacing="5">
														<TextBlock Text="New Content Notification" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
														<TextBlock Text="Whether to show an indicator for new content/updates on blogs, cosmetics, version, etc." Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													</StackPanel>
													<ToggleSwitch x:Name="EnableNewContentIndicatorsToggle" Grid.Column="1" IsChecked="True"/>
												</Grid>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M3,5 L21,5 A1,1 0 0 1 22,6 L22,10 A1,1 0 0 1 21,11 L3,11 A1,1 0 0 1 2,10 L2,6 A1,1 0 0 1 3,5 Z M3,13 L21,13 A1,1 0 0 1 22,14 L22,18 A1,1 0 0 1 21,19 L3,19 A1,1 0 0 1 2,18 L2,14 A1,1 0 0 1 3,13 Z M6,8 L6.01,8 M6,16 L6.01,16"/>
											<TextBlock Text="Storage" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="25">
										<Border BorderBrush="#152030" BorderThickness="0,0,0,1" Padding="0,0,0,15">
											<TextBlock Text="STORAGE &amp; MAINTENANCE" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20"/>
										</Border>
										<Border Background="#0C1620" CornerRadius="12" Padding="20">
											<StackPanel Spacing="20">
												<StackPanel Spacing="10">
													<TextBlock Text="Directory Overview" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
													<TextBlock Text="View how much disk space each major directory is consuming" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													<Border Background="{DynamicResource HoverBackgroundBrush}" CornerRadius="4" Margin="0,10,0,0">
														<Grid ColumnDefinitions="*,*,*,*,Auto" Height="20">
															<Border x:Name="LogsUsageBar" Grid.Column="0" Background="#FF42A5F5" HorizontalAlignment="Left" Width="0"/>
															<Border x:Name="ProfilesUsageBar" Grid.Column="1" Background="#FF9C27B0" HorizontalAlignment="Left" Width="0"/>
															<Border x:Name="AssetsUsageBar" Grid.Column="2" Background="#FF4CAF50" HorizontalAlignment="Left" Width="0"/>
															<Border x:Name="CacheUsageBar" Grid.Column="3" Background="#FFF44336" HorizontalAlignment="Left" Width="0"/>
															<Border x:Name="OtherUsageBar" Grid.Column="4" Background="#FFFFCA28" HorizontalAlignment="Left" Width="0"/>
														</Grid>
													</Border>
													<WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
														<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Margin="0,0,10,0">
															<Rectangle Width="10" Height="10" Fill="#FF42A5F5" Margin="0,1,0,0"/>
															<TextBlock x:Name="LogsUsageText" Text="Logs - 0 KB" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Margin="0,0,10,0">
															<Rectangle Width="10" Height="10" Fill="#FF9C27B0" Margin="0,1,0,0"/>
															<TextBlock x:Name="ProfilesUsageText" Text="Profiles - 0 KB" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Margin="0,0,10,0">
															<Rectangle Width="10" Height="10" Fill="#FF4CAF50" Margin="0,1,0,0"/>
															<TextBlock x:Name="AssetsUsageText" Text="Assets - 0 KB" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Margin="0,0,10,0">
															<Rectangle Width="10" Height="10" Fill="#FFF44336" Margin="0,1,0,0"/>
															<TextBlock x:Name="CacheUsageText" Text="Cache - 0 KB" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Margin="0,0,10,0">
															<Rectangle Width="10" Height="10" Fill="#FFFFCA28" Margin="0,1,0,0"/>
															<TextBlock x:Name="OtherUsageText" Text="Other - 0 KB" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
														<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Margin="10,0,0,0">
															<TextBlock Text="Total - " Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="11"/>
															<TextBlock x:Name="TotalUsageText" Text="0 KB" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="11"/>
														</StackPanel>
													</WrapPanel>
												</StackPanel>
												<Separator Background="#152030"/>
												<StackPanel Spacing="10">
													<TextBlock Text="Logs" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
													<TextBlock Text="Browse or clean up your log files" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
														<Button Content="Open Logs" Click="OpenLauncherLogsFolder"
																Background="{DynamicResource PrimaryAccentBrush}" Foreground="{DynamicResource PrimaryForegroundBrush}"
																BorderThickness="0" CornerRadius="8" Padding="15,8" FontWeight="Bold" Cursor="Hand"/>
														<Button x:Name="ClearLogsButton" Content="Clear Logs"
																Background="{DynamicResource ErrorBrush}" Foreground="{DynamicResource AccentButtonForegroundBrush}"
																BorderThickness="0" CornerRadius="8" Padding="15,8" FontWeight="Bold" Cursor="Hand"/>
													</StackPanel>
												</StackPanel>
												<Separator Background="#152030"/>
												<StackPanel Spacing="10">
													<TextBlock Text="Clear Cache" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="16"/>
													<TextBlock Text="Clean up launcher cache files (will temporarily increase launch time)" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
													<Button x:Name="ClearCacheButton" Content="Clear Cache"
															Background="{DynamicResource ErrorBrush}" Foreground="{DynamicResource AccentButtonForegroundBrush}"
															BorderThickness="0" CornerRadius="8" Padding="15,8" FontWeight="Bold" Cursor="Hand" Margin="0,5,0,0"/>
												</StackPanel>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M21,11.5 A8.38,8.38 0 0 1 12.5,20 L12.5,20 A8.5,8.5 0 0 1 4,11.5 A8.38,8.38 0 0 1 12.5,3 A8.38,8.38 0 0 1 21,11.5 Z"/>
											<TextBlock Text="Feedback" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="20">
										<StackPanel x:Name="SettingsFeedbackSection" Spacing="6">
											<TextBlock Text="FEEDBACK" Foreground="#E5E7EB" FontWeight="Black" FontSize="20" LetterSpacing="1.2"/>
											<TextBlock Text="Help us improve Leaf Client by sending your thoughts" Foreground="#6B7280" FontSize="12"/>
										</StackPanel>
										<Border Background="#0C1620" CornerRadius="14" Padding="22" BorderBrush="#152030" BorderThickness="1">
											<Grid ColumnDefinitions="*,14,*">
												<!-- Suggest a Feature -->
												<Button Grid.Column="0" x:Name="SuggestFeatureButton"
														Classes="ColorBtn"
														BorderThickness="0" CornerRadius="12"
														Padding="20,18" FontWeight="Bold" FontSize="13" MinHeight="52"
														Foreground="White" HorizontalAlignment="Stretch"
														HorizontalContentAlignment="Center"
														Cursor="Hand" Click="OpenFeedbackOverlay" Tag="Feature">
													<Button.Background>
														<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
															<GradientStop Offset="0" Color="#9333EA"/>
															<GradientStop Offset="1" Color="#6D28D9"/>
														</LinearGradientBrush>
													</Button.Background>
													<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
														<Path Width="16" Height="16" Stretch="Uniform"
															  Stroke="White" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round"
															  Fill="Transparent" VerticalAlignment="Center"
															  Data="M12,2 L14,7 L19,7.5 L15.5,11.5 L16.5,17 L12,14.5 L7.5,17 L8.5,11.5 L5,7.5 L10,7 Z"/>
														<TextBlock Text="SUGGEST A FEATURE" LetterSpacing="0.8" VerticalAlignment="Center"/>
													</StackPanel>
												</Button>
												<!-- Report a Bug -->
												<Button Grid.Column="2" x:Name="ReportBugButton"
														Classes="ColorBtn"
														BorderThickness="0" CornerRadius="12"
														Padding="20,18" FontWeight="Bold" FontSize="13" MinHeight="52"
														Foreground="White" HorizontalAlignment="Stretch"
														HorizontalContentAlignment="Center"
														Cursor="Hand" Click="OpenFeedbackOverlay" Tag="Bug">
													<Button.Background>
														<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
															<GradientStop Offset="0" Color="#EF4444"/>
															<GradientStop Offset="1" Color="#B91C1C"/>
														</LinearGradientBrush>
													</Button.Background>
													<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
														<Path Width="16" Height="16" Stretch="Uniform"
															  Stroke="White" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round"
															  Fill="Transparent" VerticalAlignment="Center"
															  Data="M8,4 L16,4 L16,12 A4,4 0 0 1 8,12 Z M4,10 L8,10 M4,16 L8,16 M16,10 L20,10 M16,16 L20,16 M12,4 L12,2 M10,4 L8,2 M14,4 L16,2"/>
														<TextBlock Text="REPORT A BUG" LetterSpacing="0.8" VerticalAlignment="Center"/>
													</StackPanel>
												</Button>
											</Grid>
										</Border>
									</StackPanel>
								</TabItem>

								<TabItem>
									<TabItem.Header>
										<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
											<Path Width="18" Height="18" Stretch="Uniform" Stroke="#9CA3AF" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,16 L12,12 M12,8 L12.01,8"/>
											<TextBlock Text="About" VerticalAlignment="Center"/>
										</StackPanel>
									</TabItem.Header>
									<StackPanel Spacing="20">
										<StackPanel Spacing="6">
											<TextBlock Text="ABOUT" Foreground="#E5E7EB" FontWeight="Black" FontSize="20" LetterSpacing="1.2"/>
											<TextBlock Text="Version, links, and community" Foreground="#6B7280" FontSize="12"/>
										</StackPanel>
										<Border Background="#0C1620" CornerRadius="14" Padding="28,24" BorderBrush="#152030" BorderThickness="1">
											<StackPanel Spacing="18" HorizontalAlignment="Center">
												<Image Source="/Assets/LeafRebrandedTransparent.png" Width="72" Height="72"/>
												<TextBlock Text="Leaf Client" Foreground="#E5E7EB" FontWeight="Black" FontSize="22" HorizontalAlignment="Center" LetterSpacing="0.5"/>
												<TextBlock x:Name="AppVersionTextBlock" Foreground="#6B7280" FontSize="12" HorizontalAlignment="Center" FontWeight="SemiBold"/>
												<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="14" Margin="0,10,0,0">
													<Button Classes="ColorBtn"
															BorderThickness="0" CornerRadius="12"
															Padding="26,16" FontWeight="Bold" FontSize="12" MinHeight="48"
															Foreground="White" Cursor="Hand" Click="OpenWebsite">
														<Button.Background>
															<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
																<GradientStop Offset="0" Color="#9333EA"/>
																<GradientStop Offset="1" Color="#6D28D9"/>
															</LinearGradientBrush>
														</Button.Background>
														<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
															<Path Width="15" Height="15" Stretch="Uniform" Stroke="White" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M2,12 L22,12 M12,2 C9,5 9,19 12,22 C15,19 15,5 12,2 Z"/>
															<TextBlock Text="WEBSITE" LetterSpacing="1" VerticalAlignment="Center"/>
														</StackPanel>
													</Button>
													<Button Classes="ColorBtn"
															BorderThickness="0" CornerRadius="12"
															Padding="26,16" FontWeight="Bold" FontSize="12" MinHeight="48"
															Foreground="White" Cursor="Hand" Click="OpenDiscord">
														<Button.Background>
															<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
																<GradientStop Offset="0" Color="#5865F2"/>
																<GradientStop Offset="1" Color="#4752C4"/>
															</LinearGradientBrush>
														</Button.Background>
														<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
															<Path Width="15" Height="15" Stretch="Uniform" Fill="White" VerticalAlignment="Center" Data="M20,4 C18.5,3.2 16.9,2.7 15.2,2.4 C14.9,2.9 14.7,3.5 14.5,4 C12.8,3.7 11.2,3.7 9.5,4 C9.3,3.5 9.1,2.9 8.8,2.4 C7.1,2.7 5.5,3.2 4,4 C0.9,8.6 0.1,13.1 0.5,17.5 C2.5,19 4.4,19.9 6.2,20.5 C6.6,19.9 7,19.3 7.3,18.6 C6.7,18.4 6.1,18.1 5.6,17.8 C5.7,17.7 5.9,17.6 6,17.5 C9.9,19.3 14.1,19.3 18,17.5 C18.1,17.6 18.3,17.7 18.4,17.8 C17.9,18.1 17.3,18.4 16.7,18.6 C17,19.3 17.4,19.9 17.8,20.5 C19.6,19.9 21.5,19 23.5,17.5 C24,12.4 22.7,7.9 20,4 Z M8.1,14.8 C6.9,14.8 5.9,13.7 5.9,12.4 C5.9,11.1 6.9,10 8.1,10 C9.3,10 10.3,11.1 10.3,12.4 C10.3,13.7 9.3,14.8 8.1,14.8 Z M15.9,14.8 C14.7,14.8 13.7,13.7 13.7,12.4 C13.7,11.1 14.7,10 15.9,10 C17.1,10 18.1,11.1 18.1,12.4 C18.1,13.7 17.1,14.8 15.9,14.8 Z"/>
															<TextBlock Text="DISCORD" LetterSpacing="1" VerticalAlignment="Center"/>
														</StackPanel>
													</Button>
													<Button Classes="ColorBtn"
															BorderThickness="0" CornerRadius="12"
															Padding="26,16" FontWeight="Bold" FontSize="12" MinHeight="48"
															Foreground="White" Cursor="Hand" Click="OpenInstagram">
														<Button.Background>
															<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
																<GradientStop Offset="0" Color="#F58529"/>
																<GradientStop Offset="0.5" Color="#DD2A7B"/>
																<GradientStop Offset="1" Color="#8134AF"/>
															</LinearGradientBrush>
														</Button.Background>
														<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
															<Path Width="15" Height="15" Stretch="Uniform" Stroke="White" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M4,4 L20,4 A2,2 0 0 1 22,6 L22,18 A2,2 0 0 1 20,20 L4,20 A2,2 0 0 1 2,18 L2,6 A2,2 0 0 1 4,4 Z M12,8 A4,4 0 1 1 12,16 A4,4 0 1 1 12,8 Z M17.5,6 L17.51,6"/>
															<TextBlock Text="INSTAGRAM" LetterSpacing="1" VerticalAlignment="Center"/>
														</StackPanel>
													</Button>
												</StackPanel>
											</StackPanel>
										</Border>

										<!-- Developer tool: bake cosmetic previews into AppData -->
										<Border Background="#0C1620" CornerRadius="14" Padding="24,20" BorderBrush="#152030" BorderThickness="1">
											<StackPanel Spacing="16">
												<StackPanel Spacing="6">
													<TextBlock Text="DEVELOPER TOOLS" Foreground="#C4B5FD" FontSize="10" FontWeight="Bold" LetterSpacing="1.2"/>
													<TextBlock Text="Render every cosmetic into 4 PNG angles (front, back, angled-left, angled-right) and save them under %APPDATA%\LeafClient\CosmeticPreviews for use in banners and marketing."
															   Foreground="#6B7280" FontSize="11" TextWrapping="Wrap" LineHeight="17"/>
												</StackPanel>
												<Button x:Name="BakeCosmeticPreviewsButton"
														Classes="ColorBtn"
														BorderThickness="0" CornerRadius="12"
														Padding="30,18" FontWeight="Bold" FontSize="12"
														MinHeight="52"
														Foreground="White" Cursor="Hand"
														HorizontalAlignment="Left"
														Click="OnBakeCosmeticPreviewsClick">
													<Button.Background>
														<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
															<GradientStop Offset="0" Color="#9333EA"/>
															<GradientStop Offset="1" Color="#6D28D9"/>
														</LinearGradientBrush>
													</Button.Background>
													<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
														<Path Width="15" Height="15" Stretch="Uniform" Stroke="White" StrokeThickness="1.8" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" VerticalAlignment="Center" Data="M4,4 L20,4 A2,2 0 0 1 22,6 L22,18 A2,2 0 0 1 20,20 L4,20 A2,2 0 0 1 2,18 L2,6 A2,2 0 0 1 4,4 Z M12,8 A4,4 0 1 1 12,16 A4,4 0 1 1 12,8 Z"/>
														<TextBlock x:Name="BakeCosmeticPreviewsButtonText" Text="BAKE COSMETIC PREVIEWS" LetterSpacing="1" VerticalAlignment="Center"/>
													</StackPanel>
												</Button>
												<TextBlock x:Name="BakeCosmeticPreviewsStatus" Text="" Foreground="#9CA3AF" FontSize="11" TextWrapping="Wrap" IsVisible="False"/>
											</StackPanel>
										</Border>
									</StackPanel>
								</TabItem>

							</TabControl>
						</Border>

						<!-- Dynamic Save Settings Banner -->
						<Border x:Name="SettingsSaveBanner"
								HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="20"
								CornerRadius="12" Padding="12" Background="#252525"
								IsVisible="False" Opacity="0" ZIndex="1000" ClipToBounds="False">
							<Border.RenderTransform>
								<TranslateTransform Y="80"/>
							</Border.RenderTransform>
							<Border.Transitions>
								<Transitions>
									<DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut"/>
									<DoubleTransition Property="(TranslateTransform.Y)" Duration="0:0:0.25" Easing="CubicEaseOut"/>
								</Transitions>
							</Border.Transitions>
							<Grid ColumnDefinitions="*,Auto,Auto">
								<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
									<TextBlock Text="💾" FontSize="16" VerticalAlignment="Center"/>
									<TextBlock Text="Save your changes" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
								</StackPanel>

								<!-- Cancel Button -->
								<Button x:Name="SettingsSaveBannerCancelButton" Grid.Column="1"
										Background="Transparent" Foreground="#AAAAAA"
										BorderThickness="0" Margin="0,0,5,0"
										Cursor="Hand" FontWeight="SemiBold" VerticalAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover /template/ ContentPresenter">
											<Setter Property="Background" Value="Transparent"/>
											<Setter Property="Foreground" Value="White"/>
										</Style>
									</Button.Styles>
									<TextBlock Text="Cancel"/>
								</Button>

								<!-- Save Button -->
								<Button x:Name="SettingsSaveBannerSaveButton" Grid.Column="2"
										Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource AccentButtonForegroundBrush}"
										BorderThickness="0" CornerRadius="8" Padding="20,10" FontWeight="Bold" Cursor="Hand">
									<TextBlock Text="SAVE"/>
								</Button>
							</Grid>
						</Border>
					</Grid>
					<!-- Skins Page -->
					<Grid x:Name="SkinsPage" IsVisible="False">
						<Border Background="{DynamicResource TertiaryBackgroundBrush}" CornerRadius="18" Padding="30">
							<ScrollViewer VerticalScrollBarVisibility="Auto">
								<StackPanel Spacing="25">
									<Grid ColumnDefinitions="*,Auto">
										<TextBlock Grid.Column="0" Text="SKINS" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="ExtraBold" FontSize="24"/>
										<Button Grid.Column="1" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource AccentButtonForegroundBrush}" BorderThickness="0" CornerRadius="8" Padding="20,10" FontWeight="Bold" Click="CreateNewSkin" Classes="ColorBtn LiftBtn GlowGreen">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="+" FontSize="16"/>
												<TextBlock Text="CREATE SKIN"/>
											</StackPanel>
										</Button>
									</Grid>
									<TextBlock Text="Manage your Minecraft skins" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="14"/>
									<!-- Add this inside your SkinsPage Grid, before other elements -->
									<Border x:Name="SkinStatusBanner"
		Background="#228B22"
		CornerRadius="6"
		Padding="12,8"
		Margin="0,10,0,10"
		IsVisible="False"
		VerticalAlignment="Top"
		ZIndex="100">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="Auto"/>
											</Grid.ColumnDefinitions>

											<TextBlock x:Name="SkinStatusBannerText"
													   Grid.Column="0"
													   Text="Skin status message"
													   Foreground="White"
													   FontSize="12"
													   FontWeight="Medium"
													   VerticalAlignment="Center"
													   TextWrapping="Wrap"/>

											<Button x:Name="SkinStatusBannerButton"
													Grid.Column="1"
													Content="✕"
													Background="Transparent"
													Foreground="White"
													FontSize="14"
													Width="20"
													Height="20"
													Padding="0"
													Margin="10,0,0,0"
													VerticalAlignment="Center"
													HorizontalContentAlignment="Center"
													VerticalContentAlignment="Center"
													Cursor="Hand"/>
										</Grid>
									</Border>
									<!-- Skins Grid -->
									<WrapPanel x:Name="SkinsWrapPanel" Orientation="Horizontal"/>

									<!-- Empty State -->
									<Border x:Name="NoSkinsMessage" Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="40" IsVisible="True">
										<StackPanel Spacing="15" HorizontalAlignment="Center">
											<TextBlock Text="🎨" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
											<TextBlock Text="No skins yet" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
											<TextBlock Text="Create your first custom skin to get started" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
										</StackPanel>
									</Border>
								</StackPanel>
							</ScrollViewer>
						</Border>
					</Grid>
				</Grid>

				<!-- Right Sidebar -->
				<Grid Grid.Column="1" Margin="0,20,20,20">
					<!-- Right Sidebar Ad Section -->
					<Border x:Name="AdSection"
							Grid.Row="2"
							Background="{DynamicResource SecondaryBackgroundBrush}"
							CornerRadius="12"
							ClipToBounds="True"
							IsVisible="False">
						<!-- Start hidden until ad is loaded -->
						<Grid>
							<!-- The clickable area for the ad -->
							<Button x:Name="AdButton"
									Classes="IconButton"
									HorizontalAlignment="Stretch"
									VerticalAlignment="Stretch"
									Cursor="Hand"
									Click="OnAdClicked">
								<Grid>
									<!-- The Ad Image -->
									<Image x:Name="AdImage"
										   Stretch="UniformToFill"
										   HorizontalAlignment="Center"
										   VerticalAlignment="Center"/>

									<!-- Optional 'Ad' badge overlay, always visible -->
									<Border Background="#99000000"
											CornerRadius="4"
											HorizontalAlignment="Right"
											VerticalAlignment="Top"
											Margin="8"
											Padding="6,2">
										<TextBlock Text="AD"
												   Foreground="White"
												   FontSize="10"
												   FontWeight="Bold"/>
									</Border>
								</Grid>
							</Button>

							<!-- Placeholder for when ad is loading or fails -->
							<TextBlock x:Name="AdLoadingText"
									   Text="Loading Ad..."
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   Foreground="{DynamicResource SecondaryForegroundBrush}"
									   Opacity="0.5"
									   IsVisible="True"/>
						</Grid>
					</Border>
				</Grid>

					<!-- COSMETICS PAGE (Index 6) -->
				<pages:CosmeticsPageView x:Name="CosmeticsPage" IsVisible="False"/>


				<!-- ══════════════════════════════════════════════════════
				     STORE PAGE (Index 7)
				══════════════════════════════════════════════════════ -->
				<pages:StorePageView x:Name="StorePage" IsVisible="False"/>

				<!-- ══════════════════════════════════════════════════════
				     SCREENSHOTS PAGE (Index 8)
				══════════════════════════════════════════════════════ -->
				<pages:ScreenshotsPageView x:Name="ScreenshotsPage" IsVisible="False"/>

			</Grid>

			<!-- Footer Bar -->
			<Border Grid.Row="3" Background="{DynamicResource TertiaryBackgroundBrush}" BorderBrush="{DynamicResource PrimaryBorderBrush}" BorderThickness="0,1,0,0">
				<Grid ColumnDefinitions="Auto,*,Auto">
					<TextBlock Grid.Column="0" Text="{Binding AppVersionText}" Foreground="{DynamicResource DisabledForegroundBrush}" VerticalAlignment="Center" Margin="20,0"/>

					<!-- Compact global stats strip (lives in the footer so it's visible from every page
					     and doesn't squeeze the home page news banners anymore) -->
					<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="22"
								HorizontalAlignment="Center" VerticalAlignment="Center">
						<StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
							<TextBlock Text="&#x23F1;" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center"/>
							<TextBlock x:Name="FooterStatsPlaytime" Text="0s"
									   Foreground="#E5E7EB" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
							<TextBlock Text="played" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
						</StackPanel>
						<Border Width="1" Height="14" Background="#1C2A38"/>
						<StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
							<TextBlock Text="&#x1F3AE;" FontSize="11" VerticalAlignment="Center"/>
							<TextBlock x:Name="FooterStatsLaunches" Text="0"
									   Foreground="#E5E7EB" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
							<TextBlock Text="launches" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
						</StackPanel>
						<Border Width="1" Height="14" Background="#1C2A38"/>
						<StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
							<TextBlock Text="&#x1F3C6;" FontSize="11" VerticalAlignment="Center"/>
							<TextBlock Text="Top:" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
							<TextBlock x:Name="FooterStatsTopVersion" Text="—"
									   Foreground="#E5E7EB" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
						</StackPanel>
					</StackPanel>

					<StackPanel x:Name="SubscriptionSection" Grid.Column="2" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center" Margin="0,0,20,0" IsVisible="False">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Text="💜" FontSize="16" VerticalAlignment="Center"/>
							<TextBlock Text="Coming soon" Foreground="{DynamicResource PrimaryForegroundBrush}" VerticalAlignment="Center" FontSize="13"/>
						</StackPanel>
						<Button Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource AccentButtonForegroundBrush}" BorderThickness="0" CornerRadius="8" Padding="25,10" FontWeight="Bold" Cursor="Hand">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<TextBlock Text="✓" FontSize="16"/>
								<TextBlock Text="Subscribe"/>
							</StackPanel>
						</Button>
					</StackPanel>
					<!-- NEW: Planned Updates Button (Bottom Right) -->
					<StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
						<Button x:Name="PlannedUpdatesButton"
								Width="48" Height="48"
								CornerRadius="24"
								Background="{DynamicResource HoverBackgroundBrush}"
								Cursor="Hand"
								PointerEntered="OpenPlannedUpdates"
								PointerExited="ClosePlannedUpdates"
								ToolTip.Tip="{x:Null}">
							<Image Source="/Assets/icon-planned-updates.png"
								   Width="24" Height="24"
								   HorizontalAlignment="Center"
								   VerticalAlignment="Center"
								   Stretch="Uniform"/>
						</Button>
					</StackPanel>
				</Grid>
			</Border>
		</Grid>

		<Grid x:Name="NatureOverlay" IsHitTestVisible="False" ZIndex="5" ClipToBounds="True">
			<!-- Grass Bottom Left -->
			<Path Data="M0,100 C 30,60 60,110 90,80 S 150,100 200,100 L 0,100 Z"
                  Fill="#589658" Opacity="0.3"
                  Width="300" Height="100" Stretch="Fill"
                  HorizontalAlignment="Left" VerticalAlignment="Bottom"
                  Margin="-20,0,0,-5"/>

			<!-- Grass Bottom Right -->
			<Path Data="M0,100 C 40,90 80,110 120,80 S 200,100 250,100 L 0,100 Z"
                  Fill="#589658" Opacity="0.3"
                  Width="400" Height="120" Stretch="Fill"
                  HorizontalAlignment="Right" VerticalAlignment="Bottom"
                  Margin="0,0,-20,-5">
				<Path.RenderTransform>
					<ScaleTransform ScaleX="-1"/>
				</Path.RenderTransform>
			</Path>

			<!-- Hanging Branch Top Right -->
			<Path Data="M0,0 Q 50,40 100,10 T 200,30"
                  Stroke="#3E2723" StrokeThickness="2" Opacity="0.5"
                  Width="200" Height="100" Stretch="None"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,-10,-20,0"/>
		</Grid>

		<!-- Falling Leaves Canvas (Dynamic) -->
		<Canvas x:Name="FallingLeavesCanvas" IsHitTestVisible="False" ZIndex="6" ClipToBounds="True" />

		<!-- Account Full-Page Overlay -->
		<Grid x:Name="AccountPanelOverlay" Grid.RowSpan="4" IsVisible="False" ZIndex="1500" Opacity="1">
			<Grid.Transitions>
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut"/>
				</Transitions>
			</Grid.Transitions>


			<!-- Dark backdrop -->
			<Border Background="#99000000" PointerPressed="OnAccountBackdropClick">
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>
			</Border>

			<!-- Centered two-column panel — matches profile editor dark style -->
			<Border x:Name="AccountPanel"
					MaxWidth="860"
					MaxHeight="560"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					CornerRadius="18"
					ClipToBounds="True"
					BorderBrush="#162030" BorderThickness="1"
					BoxShadow="0 40 120 0 #70000000"
					Margin="24"
					RenderTransformOrigin="0.5,0.5">

				<Border.Background>
					<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
						<GradientStop Offset="0" Color="#0D1520"/>
						<GradientStop Offset="0.5" Color="#0A1018"/>
						<GradientStop Offset="1" Color="#080C14"/>
					</LinearGradientBrush>
				</Border.Background>


				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="280"/>
					</Grid.ColumnDefinitions>

					<!-- LEFT COLUMN: Account Management -->
					<Grid Grid.Column="0">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<!-- Header with accent bar -->
						<Border Grid.Row="0" Padding="28,20,28,0" BorderBrush="#12FFFFFF" BorderThickness="0,0,0,0">
							<Grid ColumnDefinitions="Auto,Auto,*,Auto">
								<Border Width="3" Height="18" CornerRadius="2" Margin="0,0,14,0" VerticalAlignment="Center">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
											<GradientStop Offset="0" Color="#9333EA"/>
											<GradientStop Offset="1" Color="#6D28D9"/>
										</LinearGradientBrush>
									</Border.Background>
								</Border>
								<TextBlock Grid.Column="1" Text="ACCOUNTS"
										   Foreground="#E5E7EB"
										   FontWeight="Black"
										   FontSize="16"
										   VerticalAlignment="Center"
										   LetterSpacing="1.5"/>
								<Button Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center"
										Background="Transparent" BorderThickness="0"
										Width="32" Height="32" CornerRadius="10"
										Cursor="Hand" Click="OnAccountPanelCloseClick">
									<Button.Styles>
										<Style Selector="Button:pointerover /template/ ContentPresenter">
											<Setter Property="Background" Value="#30EF4444"/>
										</Style>
										<Style Selector="Button /template/ ContentPresenter">
											<Setter Property="Transitions">
												<Transitions><BrushTransition Property="Background" Duration="0:0:0.15"/></Transitions>
											</Setter>
										</Style>
									</Button.Styles>
									<TextBlock Text="✕" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Button>
							</Grid>
						</Border>

						<!-- Add account buttons -->
						<Grid Grid.Row="1" Margin="28,18,28,0" ColumnDefinitions="*,10,*">
							<Button Grid.Column="0"
									Height="44"
									BorderThickness="1.5"
									BorderBrush="#1C2A38"
									Background="#0F1A24"
									CornerRadius="12"
									HorizontalAlignment="Stretch"
									Cursor="Hand"
									Click="AddMicrosoftAccountClick">
								<Button.Styles>
									<Style Selector="Button:pointerover /template/ ContentPresenter">
										<Setter Property="Background" Value="#142230"/>
									</Style>
									<Style Selector="Button /template/ ContentPresenter">
										<Setter Property="Background" Value="Transparent"/>
										<Setter Property="Transitions">
											<Transitions><BrushTransition Property="Background" Duration="0:0:0.15"/></Transitions>
										</Setter>
									</Style>
								</Button.Styles>
								<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
									<TextBlock Text="&#x229E;" Foreground="#70B0FF" FontSize="16" VerticalAlignment="Center"/>
									<TextBlock Text="Microsoft" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
								</StackPanel>
							</Button>
							<Button Grid.Column="2"
									Height="44"
									BorderThickness="1.5"
									BorderBrush="#1C2A38"
									Background="#0F1A24"
									CornerRadius="12"
									HorizontalAlignment="Stretch"
									Cursor="Hand"
									Click="AddLocalAccountClick">
								<Button.Styles>
									<Style Selector="Button:pointerover /template/ ContentPresenter">
										<Setter Property="Background" Value="#142230"/>
									</Style>
									<Style Selector="Button /template/ ContentPresenter">
										<Setter Property="Background" Value="Transparent"/>
										<Setter Property="Transitions">
											<Transitions><BrushTransition Property="Background" Duration="0:0:0.15"/></Transitions>
										</Setter>
									</Style>
								</Button.Styles>
								<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
									<TextBlock Text="+" Foreground="White" FontSize="18" VerticalAlignment="Center"/>
									<TextBlock Text="Offline" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
								</StackPanel>
							</Button>
						</Grid>

						<!-- Inline: Add Offline Account form (hidden by default) -->
						<Border x:Name="AddOfflinePanel" Grid.Row="1" Margin="28,12,28,0" IsVisible="False"
								Background="#0F1A24" CornerRadius="12" Padding="16,14"
								BorderBrush="#1C2A38" BorderThickness="1.5">
							<StackPanel Spacing="10">
								<TextBlock Text="ADD OFFLINE ACCOUNT" FontSize="10" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1"/>
								<Grid ColumnDefinitions="*,10,Auto">
									<TextBox x:Name="OfflineUsernameBox" Grid.Column="0"
											 Watermark="Enter username..."
											 Background="#0A1018" Foreground="White"
											 CornerRadius="10" Padding="12,10" FontSize="13"
											 BorderBrush="#1C2A38" BorderThickness="1.5">
										<TextBox.Styles>
											<Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
												<Setter Property="BorderBrush" Value="#9333EA"/>
												<Setter Property="BorderThickness" Value="1.5"/>
												<Setter Property="Background" Value="#0A1018"/>
											</Style>
										</TextBox.Styles>
									</TextBox>
									<Button Grid.Column="2" Click="OnAddOfflineConfirm"
											Padding="16,10" CornerRadius="10" Cursor="Hand"
											BorderThickness="0" Foreground="White" FontWeight="Bold" FontSize="12">
										<Button.Background>
											<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
												<GradientStop Offset="0" Color="#7C3AED"/>
												<GradientStop Offset="1" Color="#5B21B6"/>
											</LinearGradientBrush>
										</Button.Background>
										<Button.Styles>
											<Style Selector="Button:pointerover /template/ ContentPresenter">
												<Setter Property="Background" Value="Transparent"/>
											</Style>
										</Button.Styles>
										<TextBlock Text="Add"/>
									</Button>
								</Grid>
								<Button Click="OnCancelAddOffline" Background="Transparent" BorderThickness="0"
										Cursor="Hand" Padding="0,4" HorizontalAlignment="Left">
									<TextBlock Text="Cancel" Foreground="#6B7280" FontSize="11"/>
								</Button>
							</StackPanel>
						</Border>

						<!-- Inline: Microsoft auth status (hidden by default) -->
						<Border x:Name="MsAuthStatusPanel" Grid.Row="1" Margin="28,12,28,0" IsVisible="False"
								Background="#0F1A24" CornerRadius="12" Padding="20,16"
								BorderBrush="#1C2A38" BorderThickness="1.5">
							<StackPanel Spacing="10" HorizontalAlignment="Center">
								<TextBlock x:Name="MsAuthStatusText" Text="Opening browser for Microsoft login..."
										   Foreground="#B080FF" FontSize="13" FontWeight="SemiBold"
										   HorizontalAlignment="Center"/>
								<TextBlock x:Name="MsAuthSubText" Text="Complete the sign-in in your browser"
										   Foreground="#6B7280" FontSize="11" HorizontalAlignment="Center"/>
								<Button Click="OnCancelMsAuth" Background="Transparent" BorderThickness="0"
										Cursor="Hand" Padding="0,4" HorizontalAlignment="Center">
									<TextBlock Text="Cancel" Foreground="#6B7280" FontSize="11"/>
								</Button>
							</StackPanel>
						</Border>

						<!-- Accounts list -->
						<ScrollViewer Grid.Row="2" Margin="28,14,28,0" VerticalScrollBarVisibility="Hidden">
							<StackPanel x:Name="AccountsListPanel" Spacing="6"/>
						</ScrollViewer>

						<!-- Account panel footer buttons -->
						<StackPanel Grid.Row="3" Margin="28,12,28,24" Spacing="8">
							<StackPanel x:Name="AccountFooterButtonsPanel" Spacing="8">
								<Button Height="40"
										Background="#0D1A2A"
										BorderThickness="1"
										BorderBrush="#153D3D"
										CornerRadius="10"
										HorizontalAlignment="Stretch"
										Cursor="Hand"
										Click="LinkWebsiteButton_Click">
									<Button.Styles>
										<Style Selector="Button:pointerover /template/ ContentPresenter">
											<Setter Property="Background" Value="#153D3D"/>
										</Style>
										<Style Selector="Button /template/ ContentPresenter">
											<Setter Property="Background" Value="Transparent"/>
											<Setter Property="Transitions">
												<Transitions>
													<BrushTransition Property="Background" Duration="0:0:0.15"/>
												</Transitions>
											</Setter>
										</Style>
									</Button.Styles>
									<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
										<TextBlock Text="&#x1F517;" FontSize="13" VerticalAlignment="Center"/>
										<TextBlock Text="LINK WEBSITE" Foreground="#6BDFFF" FontSize="12" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center"/>
									</StackPanel>
								</Button>
								<Button Height="40"
										Background="#2A0D0D"
										BorderThickness="1"
										BorderBrush="#3D1515"
										CornerRadius="10"
										HorizontalAlignment="Stretch"
										Cursor="Hand"
										Click="LogoutButton_Click">
									<Button.Styles>
										<Style Selector="Button:pointerover /template/ ContentPresenter">
											<Setter Property="Background" Value="#3D1515"/>
										</Style>
										<Style Selector="Button /template/ ContentPresenter">
											<Setter Property="Background" Value="Transparent"/>
											<Setter Property="Transitions">
												<Transitions>
													<BrushTransition Property="Background" Duration="0:0:0.15"/>
												</Transitions>
											</Setter>
										</Style>
									</Button.Styles>
									<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
										<TextBlock Text="&#x2BBF;" Foreground="#FF6B6B" FontSize="14" VerticalAlignment="Center"/>
										<TextBlock Text="LOG OUT" Foreground="#FF6B6B" FontSize="12" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center"/>
									</StackPanel>
								</Button>
							</StackPanel>

							<!-- Inline weblink panel (shown when Link Website is clicked) -->
							<Border x:Name="WebLinkInlinePanel" IsVisible="False"
									Background="#0A1520"
									BorderBrush="#153D3D"
									BorderThickness="1"
									CornerRadius="10"
									Padding="14,12">
								<StackPanel Spacing="8">

									<!-- Code entry state -->
									<StackPanel x:Name="WebLinkCodeEntryPanel" Spacing="8">
										<TextBlock Text="Enter the 6-character code from the website:"
												   Foreground="#9BA1A8" FontSize="11"
												   TextWrapping="Wrap"/>
										<TextBox x:Name="WebLinkCodeTextBox"
												 Watermark="e.g. MSCUFQ"
												 MaxLength="6"
												 FontSize="16" FontWeight="Bold"
												 LetterSpacing="4"
												 HorizontalContentAlignment="Center"
												 Background="#0D1A2A"
												 BorderBrush="#153D3D"
												 BorderThickness="1"
												 CornerRadius="8"
												 Foreground="#6BDFFF"
												 CaretBrush="#6BDFFF"
												 Padding="10,8"/>
										<Grid ColumnDefinitions="*,8,*">
											<Button Grid.Column="0" Height="34"
													Background="#0D2A1A"
													BorderThickness="1"
													BorderBrush="#1A5C2A"
													CornerRadius="8"
													HorizontalAlignment="Stretch"
													HorizontalContentAlignment="Center"
													VerticalContentAlignment="Center"
													Padding="0"
													Cursor="Hand"
													Click="WebLinkConfirmButton_Click">
												<Button.Styles>
													<Style Selector="Button:pointerover /template/ ContentPresenter">
														<Setter Property="Background" Value="#1A5C2A"/>
													</Style>
													<Style Selector="Button /template/ ContentPresenter">
														<Setter Property="Background" Value="Transparent"/>
													</Style>
												</Button.Styles>
												<TextBlock Text="CONFIRM" Foreground="#6BDF9F" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center"/>
											</Button>
											<Button Grid.Column="2" Height="34"
													Background="#1A1A1A"
													BorderThickness="1"
													BorderBrush="#333"
													CornerRadius="8"
													HorizontalAlignment="Stretch"
													HorizontalContentAlignment="Center"
													VerticalContentAlignment="Center"
													Padding="0"
													Cursor="Hand"
													Click="WebLinkCancelButton_Click">
												<Button.Styles>
													<Style Selector="Button:pointerover /template/ ContentPresenter">
														<Setter Property="Background" Value="#333"/>
													</Style>
													<Style Selector="Button /template/ ContentPresenter">
														<Setter Property="Background" Value="Transparent"/>
													</Style>
												</Button.Styles>
												<TextBlock Text="CANCEL" Foreground="#9BA1A8" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center"/>
											</Button>
										</Grid>
									</StackPanel>

									<!-- Result state (success / error) -->
									<StackPanel x:Name="WebLinkResultPanel" IsVisible="False" Spacing="10">
										<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
											<TextBlock x:Name="WebLinkResultIcon" Text="✓" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
											<TextBlock x:Name="WebLinkResultText" FontSize="12" FontWeight="SemiBold"
													   TextWrapping="Wrap" VerticalAlignment="Center"/>
										</StackPanel>
										<Button Height="34"
												Background="#1A1A1A"
												BorderThickness="1"
												BorderBrush="#333"
												CornerRadius="8"
												HorizontalAlignment="Stretch"
												HorizontalContentAlignment="Center"
												VerticalContentAlignment="Center"
												Padding="0"
												Cursor="Hand"
												Click="WebLinkCancelButton_Click">
											<Button.Styles>
												<Style Selector="Button:pointerover /template/ ContentPresenter">
													<Setter Property="Background" Value="#333"/>
												</Style>
												<Style Selector="Button /template/ ContentPresenter">
													<Setter Property="Background" Value="Transparent"/>
												</Style>
											</Button.Styles>
											<TextBlock Text="OK" Foreground="#9BA1A8" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center"/>
										</Button>
									</StackPanel>

								</StackPanel>
							</Border>
						</StackPanel>
					</Grid>

					<!-- Vertical divider -->
					<Border Grid.Column="1" Width="1" Background="#12FFFFFF" Margin="0,20"/>

					<!-- RIGHT COLUMN: Skin Preview -->
					<Grid Grid.Column="2">
						<Grid.RowDefinitions>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<!-- Skin render area (image only) -->
						<Border Grid.Row="0"
								Margin="20,20,20,8"
								CornerRadius="16"
								ClipToBounds="True"
								BorderBrush="#152030" BorderThickness="1">
							<Border.Background>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
									<GradientStop Color="#0C1620" Offset="0"/>
									<GradientStop Color="#080D15" Offset="1"/>
								</LinearGradientBrush>
							</Border.Background>

							<Grid>
								<Ellipse Width="180" Height="180" Opacity="0.1" HorizontalAlignment="Center" VerticalAlignment="Center">
									<Ellipse.Fill>
										<RadialGradientBrush>
											<GradientStop Color="#7B2CBF" Offset="0"/>
											<GradientStop Color="Transparent" Offset="1"/>
										</RadialGradientBrush>
									</Ellipse.Fill>
								</Ellipse>

								<Image x:Name="AccountCharacterImage"
									   Stretch="Uniform"
									   MaxHeight="200"
									   MaxWidth="120"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"/>

								<!-- Edit skin button (top-right overlay) -->
								<Button HorizontalAlignment="Right" VerticalAlignment="Top"
										Margin="0,10,10,0"
										Background="#22FFFFFF"
										BorderThickness="0"
										CornerRadius="8"
										Padding="10,6"
										Cursor="Hand"
										Click="OpenSkinsPage">
									<TextBlock Text="Edit Skin" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
								</Button>
							</Grid>
						</Border>

						<!-- Username (below skin) -->
						<TextBlock Grid.Row="1" x:Name="AccountUsernameDisplay"
								   Text="&#x2014;"
								   Foreground="White"
								   FontWeight="Black"
								   FontSize="16"
								   HorizontalAlignment="Center"
								   Margin="0,4,0,6"
								   LetterSpacing="1"/>

						<!-- UUID badge (below username) -->
						<Border Grid.Row="2" Background="#0F1A24" CornerRadius="8" HorizontalAlignment="Center"
								Padding="10,5" Cursor="Hand" PointerPressed="CopyUuidToClipboard"
								BorderBrush="#1C2A38" BorderThickness="1" Margin="0,0,0,8">
							<StackPanel Orientation="Horizontal" Spacing="5">
								<TextBlock Text="#" Foreground="#4B5563" FontSize="10" FontWeight="Bold"/>
								<TextBlock x:Name="AccountUuidDisplay"
										   Text="&#x2014;"
										   Foreground="#6B7280"
										   FontSize="10"
										   FontFamily="Consolas, Monospace"/>
								<TextBlock Text="COPY" Foreground="#4B5563" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="3,0,0,0"/>
							</StackPanel>
							<ToolTip.Tip>Click to copy UUID</ToolTip.Tip>
						</Border>

						<!-- Account type badge -->
						<Border Grid.Row="3" Margin="20,0,20,20" HorizontalAlignment="Center">
							<Border x:Name="AccountTypeBadge"
									Background="#0F1A24"
									CornerRadius="10"
									Padding="14,7"
									BorderBrush="#1C2A38" BorderThickness="1">
								<StackPanel Orientation="Horizontal" Spacing="7">
									<Ellipse x:Name="AccountOnlineDot" Width="7" Height="7" Fill="#9333EA" VerticalAlignment="Center"/>
									<TextBlock x:Name="AccountTypeLabel"
											   Text="Microsoft Account"
											   Foreground="#9CA3AF"
											   FontSize="11"
											   FontWeight="SemiBold"/>
								</StackPanel>
							</Border>
						</Border>
					</Grid>
				</Grid>
			</Border>
		</Grid>


		<!-- Global tooltip layer (on top of everything) -->
		<Canvas x:Name="GlobalTooltipLayer"
				IsHitTestVisible="False"
				Panel.ZIndex="9999">
			<!-- Sidebar Tooltip -->
			<Border x:Name="SidebarHoverTooltip"
					MinWidth="80" Height="26"
					Background="{DynamicResource HoverBackgroundBrush}"
					CornerRadius="13"
					Opacity="0"
					IsVisible="False">
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
						<DoubleTransition Property="(Canvas.Top)" Duration="0:0:0.25" Easing="CubicEaseOut"/>
						<DoubleTransition Property="(Canvas.Left)" Duration="0:0:0.25" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>
				<TextBlock x:Name="SidebarHoverTooltipText"
						   Text="LAUNCH"
						   Foreground="{DynamicResource PrimaryForegroundBrush}"
						   FontSize="11"
						   FontWeight="Bold"
						   Margin="10,0"
						   HorizontalAlignment="Center"
						   VerticalAlignment="Center"/>
			</Border>

			<!-- Quick Play Server Tooltip -->
			<Border x:Name="QuickPlayTooltip"
					MinWidth="80" Height="26"
					Background="{DynamicResource HoverBackgroundBrush}"
					CornerRadius="13"
					Opacity="0"
					IsVisible="False">
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
						<DoubleTransition Property="(Canvas.Top)" Duration="0:0:0.25" Easing="CubicEaseOut"/>
						<DoubleTransition Property="(Canvas.Left)" Duration="0:0:0.25" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>
				<TextBlock x:Name="QuickPlayTooltipText"
						   Text="2B2T"
						   Foreground="{DynamicResource PrimaryForegroundBrush}"
						   FontSize="11"
						   FontWeight="Bold"
						   Margin="10,0"
						   HorizontalAlignment="Center"
						   VerticalAlignment="Center"/>
			</Border>
		</Canvas>
		<!-- Resolution Preset Pop-up Overlay -->
		<Grid x:Name="ResolutionPresetOverlay" IsVisible="False" ZIndex="2000">
			<Border Background="#80000000" PointerPressed="CloseResolutionPreset" />
			<Border x:Name="ResolutionPresetPanel"
					Width="560"
					MaxHeight="600"
					Background="{DynamicResource CardBackgroundColor}"
					CornerRadius="18"
					Padding="24"
					HorizontalAlignment="Center"
					VerticalAlignment="Top"
					Margin="0,60,0,0"
					BoxShadow="0 10 40 5 #40000000">
				<Border.RenderTransform>
					<TranslateTransform Y="-700"/>
				</Border.RenderTransform>
				<StackPanel Spacing="18">
					<!-- Header -->
					<Grid ColumnDefinitions="*,Auto">
						<TextBlock Text="Select a Preset"
								   Foreground="{DynamicResource PrimaryForegroundBrush}"
								   FontWeight="ExtraBold"
								   FontSize="22"/>
						<Button x:Name="ResolutionPresetCloseButton"
								Grid.Column="1"
								Width="32" Height="32"
								CornerRadius="8"
								Background="{DynamicResource HoverBackgroundBrush}"
								Click="CloseResolutionPreset">
							<TextBlock Text="✕"
									   Foreground="{DynamicResource PrimaryForegroundBrush}"
									   FontSize="14"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"/>
						</Button>
					</Grid>

					<!-- 16:9 -->
					<StackPanel Spacing="10">
						<TextBlock Text="16:9 aspect ratio"
								   Foreground="{DynamicResource SecondaryForegroundBrush}"
								   FontSize="12"/>
						<WrapPanel ItemWidth="240" ItemHeight="40" Orientation="Horizontal">
							<Button Tag="1920x1080" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}"
									Foreground="{DynamicResource PrimaryForegroundBrush}"
									BorderThickness="0" CornerRadius="10">
								<TextBlock Text="✨ 1920×1080" FontWeight="Bold"/>
							</Button>
							<Button Tag="1600x900" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="1600×900" FontWeight="Bold"/>
							</Button>
							<Button Tag="1366x768" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="1366×768" FontWeight="Bold"/>
							</Button>
							<Button Tag="1280x720" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="1280×720" FontWeight="Bold"/>
							</Button>
							<Button Tag="1024x576" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="1024×576" FontWeight="Bold"/>
							</Button>
							<Button Tag="960x540" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="960×540" FontWeight="Bold"/>
							</Button>
						</WrapPanel>
					</StackPanel>

					<!-- 4:3 -->
					<StackPanel Spacing="10">
						<TextBlock Text="4:3 aspect ratio"
								   Foreground="{DynamicResource SecondaryForegroundBrush}"
								   FontSize="12"/>
						<WrapPanel ItemWidth="240" ItemHeight="40" Orientation="Horizontal">
							<Button Tag="1600x1200" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="✨ 1600×1200" FontWeight="Bold"/>
							</Button>
							<Button Tag="1280x960" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="1280×960" FontWeight="Bold"/>
							</Button>
							<Button Tag="1152x864" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="1152×864" FontWeight="Bold"/>
							</Button>
							<Button Tag="1024x768" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="1024×768" FontWeight="Bold"/>
							</Button>
							<Button Tag="800x600" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="800×600" FontWeight="Bold"/>
							</Button>
							<Button Tag="640x480" Click="OnPresetClicked"
									Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="0" CornerRadius="10">
								<TextBlock Text="640×480" FontWeight="Bold"/>
							</Button>
						</WrapPanel>
					</StackPanel>
				</StackPanel>
			</Border>
		</Grid>

		<!-- Resolution Visualizer Overlay (updated to show actual box at screen DPI) -->
		<Grid x:Name="ResolutionVisualOverlay" IsVisible="False" ZIndex="2000">
			<Border Background="#80000000" PointerPressed="CloseResolutionVisualOverlay"/>
			<Border x:Name="ResolutionVisualPanel"
					Background="{DynamicResource CardBackgroundColor}"
					CornerRadius="18"
					Padding="24"
					HorizontalAlignment="Center"
					VerticalAlignment="Top"
					Margin="0,60,0,0"
					BoxShadow="0 10 40 5 #40000000">
				<Border.RenderTransform>
					<TranslateTransform Y="-700"/>
				</Border.RenderTransform>

				<Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
					<!-- Header -->
					<Grid ColumnDefinitions="*,Auto">
						<TextBlock Text="Resolution Preview"
								   Foreground="{DynamicResource PrimaryForegroundBrush}"
								   FontWeight="ExtraBold"
								   FontSize="18"/>
						<Button Grid.Column="1"
								Background="{DynamicResource PrimaryAccentBrush}"
								Foreground="{DynamicResource AccentButtonForegroundBrush}"
								BorderThickness="0"
								CornerRadius="8"
								Padding="18,8"
								FontWeight="Bold"
								Cursor="Hand"
								Click="CloseResolutionVisualOverlay">
							<TextBlock Text="Close"/>
						</Button>
					</Grid>

					<!-- Preview area: centers the box -->
					<Grid Grid.Row="1">
						<Border x:Name="ResolutionBox"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Background="#202020"
								BorderBrush="{DynamicResource PrimaryAccentBrush}"
								BorderThickness="2"
								CornerRadius="12"
								Opacity="0.85">
							<!-- Size label inside the box -->
							<TextBlock x:Name="ResolutionVisualText"
									   Text="854×480"
									   Foreground="{DynamicResource AccentButtonForegroundBrush}"
									   FontWeight="ExtraBold"
									   FontSize="18"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"/>
						</Border>
					</Grid>

					<!-- Scale note -->
					<TextBlock Grid.Row="2"
							   x:Name="ResolutionScaleNote"
							   Text="1.00× scale (true size)"
							   Foreground="{DynamicResource SecondaryForegroundBrush}"
							   FontSize="12"
							   HorizontalAlignment="Center"/>
				</Grid>
			</Border>
		</Grid>
		<!-- ═══════════════════════════════════════════════════════════════
		     About Leaf Client Pop-up Overlay (redesigned)
		     Matches the new MainWindow / LoginWindow look: gradient dark
		     card, purple accent-bar header, vector feature icons, pill
		     mod chips.
		     ═══════════════════════════════════════════════════════════════ -->
		<Grid x:Name="AboutLeafClientOverlay" IsVisible="False" ZIndex="2000">
			<Border x:Name="AboutLeafClientBackdrop" Background="#B0000000" Opacity="0"
					PointerPressed="CloseAboutLeafClient">
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>
			</Border>

			<Border x:Name="AboutLeafClientPanel"
					Width="720"
					MaxHeight="640"
					CornerRadius="20"
					Padding="0"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					BorderThickness="1"
					BorderBrush="#1C2A38"
					BoxShadow="0 24 60 0 #A0000000"
					Opacity="0"
					ClipToBounds="True"
					RenderTransformOrigin="0.5,0.5"
					x:DataType="viewmodels:MainWindowViewModel">
				<Border.Background>
					<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
						<GradientStop Offset="0" Color="#0F1A24"/>
						<GradientStop Offset="1" Color="#070B12"/>
					</LinearGradientBrush>
				</Border.Background>
				<Border.RenderTransform>
					<ScaleTransform ScaleX="0.92" ScaleY="0.92"/>
				</Border.RenderTransform>
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut"/>
						<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.32" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>

				<Grid RowDefinitions="Auto,*">
					<!-- Header bar with accent bar + close button -->
					<Border Grid.Row="0" Padding="28,22,18,18" BorderThickness="0,0,0,1" BorderBrush="#152030">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
								<Border Width="3" Height="22" CornerRadius="2" VerticalAlignment="Center">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
											<GradientStop Offset="0" Color="#9333EA"/>
											<GradientStop Offset="1" Color="#6D28D9"/>
										</LinearGradientBrush>
									</Border.Background>
								</Border>
								<StackPanel Spacing="2">
									<TextBlock Text="ABOUT LEAF CLIENT"
											   Foreground="#E5E7EB" FontWeight="Black"
											   FontSize="20" LetterSpacing="1.5"/>
									<TextBlock Text="A modern Minecraft launcher &amp; in-game client."
											   Foreground="#6B7280" FontSize="12"/>
								</StackPanel>
							</StackPanel>
							<Border Grid.Column="2" Width="32" Height="32" CornerRadius="10"
									Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1"
									Cursor="Hand" PointerPressed="CloseAboutLeafClient"
									VerticalAlignment="Center">
								<Path Width="12" Height="12" Stretch="Uniform"
									  Stroke="#9CA3AF" StrokeThickness="2" StrokeLineCap="Round"
									  Data="M4,4 L16,16 M16,4 L4,16"/>
							</Border>
						</Grid>
					</Border>

					<!-- Scrollable content -->
					<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,22,28,26">
						<StackPanel Spacing="22">
							<!-- Hero description card -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1"
									CornerRadius="14" Padding="20">
								<TextBlock TextWrapping="Wrap"
										   Foreground="#CBD5E1"
										   FontSize="13"
										   LineHeight="21">
									Leaf Client is a powerful, modern Minecraft launcher and client designed to enhance your gameplay experience.
									Built with performance and customization in mind, Leaf Client offers seamless version management,
									mod support, and exclusive in-game features.
								</TextBlock>
							</Border>

							<!-- Key Features section header -->
							<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
								<Border Width="3" Height="16" CornerRadius="2" VerticalAlignment="Center">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
											<GradientStop Offset="0" Color="#9333EA"/>
											<GradientStop Offset="1" Color="#6D28D9"/>
										</LinearGradientBrush>
									</Border.Background>
								</Border>
								<TextBlock Text="KEY FEATURES" Foreground="#E5E7EB" FontWeight="Black" FontSize="13" LetterSpacing="1.2"/>
							</StackPanel>

							<!-- Key Features grid cards -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1" CornerRadius="14" Padding="20">
								<StackPanel Spacing="16">
									<!-- Feature 1 -->
									<Grid ColumnDefinitions="Auto,*">
										<Border Grid.Column="0" Width="34" Height="34" CornerRadius="10"
												Background="#1A9333EA" Margin="0,0,14,0">
											<Path Width="18" Height="18" Stretch="Uniform"
												  Stroke="#C4B5FD" StrokeThickness="1.8"
												  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
												  Data="M4,20 L8,16 M12,4 C15,4 18,5 20,7 C19,11 16,14 12,16 C9,15 6,12 4,10 C5,6 8,4 12,4 Z M13,10 A1.5,1.5 0 1 1 13,10.01 Z"/>
										</Border>
										<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
											<TextBlock Text="Advanced Launcher" Foreground="#F3F4F6" FontWeight="Bold" FontSize="13"/>
											<TextBlock Text="Fast version switching, Fabric support, and OptiFine integration"
													   Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
										</StackPanel>
									</Grid>
									<Separator Background="#152030" Margin="0"/>
									<!-- Feature 2 -->
									<Grid ColumnDefinitions="Auto,*">
										<Border Grid.Column="0" Width="34" Height="34" CornerRadius="10"
												Background="#1A9333EA" Margin="0,0,14,0">
											<Path Width="18" Height="18" Stretch="Uniform"
												  Stroke="#C4B5FD" StrokeThickness="1.8"
												  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
												  Data="M6,8 L18,8 C20,8 21,9 21,11 L21,15 C21,17 20,18 18,18 L6,18 C4,18 3,17 3,15 L3,11 C3,9 4,8 6,8 Z M7,12 L7,14 M6,13 L8,13 M15,12 L15,12.01 M17,14 L17,14.01"/>
										</Border>
										<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
											<TextBlock Text="In-Game Client Mods" Foreground="#F3F4F6" FontWeight="Bold" FontSize="13"/>
											<TextBlock Text="Performance boosts, HUD customization, and quality-of-life improvements"
													   Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
										</StackPanel>
									</Grid>
									<Separator Background="#152030" Margin="0"/>
									<!-- Feature 3 -->
									<Grid ColumnDefinitions="Auto,*">
										<Border Grid.Column="0" Width="34" Height="34" CornerRadius="10"
												Background="#1A9333EA" Margin="0,0,14,0">
											<Path Width="18" Height="18" Stretch="Uniform"
												  Stroke="#C4B5FD" StrokeThickness="1.8"
												  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
												  Data="M13,2 L5,14 L12,14 L11,22 L19,10 L12,10 Z"/>
										</Border>
										<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
											<TextBlock Text="Quick Play" Foreground="#F3F4F6" FontWeight="Bold" FontSize="13"/>
											<TextBlock Text="Join your favorite servers instantly with one click"
													   Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
										</StackPanel>
									</Grid>
									<Separator Background="#152030" Margin="0"/>
									<!-- Feature 4 -->
									<Grid ColumnDefinitions="Auto,*">
										<Border Grid.Column="0" Width="34" Height="34" CornerRadius="10"
												Background="#1A9333EA" Margin="0,0,14,0">
											<Path Width="18" Height="18" Stretch="Uniform"
												  Stroke="#C4B5FD" StrokeThickness="1.8"
												  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
												  Data="M12,2 C7,2 3,6 3,11 C3,15 6,18 10,18 C10,16 12,15 13,15 C14,15 15,14 15,13 C15,12 16,11 18,11 C20,11 21,12 21,11 C21,6 17,2 12,2 Z M7,9 A1,1 0 1 1 7,9.01 Z M10,6 A1,1 0 1 1 10,6.01 Z M15,6 A1,1 0 1 1 15,6.01 Z M18,9 A1,1 0 1 1 18,9.01 Z"/>
										</Border>
										<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
											<TextBlock Text="Custom Skins" Foreground="#F3F4F6" FontWeight="Bold" FontSize="13"/>
											<TextBlock Text="Manage and apply skins directly from the launcher"
													   Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
										</StackPanel>
									</Grid>
									<Separator Background="#152030" Margin="0"/>
									<!-- Feature 5 -->
									<Grid ColumnDefinitions="Auto,*">
										<Border Grid.Column="0" Width="34" Height="34" CornerRadius="10"
												Background="#1A9333EA" Margin="0,0,14,0">
											<Path Width="18" Height="18" Stretch="Uniform"
												  Stroke="#C4B5FD" StrokeThickness="1.8"
												  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
												  Data="M14.7,6.3 A4,4 0 0 0 9.3,11.7 L3,18 L3,21 L6,21 L12.3,14.7 A4,4 0 0 0 17.7,9.3 L15,12 L12,9 Z"/>
										</Border>
										<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
											<TextBlock Text="Extensive Settings" Foreground="#F3F4F6" FontWeight="Bold" FontSize="13"/>
											<TextBlock Text="Fine-tune every aspect of your Minecraft experience"
													   Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"/>
										</StackPanel>
									</Grid>
								</StackPanel>
							</Border>

							<!-- Included Client Mods header -->
							<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
								<Border Width="3" Height="16" CornerRadius="2" VerticalAlignment="Center">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
											<GradientStop Offset="0" Color="#9333EA"/>
											<GradientStop Offset="1" Color="#6D28D9"/>
										</LinearGradientBrush>
									</Border.Background>
								</Border>
								<TextBlock Text="INCLUDED CLIENT MODS" Foreground="#E5E7EB" FontWeight="Black" FontSize="13" LetterSpacing="1.2"/>
							</StackPanel>

							<!-- Mod chip wrap -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1" CornerRadius="14" Padding="16">
								<WrapPanel>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="ArmorHUD" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="ChatMacros" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Coordinates" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="CPS Counter" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Crosshair" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="FPS Display" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Spectate" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="FullBright" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="HUD Themes" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Item Counter" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Keystrokes" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Minimap" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Performance" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Ping Display" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Replay Mod" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Server Info" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Toggle Sprint" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Waypoints" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
									<Border Background="#12202E" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,7,7">
										<TextBlock Text="Zoom" FontSize="11" FontWeight="SemiBold" Foreground="#CBD5E1"/>
									</Border>
								</WrapPanel>
							</Border>

							<!-- Developer header -->
							<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
								<Border Width="3" Height="16" CornerRadius="2" VerticalAlignment="Center">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
											<GradientStop Offset="0" Color="#9333EA"/>
											<GradientStop Offset="1" Color="#6D28D9"/>
										</LinearGradientBrush>
									</Border.Background>
								</Border>
								<TextBlock Text="DEVELOPER" Foreground="#E5E7EB" FontWeight="Black" FontSize="13" LetterSpacing="1.2"/>
							</StackPanel>

							<!-- Developer card with GitHub link -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1" CornerRadius="14" Padding="18">
								<Grid ColumnDefinitions="Auto,*,Auto">
									<Border Grid.Column="0" Width="40" Height="40" CornerRadius="12"
											Background="#1A9333EA" Margin="0,0,14,0">
										<Path Width="20" Height="20" Stretch="Uniform"
											  Stroke="#C4B5FD" StrokeThickness="1.8"
											  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
											  Data="M12,2 A10,10 0 0 0 9,21.5 C9.5,21.5 10,21 10,20.5 L10,18.5 C7,19 6,17 6,17 C5.5,16 4.5,15.5 4.5,15.5 C3.5,15 5,15 5,15 C6,15 6.5,16 6.5,16 C7.5,17.5 9,17 10,16.5 C10,15.5 10.5,15 11,14.5 C8.5,14 6,13 6,9 C6,8 6.5,7 7,6.5 C7,6 6.5,5 7,3.5 C7,3.5 8,3 10,4.5 C11,4 13,4 14,4.5 C16,3 17,3.5 17,3.5 C17.5,5 17,6 17,6.5 C17.5,7 18,8 18,9 C18,13 15.5,14 13,14.5 C13.5,15 14,16 14,17 L14,20.5 C14,21 14.5,21.5 15,21.5 A10,10 0 0 0 12,2 Z"/>
									</Border>
									<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
										<TextBlock Text="voidZiAD" Foreground="#F3F4F6" FontWeight="Bold" FontSize="14"/>
										<TextBlock Text="Creator &amp; lead developer of Leaf Client" Foreground="#9CA3AF" FontSize="12"/>
									</StackPanel>
									<Border Grid.Column="2" CornerRadius="10" Padding="14,9" VerticalAlignment="Center" Cursor="Hand"
											PointerPressed="OpenDeveloperGitHubBorder">
										<Border.Background>
											<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
												<GradientStop Offset="0" Color="#9333EA"/>
												<GradientStop Offset="0.55" Color="#7B2CBF"/>
												<GradientStop Offset="1" Color="#6B21A8"/>
											</LinearGradientBrush>
										</Border.Background>
										<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
											<TextBlock Text="VIEW GITHUB" FontSize="11" FontWeight="Bold" Foreground="White" LetterSpacing="1" VerticalAlignment="Center"/>
											<TextBlock Text="↗" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
										</StackPanel>
									</Border>
								</Grid>
							</Border>

							<!-- Last updated -->
							<TextBlock Text="{Binding LastUpdatedText}"
									   Foreground="#6B7280"
									   FontSize="11"
									   HorizontalAlignment="Center"
									   Margin="0,8,0,0"/>
						</StackPanel>
					</ScrollViewer>
				</Grid>
			</Border>
		</Grid>
		<!-- ═══════════════════════════════════════════════════════════════
		     Common Questions Pop-up Overlay (redesigned)
		     Matches the new MainWindow / LoginWindow look: gradient dark
		     card, purple accent-bar header, dark-surface Q/A cards with
		     little purple Q chip, smooth scale+opacity transition.
		     ═══════════════════════════════════════════════════════════════ -->
		<Grid x:Name="CommonQuestionsOverlay" IsVisible="False" ZIndex="2000">
			<Border x:Name="CommonQuestionsBackdrop" Background="#B0000000" Opacity="0"
					PointerPressed="CloseCommonQuestions">
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>
			</Border>

			<Border x:Name="CommonQuestionsPanel"
                    Width="720"
                    MaxHeight="640"
                    CornerRadius="20"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderThickness="1"
                    BorderBrush="#1C2A38"
                    BoxShadow="0 24 60 0 #A0000000"
                    Opacity="0"
                    ClipToBounds="True"
                    RenderTransformOrigin="0.5,0.5"
                    x:DataType="viewmodels:MainWindowViewModel">
				<Border.Background>
					<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
						<GradientStop Offset="0" Color="#0F1A24"/>
						<GradientStop Offset="1" Color="#070B12"/>
					</LinearGradientBrush>
				</Border.Background>
				<Border.RenderTransform>
					<ScaleTransform ScaleX="0.92" ScaleY="0.92"/>
				</Border.RenderTransform>
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut"/>
						<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.32" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>

				<Grid RowDefinitions="Auto,*">
					<!-- Header bar with accent bar + close button -->
					<Border Grid.Row="0" Padding="28,22,18,18" BorderThickness="0,0,0,1" BorderBrush="#152030">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
								<Border Width="3" Height="22" CornerRadius="2" VerticalAlignment="Center">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
											<GradientStop Offset="0" Color="#9333EA"/>
											<GradientStop Offset="1" Color="#6D28D9"/>
										</LinearGradientBrush>
									</Border.Background>
								</Border>
								<StackPanel Spacing="2">
									<TextBlock Text="COMMON QUESTIONS"
											   Foreground="#E5E7EB" FontWeight="Black"
											   FontSize="20" LetterSpacing="1.5"/>
									<TextBlock Text="Quick answers to things people ask most."
											   Foreground="#6B7280" FontSize="12"/>
								</StackPanel>
							</StackPanel>
							<Border Grid.Column="2" Width="32" Height="32" CornerRadius="10"
									Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1"
									Cursor="Hand" PointerPressed="CloseCommonQuestions"
									VerticalAlignment="Center">
								<Path Width="12" Height="12" Stretch="Uniform"
									  Stroke="#9CA3AF" StrokeThickness="2" StrokeLineCap="Round"
									  Data="M4,4 L16,16 M16,4 L4,16"/>
							</Border>
						</Grid>
					</Border>

					<!-- Scrollable Q/A list -->
					<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,22,28,48">
						<StackPanel Spacing="14">

							<!-- FAQ 1 -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1" CornerRadius="14" Padding="20,16">
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
										<Border Width="26" Height="26" CornerRadius="8" Background="#1A9333EA" VerticalAlignment="Center">
											<TextBlock Text="Q" Foreground="#C4B5FD" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Is Leaf Client free?" Foreground="#F3F4F6" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
									</StackPanel>
									<TextBlock Text="Yes — Leaf Client is completely free to download and use. Premium cosmetics are optional."
											   TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="13" LineHeight="20" Margin="38,0,0,0"/>
								</StackPanel>
							</Border>

							<!-- FAQ 2 -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1" CornerRadius="14" Padding="20,16">
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
										<Border Width="26" Height="26" CornerRadius="8" Background="#1A9333EA" VerticalAlignment="Center">
											<TextBlock Text="Q" Foreground="#C4B5FD" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Which Minecraft versions does Leaf Client support?" Foreground="#F3F4F6" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
									</StackPanel>
									<TextBlock Text="Leaf Client supports a wide range of popular Minecraft versions — the latest releases and the older favorites used for competitive play."
											   TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="13" LineHeight="20" Margin="38,0,0,0"/>
								</StackPanel>
							</Border>

							<!-- FAQ 3 -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1" CornerRadius="14" Padding="20,16">
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
										<Border Width="26" Height="26" CornerRadius="8" Background="#1A9333EA" VerticalAlignment="Center">
											<TextBlock Text="Q" Foreground="#C4B5FD" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Can I use my existing Minecraft account?" Foreground="#F3F4F6" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
									</StackPanel>
									<TextBlock Text="Absolutely. Leaf Client signs in with your official Microsoft / Minecraft account — no separate account needed."
											   TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="13" LineHeight="20" Margin="38,0,0,0"/>
								</StackPanel>
							</Border>

							<!-- FAQ 4 -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1" CornerRadius="14" Padding="20,16">
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
										<Border Width="26" Height="26" CornerRadius="8" Background="#1A9333EA" VerticalAlignment="Center">
											<TextBlock Text="Q" Foreground="#C4B5FD" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Are custom mods supported?" Foreground="#F3F4F6" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
									</StackPanel>
									<TextBlock Text="Yes — Leaf Client integrates with Fabric and lets you manage and toggle your own client-side mods from the Mods page."
											   TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="13" LineHeight="20" Margin="38,0,0,0"/>
								</StackPanel>
							</Border>

							<!-- FAQ 5 -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1" CornerRadius="14" Padding="20,16">
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
										<Border Width="26" Height="26" CornerRadius="8" Background="#1A9333EA" VerticalAlignment="Center">
											<TextBlock Text="Q" Foreground="#C4B5FD" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="How do I get support or report a bug?" Foreground="#F3F4F6" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
									</StackPanel>
									<TextBlock Text="Use the hamburger menu → Support &amp; Feedback → Join Discord, or open Suggest / Report to send a bug report straight from the launcher."
											   TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="13" LineHeight="20" Margin="38,0,0,0"/>
								</StackPanel>
							</Border>

							<!-- Last updated -->
							<TextBlock Text="{Binding LastUpdatedText}"
									   Foreground="#6B7280" FontSize="11"
									   HorizontalAlignment="Center" Margin="0,8,0,0"/>
						</StackPanel>
					</ScrollViewer>
				</Grid>
			</Border>
		</Grid>
		<!-- Mod Browser Pop-up Overlay -->
		<Grid x:Name="ModBrowserOverlay" IsVisible="False" ZIndex="2000">
			<Border x:Name="ModBrowserBackdrop" Background="#B0000000" PointerPressed="CloseModBrowser">
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
					</Transitions>
				</Border.Transitions>
			</Border>

			<Border x:Name="ModBrowserPanel"
					Width="960"
					MaxHeight="720"
					Background="{DynamicResource CardBackgroundColor}"
					CornerRadius="18"
					Padding="0"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					BoxShadow="0 32 100 0 #70000000"
					RenderTransformOrigin="0.5,0.5">

				<Border.RenderTransform>
					<ScaleTransform ScaleX="0.92" ScaleY="0.92"/>
				</Border.RenderTransform>
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>

				<Grid RowDefinitions="Auto,*">

					<!-- Top bar: flat, no background border -->
					<Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="28,22,22,0">
						<TextBlock Grid.Column="0"
								   Text="Browse Mods"
								   Foreground="{DynamicResource PrimaryForegroundBrush}"
								   FontWeight="Bold"
								   FontSize="20"
								   VerticalAlignment="Center"/>

						<!-- Search pill -->
						<Border Grid.Column="1"
								Background="{DynamicResource TertiaryBackgroundBrush}"
								CornerRadius="10"
								Margin="20,0">
							<Grid ColumnDefinitions="Auto,*" Margin="12,0">
								<TextBlock Grid.Column="0"
										   Text="🔍"
										   FontSize="13"
										   Opacity="0.5"
										   VerticalAlignment="Center"
										   Margin="0,0,8,0"/>
								<TextBox x:Name="ModSearchBox"
										 Grid.Column="1"
										 Watermark="Search mods…"
										 Background="Transparent"
										 BorderThickness="0"
										 Padding="0,10"
										 FontSize="13"
										 TextChanged="OnModSearchTextChanged"/>
							</Grid>
						</Border>

						<!-- Close -->
						<Button Grid.Column="2"
								Classes="IconButton ColorBtn"
								Click="CloseModBrowser"
								Width="34" Height="34"
								CornerRadius="10"
								Background="{DynamicResource HoverBackgroundBrush}"
								VerticalAlignment="Center">
							<TextBlock Text="✕"
									   Foreground="{DynamicResource SecondaryForegroundBrush}"
									   FontSize="13"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"/>
						</Button>
					</Grid>

					<!-- Body: results + detail panel -->
					<Grid Grid.Row="1" ColumnDefinitions="*,320" Margin="0,14,0,0">

						<ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="28,0,28,24">
							<StackPanel>
								<WrapPanel x:Name="ModsResultsPanel" Orientation="Horizontal" Margin="0,0,0,10"/>

								<StackPanel x:Name="ModsLoadingPanel"
										    HorizontalAlignment="Center"
										    Spacing="12"
										    Margin="0,40,0,0"
										    IsVisible="False">
									<ProgressBar IsIndeterminate="True" Width="180" Height="4" CornerRadius="2"/>
									<TextBlock Text="Loading mods…"
											   Foreground="{DynamicResource SecondaryForegroundBrush}"
											   FontSize="13"
											   HorizontalAlignment="Center"/>
								</StackPanel>

								<StackPanel x:Name="ModsEmptyPanel"
										    HorizontalAlignment="Center"
										    Spacing="10"
										    Margin="0,50,0,0"
										    IsVisible="False">
									<TextBlock Text="No mods found"
											   Foreground="{DynamicResource PrimaryForegroundBrush}"
											   FontWeight="SemiBold"
											   FontSize="15"
											   HorizontalAlignment="Center"/>
									<TextBlock Text="Try different search terms"
											   Foreground="{DynamicResource SecondaryForegroundBrush}"
											   FontSize="12"
											   HorizontalAlignment="Center"/>
								</StackPanel>
							</StackPanel>
						</ScrollViewer>

						<!-- Detail panel -->
						<Border x:Name="ModDetailsSidebar"
								Grid.Column="1"
								Background="{DynamicResource TertiaryBackgroundBrush}"
								BorderBrush="{DynamicResource PrimaryBorderBrush}"
								BorderThickness="1,0,0,0"
								CornerRadius="0,18,18,0"
								Padding="20"
								IsVisible="False">
							<Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="12">
								<Border Background="{DynamicResource HoverBackgroundBrush}" CornerRadius="10" Padding="10" HorizontalAlignment="Left">
									<Image x:Name="ModDetailsIcon" Width="56" Height="56" Stretch="Uniform"/>
								</Border>

								<TextBlock x:Name="ModDetailsTitle"
										   Grid.Row="1"
										   Text=""
										   FontWeight="Bold"
										   FontSize="16"
										   TextWrapping="Wrap"
										   Foreground="{DynamicResource PrimaryForegroundBrush}"/>

								<TextBlock x:Name="ModDetailsStats"
										   Grid.Row="2"
										   Text=""
										   FontSize="11"
										   Opacity="0.6"
										   Foreground="{DynamicResource SecondaryForegroundBrush}"/>

								<ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
									<TextBlock x:Name="ModDetailsDescription"
											   Text=""
											   TextWrapping="Wrap"
											   FontSize="12"
											   LineHeight="18"
											   Foreground="{DynamicResource SecondaryForegroundBrush}"/>
								</ScrollViewer>

								<Button x:Name="ModDetailsDownloadButton"
										Grid.Row="4"
										Classes="ColorBtn GlowGreen"
										Content="Download"
										HorizontalAlignment="Stretch"
										Padding="0,11"
										Background="{DynamicResource PrimaryAccentBrush}"
										Foreground="{DynamicResource AccentButtonForegroundBrush}"
										FontWeight="SemiBold"
										CornerRadius="10"
										Click="OnModDetailsDownloadClicked"/>
							</Grid>
						</Border>
					</Grid>

				</Grid>
			</Border>
		</Grid>
		<!-- NEW: Launch Failure Banner -->
		<Border x:Name="LaunchFailureBanner"
                Width="500"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,60,0,0"
                CornerRadius="12"
                Padding="15"
                Background="{DynamicResource ErrorBrush}"
                IsVisible="False"
                Opacity="0"
                ZIndex="1001"
                ClipToBounds="False">
			<Border.RenderTransform>
				<TranslateTransform Y="-100"/>
			</Border.RenderTransform>
			<Border.Transitions>
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseOut"/>
					<DoubleTransition Property="(TranslateTransform.Y)" Duration="0:0:0.5" Easing="CubicEaseOut"/>
				</Transitions>
			</Border.Transitions>
			<Grid ColumnDefinitions="Auto,*,Auto">
				<TextBlock Grid.Column="0" Text="❌" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
				<TextBlock x:Name="LaunchFailureBannerText"
                           Grid.Column="1"
                           Text="Failed to launch Minecraft. Please check logs."
                           Foreground="{DynamicResource AccentButtonForegroundBrush}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
				<Button x:Name="LaunchFailureBannerCloseButton"
                        Grid.Column="2"
                        Content="✕"
                        Background="Transparent"
                        Foreground="{DynamicResource AccentButtonForegroundBrush}"
                        FontSize="14"
                        Width="20" Height="20"
                        Padding="0"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Cursor="Hand"/>
			</Grid>
		</Border>
		<!-- NEW: Game Starting Banner -->
		<Border x:Name="GameStartingBanner"
				Width="500"
			HorizontalAlignment="Center"
			VerticalAlignment="Top"
			Margin="0,60,0,0"
			CornerRadius="12"
			Padding="15"
			Background="#32CD32"
			IsVisible="False"
			Opacity="0"
			ZIndex="1000"
			ClipToBounds="False">
			<Border.RenderTransform>
				<TranslateTransform Y="-100"/>
			</Border.RenderTransform>
			<Border.Transitions>
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseOut"/>
					<DoubleTransition Property="(TranslateTransform.Y)" Duration="0:0:0.5" Easing="CubicEaseOut"/>
				</Transitions>
			</Border.Transitions>
			<Grid ColumnDefinitions="Auto,*,Auto">
				<TextBlock Grid.Column="0" Text="🚀" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
				<TextBlock x:Name="GameStartingBannerText"
						   Grid.Column="1"
						   Text="Minecraft may take a few seconds to appear on your screen"
						   Foreground="{DynamicResource AccentButtonForegroundBrush}"
						   FontWeight="Bold"
						   VerticalAlignment="Center"
						   TextWrapping="Wrap"/>
				<Button x:Name="GameStartingBannerCloseButton"
						Grid.Column="2"
						Content="✕"
						Background="Transparent"
						Foreground="{DynamicResource AccentButtonForegroundBrush}"
						FontSize="14"
						Width="20" Height="20"
						Padding="0"
						Margin="10,0,0,0"
						VerticalAlignment="Center"
						HorizontalContentAlignment="Center"
						VerticalContentAlignment="Center"
						Cursor="Hand"/>
			</Grid>
		</Border>

		<!-- ═══════════════════════════════════════════════════════════════
		     Feedback Overlay (redesigned)
		     Matches the new MainWindow / LoginWindow look: gradient dark
		     card, accent-bar "SEND FEEDBACK" header, pill-tab selector
		     (drives a hidden ComboBox so the existing handler wiring
		     keeps working), gradient-bordered input cards, gradient send
		     button.
		     ═══════════════════════════════════════════════════════════════ -->
		<Grid x:Name="FeedbackOverlay" IsVisible="False" ZIndex="2000">
			<Border x:Name="FeedbackBackdrop" Background="#B0000000" Opacity="0"
					PointerPressed="CloseFeedbackOverlay">
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>
			</Border>

			<Border x:Name="FeedbackPanel"
                    Width="680"
                    MaxHeight="760"
                    CornerRadius="20"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderThickness="1"
                    BorderBrush="#1C2A38"
                    BoxShadow="0 24 60 0 #A0000000"
                    Opacity="0"
                    ClipToBounds="True"
                    RenderTransformOrigin="0.5,0.5">
				<Border.Background>
					<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
						<GradientStop Offset="0" Color="#0F1A24"/>
						<GradientStop Offset="1" Color="#070B12"/>
					</LinearGradientBrush>
				</Border.Background>
				<Border.RenderTransform>
					<ScaleTransform ScaleX="0.92" ScaleY="0.92"/>
				</Border.RenderTransform>
				<Border.Transitions>
					<Transitions>
						<DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut"/>
						<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.32" Easing="CubicEaseOut"/>
					</Transitions>
				</Border.Transitions>

				<Grid RowDefinitions="Auto,*,Auto">
					<!-- Header bar with accent bar + close button -->
					<Border Grid.Row="0" Padding="28,22,18,18" BorderThickness="0,0,0,1" BorderBrush="#152030">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
								<Border Width="3" Height="22" CornerRadius="2" VerticalAlignment="Center">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
											<GradientStop Offset="0" Color="#9333EA"/>
											<GradientStop Offset="1" Color="#6D28D9"/>
										</LinearGradientBrush>
									</Border.Background>
								</Border>
								<StackPanel Spacing="2">
									<TextBlock Text="SEND FEEDBACK"
											   Foreground="#E5E7EB" FontWeight="Black"
											   FontSize="20" LetterSpacing="1.5"/>
									<TextBlock Text="Help shape Leaf Client — every suggestion and bug report counts."
											   Foreground="#6B7280" FontSize="12"/>
								</StackPanel>
							</StackPanel>
							<Border Grid.Column="2" Width="32" Height="32" CornerRadius="10"
									Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1"
									Cursor="Hand" PointerPressed="CloseFeedbackOverlay"
									VerticalAlignment="Center">
								<Path Width="12" Height="12" Stretch="Uniform"
									  Stroke="#9CA3AF" StrokeThickness="2" StrokeLineCap="Round"
									  Data="M4,4 L16,16 M16,4 L4,16"/>
							</Border>
						</Grid>
					</Border>

					<!-- Hidden ComboBox kept as state store so the existing
					     selection-change handler still drives panel visibility. -->
					<ComboBox x:Name="FeedbackTypeComboBox" Grid.Row="0" Width="0" Height="0"
							  IsVisible="False" SelectedIndex="0"
							  SelectionChanged="FeedbackTypeComboBox_SelectionChanged">
						<ComboBoxItem Content="Suggest a Feature" Tag="Feature"/>
						<ComboBoxItem Content="Report a Bug" Tag="Bug"/>
					</ComboBox>

					<!-- Scrollable content -->
					<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,22,28,14">
						<StackPanel Spacing="20">
							<!-- Pill-tab selector (Feature / Bug) -->
							<Border Background="#0C1620" BorderBrush="#152030" BorderThickness="1" CornerRadius="12" Padding="5">
								<Grid ColumnDefinitions="*,*">
									<Border Grid.Column="0" x:Name="FeedbackFeatureTab" Tag="Feature"
											CornerRadius="9" Padding="16,11" Cursor="Hand"
											PointerPressed="OnFeedbackTabTapped"
											HorizontalAlignment="Stretch">
										<Border.Background>
											<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
												<GradientStop Offset="0" Color="#9333EA"/>
												<GradientStop Offset="0.55" Color="#7B2CBF"/>
												<GradientStop Offset="1" Color="#6B21A8"/>
											</LinearGradientBrush>
										</Border.Background>
										<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
											<Path Width="16" Height="16" Stretch="Uniform"
												  Stroke="#FFFFFF" StrokeThickness="1.8"
												  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
												  Data="M12,2 L15,9 L22,10 L17,15 L18,22 L12,19 L6,22 L7,15 L2,10 L9,9 Z"/>
											<TextBlock Text="SUGGEST A FEATURE" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" LetterSpacing="0.8" VerticalAlignment="Center"/>
										</StackPanel>
									</Border>
									<Border Grid.Column="1" x:Name="FeedbackBugTab" Tag="Bug"
											Background="Transparent" CornerRadius="9" Padding="16,11"
											Cursor="Hand" PointerPressed="OnFeedbackTabTapped"
											HorizontalAlignment="Stretch">
										<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
											<Path Width="16" Height="16" Stretch="Uniform"
												  Stroke="#9CA3AF" StrokeThickness="1.8"
												  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
												  Data="M9,4 L9,6 L15,6 L15,4 M8,6 L16,6 C17,6 18,7 18,9 L18,15 C18,18 15,20 12,20 C9,20 6,18 6,15 L6,9 C6,7 7,6 8,6 Z M2,12 L6,12 M18,12 L22,12 M3,6 L6,8 M21,6 L18,8 M3,18 L6,16 M21,18 L18,16"/>
											<TextBlock Text="REPORT A BUG" Foreground="#9CA3AF" FontWeight="Bold" FontSize="12" LetterSpacing="0.8" VerticalAlignment="Center"/>
										</StackPanel>
									</Border>
								</Grid>
							</Border>

							<!-- Feature Suggestion Panel -->
							<StackPanel x:Name="FeatureSuggestionPanel" IsVisible="True" Spacing="12">
								<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
									<Border Width="3" Height="14" CornerRadius="2" VerticalAlignment="Center">
										<Border.Background>
											<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
												<GradientStop Offset="0" Color="#9333EA"/>
												<GradientStop Offset="1" Color="#6D28D9"/>
											</LinearGradientBrush>
										</Border.Background>
									</Border>
									<TextBlock Text="YOUR SUGGESTION" Foreground="#E5E7EB" FontWeight="Black" FontSize="12" LetterSpacing="1.2"/>
								</StackPanel>
								<Border Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="12">
									<TextBox x:Name="SuggestionTextBox"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Height="180"
                                             Watermark="Describe your amazing feature suggestion here... (Max 1000 characters)"
                                             Foreground="#F3F4F6"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="14,12"
                                             FontSize="13"
                                             VerticalContentAlignment="Top"
                                             MaxLength="1000"/>
								</Border>
							</StackPanel>

							<!-- Bug Report Panel -->
							<StackPanel x:Name="BugReportPanel" IsVisible="False" Spacing="16">
								<!-- Expected Behavior Card -->
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
										<Border Width="3" Height="14" CornerRadius="2" VerticalAlignment="Center">
											<Border.Background>
												<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
													<GradientStop Offset="0" Color="#9333EA"/>
													<GradientStop Offset="1" Color="#6D28D9"/>
												</LinearGradientBrush>
											</Border.Background>
										</Border>
										<TextBlock Text="EXPECTED BEHAVIOR" Foreground="#E5E7EB" FontWeight="Black" FontSize="12" LetterSpacing="1.2"/>
									</StackPanel>
									<Border Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="12">
										<TextBox x:Name="ExpectedBehaviorTextBox"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Height="100"
                                                 Watermark="Describe the expected behavior from the client/launcher here. Please be as clear as possible."
                                                 Foreground="#F3F4F6"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="14,12"
                                                 FontSize="13"
                                                 VerticalContentAlignment="Top"/>
									</Border>
								</StackPanel>

								<!-- Actual Behavior Card -->
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
										<Border Width="3" Height="14" CornerRadius="2" VerticalAlignment="Center">
											<Border.Background>
												<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
													<GradientStop Offset="0" Color="#9333EA"/>
													<GradientStop Offset="1" Color="#6D28D9"/>
												</LinearGradientBrush>
											</Border.Background>
										</Border>
										<TextBlock Text="ACTUAL BEHAVIOR (REALITY)" Foreground="#E5E7EB" FontWeight="Black" FontSize="12" LetterSpacing="1.2"/>
									</StackPanel>
									<Border Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="12">
										<TextBox x:Name="ActualBehaviorTextBox"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Height="100"
                                                 Watermark="Describe what actually happens within the client/launcher. Please be as clear as possible."
                                                 Foreground="#F3F4F6"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="14,12"
                                                 FontSize="13"
                                                 VerticalContentAlignment="Top"/>
									</Border>
								</StackPanel>

								<!-- Steps to Reproduce Card -->
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
										<Border Width="3" Height="14" CornerRadius="2" VerticalAlignment="Center">
											<Border.Background>
												<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
													<GradientStop Offset="0" Color="#9333EA"/>
													<GradientStop Offset="1" Color="#6D28D9"/>
												</LinearGradientBrush>
											</Border.Background>
										</Border>
										<TextBlock Text="STEPS TO REPRODUCE" Foreground="#E5E7EB" FontWeight="Black" FontSize="12" LetterSpacing="1.2"/>
									</StackPanel>
									<Border Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="12">
										<TextBox x:Name="StepsToReproduceTextBox"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Height="130"
                                                 Watermark="Describe the steps you took that caused this bug/issue within the client/launcher. Please be as clear as possible."
                                                 Foreground="#F3F4F6"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="14,12"
                                                 FontSize="13"
                                                 VerticalContentAlignment="Top"/>
									</Border>
								</StackPanel>

								<!-- Log File Attachment -->
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
										<Border Width="3" Height="14" CornerRadius="2" VerticalAlignment="Center">
											<Border.Background>
												<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
													<GradientStop Offset="0" Color="#9333EA"/>
													<GradientStop Offset="1" Color="#6D28D9"/>
												</LinearGradientBrush>
											</Border.Background>
										</Border>
										<TextBlock Text="RELEVANT LOG FILE (RECOMMENDED)" Foreground="#E5E7EB" FontWeight="Black" FontSize="12" LetterSpacing="1.2"/>
									</StackPanel>
									<Border Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="12" Padding="14,12">
										<Grid ColumnDefinitions="Auto,*">
											<Button x:Name="AttachLogButton" Grid.Column="0"
                                                    Click="AttachLogButton_Click"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    Cursor="Hand"
                                                    Margin="0,0,14,0">
												<Border CornerRadius="9" Padding="14,9">
													<Border.Background>
														<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
															<GradientStop Offset="0" Color="#9333EA"/>
															<GradientStop Offset="0.55" Color="#7B2CBF"/>
															<GradientStop Offset="1" Color="#6B21A8"/>
														</LinearGradientBrush>
													</Border.Background>
													<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
														<Path Width="14" Height="14" Stretch="Uniform"
															  Stroke="#FFFFFF" StrokeThickness="1.8"
															  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
															  Data="M14,3 L14,7 L18,7 M6,3 L14,3 L18,7 L18,21 L6,21 Z M9,14 L15,14 M9,17 L13,17"/>
														<TextBlock Text="ATTACH LATEST LOG" FontSize="11" FontWeight="Bold" Foreground="White" LetterSpacing="0.8" VerticalAlignment="Center"/>
													</StackPanel>
												</Border>
											</Button>
											<TextBlock x:Name="AttachedLogFileName" Grid.Column="1"
                                                       Text="No file attached"
                                                       VerticalAlignment="Center"
                                                       Foreground="#9CA3AF"
                                                       FontSize="12"/>
										</Grid>
									</Border>
								</StackPanel>

								<!-- Additional Information Card -->
								<StackPanel Spacing="10">
									<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
										<Border Width="3" Height="14" CornerRadius="2" VerticalAlignment="Center">
											<Border.Background>
												<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
													<GradientStop Offset="0" Color="#9333EA"/>
													<GradientStop Offset="1" Color="#6D28D9"/>
												</LinearGradientBrush>
											</Border.Background>
										</Border>
										<TextBlock Text="ENVIRONMENT INFO" Foreground="#E5E7EB" FontWeight="Black" FontSize="12" LetterSpacing="1.2"/>
									</StackPanel>
									<Border Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1" CornerRadius="12" Padding="16,14">
										<StackPanel Spacing="10">
											<TextBlock Text="Operating system &amp; version" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" LetterSpacing="0.5"/>
											<TextBox x:Name="OsVersionTextBox"
                                                     IsReadOnly="True"
                                                     Foreground="#F3F4F6"
                                                     Background="#12202E"
                                                     BorderBrush="#1C2A38"
                                                     BorderThickness="1"
                                                     Padding="12,8"
                                                     FontSize="12"
                                                     CornerRadius="8"/>

											<TextBlock Text="Leaf Client version" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" LetterSpacing="0.5" Margin="0,4,0,0"/>
											<TextBox x:Name="LeafClientVersionTextBox"
                                                     IsReadOnly="True"
                                                     Foreground="#F3F4F6"
                                                     Background="#12202E"
                                                     BorderBrush="#1C2A38"
                                                     BorderThickness="1"
                                                     Padding="12,8"
                                                     FontSize="12"
                                                     CornerRadius="8"/>
										</StackPanel>
									</Border>
								</StackPanel>
							</StackPanel>

							<!-- Status Message -->
							<TextBlock x:Name="StatusMessageTextBlock"
                                       Foreground="#C4B5FD"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>
						</StackPanel>
					</ScrollViewer>

					<!-- Footer action bar -->
					<Border Grid.Row="2" Padding="28,18,28,22" BorderThickness="0,1,0,0" BorderBrush="#152030">
						<Grid ColumnDefinitions="*,Auto">
							<!-- Cancel button -->
							<Button Grid.Column="0"
									Click="CancelFeedbackButton_Click"
									Background="Transparent"
									BorderThickness="0"
									Padding="0"
									Cursor="Hand"
									HorizontalAlignment="Left">
								<Border CornerRadius="10" Padding="18,11"
										Background="#0C1620" BorderBrush="#1C2A38" BorderThickness="1">
									<TextBlock Text="CANCEL" Foreground="#9CA3AF" FontWeight="Bold" FontSize="12" LetterSpacing="1"/>
								</Border>
							</Button>
							<!-- Send button -->
							<Button Grid.Column="1"
									Click="SendFeedbackButton_Click"
									Background="Transparent"
									BorderThickness="0"
									Padding="0"
									Cursor="Hand"
									HorizontalAlignment="Right">
								<Border CornerRadius="10" Padding="24,12"
										BoxShadow="0 6 18 0 #6A7B2CBF">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
											<GradientStop Offset="0" Color="#9333EA"/>
											<GradientStop Offset="0.55" Color="#7B2CBF"/>
											<GradientStop Offset="1" Color="#6B21A8"/>
										</LinearGradientBrush>
									</Border.Background>
									<StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
										<Path Width="14" Height="14" Stretch="Uniform"
											  Stroke="#FFFFFF" StrokeThickness="1.9"
											  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
											  Data="M3,12 L21,3 L14,21 L12,13 Z"/>
										<TextBlock Text="SEND FEEDBACK" FontSize="12" FontWeight="Bold" Foreground="White" LetterSpacing="1" VerticalAlignment="Center"/>
									</StackPanel>
								</Border>
							</Button>
						</Grid>
					</Border>
				</Grid>
			</Border>
		</Grid>
		<!-- Planned Updates Mini-Window Overlay -->
		<Grid x:Name="PlannedUpdatesOverlay" IsVisible="False" ZIndex="2002" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,60,70">
			<Border x:Name="PlannedUpdatesPanel"
					Width="260" Height="320"
					Background="{DynamicResource CardBackgroundColor}"
					CornerRadius="12"
					Padding="20"
					BoxShadow="0 4 20 0 #66000000"
					Opacity="0"
					PointerExited="ClosePlannedUpdates">
				<Border.RenderTransform>
					<TranslateTransform Y="20"/>
				</Border.RenderTransform>

				<Border.Effect>
					<BlurEffect Radius="10"/>
				</Border.Effect>

				<Grid RowDefinitions="Auto,*">
					<!-- Header -->
					<StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,15">
						<TextBlock Text="PLANNED FUTURE UPDATES" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="ExtraBold" FontSize="14"/>
						<Rectangle Height="2" Width="30" HorizontalAlignment="Left" Fill="{DynamicResource PrimaryAccentBrush}" RadiusX="1" RadiusY="1"/>
					</StackPanel>

					<!-- Content -->
					<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
						<StackPanel Spacing="12">
							<TextBlock Text="• Custom Replay Mod &amp; Browser" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="13" TextWrapping="Wrap"/>
							<TextBlock Text="• In-game Store" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="13" TextWrapping="Wrap"/>
							<TextBlock Text="• Cosmetics Editor" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="13" TextWrapping="Wrap"/>
							<TextBlock Text="• PvP Mod Features" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="13" TextWrapping="Wrap"/>
							<TextBlock Text="• Forge Support" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="13" TextWrapping="Wrap"/>
							<TextBlock Text="• Chroma HUD Support" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="13" TextWrapping="Wrap"/>
							<TextBlock Text="• Friend System Integration" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="13" TextWrapping="Wrap"/>
						</StackPanel>
					</ScrollViewer>
				</Grid>
			</Border>
		</Grid>

		<!-- Crash Report Overlay (ZIndex 3000 — above FeedbackOverlay) -->
		<Grid x:Name="CrashReportOverlay" IsVisible="False" ZIndex="3000">
			<Border Background="#A0000000" />

			<Border x:Name="CrashReportPanel"
                    Width="520"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource SecondaryBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="40,36"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 12 50 8 #50000000">

				<Border.RenderTransform>
					<TranslateTransform Y="-700" />
				</Border.RenderTransform>

				<StackPanel Spacing="20">
					<!-- Icon + Title -->
					<StackPanel Spacing="10" HorizontalAlignment="Center">
						<TextBlock Text="🐛"
                                   FontSize="48"
                                   HorizontalAlignment="Center" />
						<TextBlock Text="We caught a bug"
                                   Foreground="{DynamicResource PrimaryForegroundBrush}"
                                   FontSize="24"
                                   FontWeight="ExtraBold"
                                   HorizontalAlignment="Center" />
					</StackPanel>

					<!-- Description -->
					<StackPanel Spacing="8">
						<TextBlock x:Name="CrashScreenshotLine"
                                   Text="A screenshot was taken when this happened."
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
						<TextBlock Text="Sending a report helps us fix issues faster. No personal data is included."
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Opacity="0.7" />
					</StackPanel>

					<!-- Status line (shown after sending) -->
					<TextBlock x:Name="CrashStatusLine"
                               Text=""
                               Foreground="{DynamicResource PrimaryAccentBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               IsVisible="False" />

					<!-- Primary buttons -->
					<Grid ColumnDefinitions="*,12,*" Margin="0,8,0,0">
						<Button x:Name="CrashSendButton"
                                Grid.Column="0"
                                Content="Send Report"
                                Background="{DynamicResource PrimaryAccentBrush}"
                                Foreground="{DynamicResource AccentButtonForegroundBrush}"
                                BorderThickness="0"
                                CornerRadius="10"
                                Padding="0,12"
                                MinHeight="44"
                                FontWeight="Bold"
                                FontSize="14"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Classes="ColorBtn LiftBtn GlowAccent"
                                Click="CrashSendButton_Click" />
						<Button x:Name="CrashDismissButton"
                                Grid.Column="2"
                                Content="Dismiss"
                                Background="{DynamicResource TertiaryBackgroundBrush}"
                                Foreground="{DynamicResource PrimaryForegroundBrush}"
                                BorderThickness="0"
                                CornerRadius="10"
                                Padding="0,12"
                                MinHeight="44"
                                FontWeight="SemiBold"
                                FontSize="14"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Classes="LiftBtn"
                                Click="CrashDismissButton_Click" />
					</Grid>

					<!-- Fallback actions — only shown after a failed send, and
					     only when a local copy of the report was successfully
					     written to %APPDATA%\LeafClient\CrashReports. -->
					<Grid ColumnDefinitions="*,10,*" Margin="0,2,0,0">
						<Button x:Name="CrashCopyButton"
                                Grid.Column="0"
                                IsVisible="False"
                                Background="#0C1620"
                                BorderBrush="#1C2A38"
                                BorderThickness="1"
                                Foreground="#C4B5FD"
                                CornerRadius="10"
                                Padding="0,11"
                                MinHeight="42"
                                FontWeight="Bold"
                                FontSize="12"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Cursor="Hand"
                                Click="CrashCopyButton_Click">
							<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
								<Path Width="14" Height="14" Stretch="Uniform"
									  Stroke="#C4B5FD" StrokeThickness="1.8"
									  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
									  Data="M8,4 L18,4 L18,18 L8,18 Z M4,8 L4,22 L14,22"/>
								<TextBlock Text="COPY JSON" LetterSpacing="0.8" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
						<Button x:Name="CrashOpenFolderButton"
                                Grid.Column="2"
                                IsVisible="False"
                                Background="#0C1620"
                                BorderBrush="#1C2A38"
                                BorderThickness="1"
                                Foreground="#C4B5FD"
                                CornerRadius="10"
                                Padding="0,11"
                                MinHeight="42"
                                FontWeight="Bold"
                                FontSize="12"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Cursor="Hand"
                                Click="CrashOpenFolderButton_Click">
							<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
								<Path Width="14" Height="14" Stretch="Uniform"
									  Stroke="#C4B5FD" StrokeThickness="1.8"
									  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
									  Data="M3,8 L3,18 L21,18 L21,10 L12,10 L10,8 Z"/>
								<TextBlock Text="OPEN FOLDER" LetterSpacing="0.8" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
					</Grid>
				</StackPanel>
			</Border>
		</Grid>

		<!-- ============================================================ -->
		<!-- PROFESSIONAL CINEMATIC STARTUP                               -->
		<!-- ============================================================ -->
		<Grid x:Name="StartupOverlay"
			  IsVisible="True"
			  ZIndex="99999"
			  Background="Black">

			<Image x:Name="StartupBg"
				   Source="/Assets/bg.jpg"
				   Stretch="UniformToFill"
				   Opacity="0"
				   RenderTransformOrigin="50%,50%"
				   RenderOptions.BitmapInterpolationMode="HighQuality">
				<Image.Effect>
					<BlurEffect Radius="20"/>
				</Image.Effect>
				<Image.RenderTransform>
					<ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
				</Image.RenderTransform>
			</Image>

			<Rectangle Fill="Black" Opacity="0.4"/>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0"
						RenderTransformOrigin="50%,50%">
				<!-- Leaf icon -->
				<Image x:Name="StartupLogo"
					   Source="/Assets/LeafRebrandedTransparent.png"
					   Width="90" Height="90"
					   Opacity="0"
					   Stretch="Uniform"
					   VerticalAlignment="Center"
					   Margin="0,0,-44,0"
					   RenderTransformOrigin="50%,50%"
					   RenderOptions.BitmapInterpolationMode="HighQuality">
					<Image.Effect>
						<DropShadowEffect Color="#CC000000" BlurRadius="20" OffsetX="0" OffsetY="4" Opacity="0.7"/>
					</Image.Effect>
				</Image>
				<!-- LEAF CLIENT text -->
				<Image x:Name="StartupLogoText"
					   Source="/Assets/logo_text.png"
					   Width="210" Height="55"
					   Opacity="0"
					   Stretch="Uniform"
					   VerticalAlignment="Center"
					   RenderTransformOrigin="50%,50%"
					   RenderOptions.BitmapInterpolationMode="HighQuality">
					<Image.Effect>
						<DropShadowEffect Color="#CC000000" BlurRadius="20" OffsetX="0" OffsetY="4" Opacity="0.7"/>
					</Image.Effect>
				</Image>
			</StackPanel>
		</Grid>
		<!-- ══════════════════════════════════════════════════════
		     UPDATE CHECKING OVERLAY — glass-card style, fades in
		     with scrim, card springs in, spinner rotates smoothly.
		══════════════════════════════════════════════════════ -->
		<Grid x:Name="UpdateCheckOverlay" IsVisible="False" ZIndex="99999" Opacity="0">
			<Grid.Transitions>
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut"/>
				</Transitions>
			</Grid.Transitions>

			<!-- Scrim: glass-tinted dark wash, same family as the rest of the UI -->
			<Border Background="#BB060C14"/>

			<!-- Glass card -->
			<Border x:Name="UpdateCheckCard" Width="320"
					HorizontalAlignment="Center" VerticalAlignment="Center"
					CornerRadius="20" Padding="36,32,36,32"
					Background="#CC060C14" BorderBrush="#30FFFFFF" BorderThickness="1"
					RenderTransformOrigin="0.5,0.5" RenderTransform="scale(0.94)">
				<Border.BoxShadow>
					0 20 60 0 #554CAF50, 0 10 32 0 #60000000
				</Border.BoxShadow>
				<Border.Transitions>
					<Transitions>
						<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.40">
							<TransformOperationsTransition.Easing>
								<BackEaseOut/>
							</TransformOperationsTransition.Easing>
						</TransformOperationsTransition>
					</Transitions>
				</Border.Transitions>

				<StackPanel HorizontalAlignment="Center" Spacing="22">
					<!-- Spinner: 12 stationary dots with chasing opacity.
					     No rotation transform at all — the dots don't move;
					     C# animates their opacity in a "trail" around the ring.
					     Positions are precomputed for a 72x72 box with dots of
					     size 6, orbit radius 30, centered at (36,36). -->
					<Canvas x:Name="UpdateSpinner" Width="72" Height="72"
							HorizontalAlignment="Center" VerticalAlignment="Center">
						<Canvas.Effect>
							<DropShadowEffect Color="#5CCF6B" BlurRadius="20" OffsetX="0" OffsetY="0" Opacity="0.55"/>
						</Canvas.Effect>
						<Ellipse Canvas.Left="33"    Canvas.Top="3"     Width="6" Height="6" Fill="#7CE38A" Opacity="1.0"/>
						<Ellipse Canvas.Left="48"    Canvas.Top="7.02"  Width="6" Height="6" Fill="#7CE38A" Opacity="0.85"/>
						<Ellipse Canvas.Left="58.98" Canvas.Top="18"    Width="6" Height="6" Fill="#7CE38A" Opacity="0.7"/>
						<Ellipse Canvas.Left="63"    Canvas.Top="33"    Width="6" Height="6" Fill="#7CE38A" Opacity="0.58"/>
						<Ellipse Canvas.Left="58.98" Canvas.Top="48"    Width="6" Height="6" Fill="#7CE38A" Opacity="0.48"/>
						<Ellipse Canvas.Left="48"    Canvas.Top="58.98" Width="6" Height="6" Fill="#7CE38A" Opacity="0.4"/>
						<Ellipse Canvas.Left="33"    Canvas.Top="63"    Width="6" Height="6" Fill="#7CE38A" Opacity="0.32"/>
						<Ellipse Canvas.Left="18"    Canvas.Top="58.98" Width="6" Height="6" Fill="#7CE38A" Opacity="0.26"/>
						<Ellipse Canvas.Left="7.02"  Canvas.Top="48"    Width="6" Height="6" Fill="#7CE38A" Opacity="0.22"/>
						<Ellipse Canvas.Left="3"     Canvas.Top="33"    Width="6" Height="6" Fill="#7CE38A" Opacity="0.18"/>
						<Ellipse Canvas.Left="7.02"  Canvas.Top="18"    Width="6" Height="6" Fill="#7CE38A" Opacity="0.16"/>
						<Ellipse Canvas.Left="18"    Canvas.Top="7.02"  Width="6" Height="6" Fill="#7CE38A" Opacity="0.16"/>
					</Canvas>

					<StackPanel Spacing="4" HorizontalAlignment="Center">
						<TextBlock Text="Checking for updates"
								   Foreground="#F0FFFFFF"
								   FontWeight="SemiBold"
								   FontSize="15"
								   LetterSpacing="0.4"
								   HorizontalAlignment="Center"/>
						<TextBlock Text="Hold tight — this only takes a moment"
								   Foreground="#80FFFFFF"
								   FontSize="11"
								   HorizontalAlignment="Center"/>
					</StackPanel>
				</StackPanel>
			</Border>
		</Grid>

	<!-- ══════════════════════════════════════════════════════
	     UPDATE DOWNLOAD OVERLAY — mandatory, no dismiss.
	     Same glass aesthetic, animated progress bar.
	══════════════════════════════════════════════════════ -->
	<Grid x:Name="UpdateDownloadOverlay" IsVisible="False" ZIndex="100000" Opacity="0">
		<Grid.Transitions>
			<Transitions>
				<DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut"/>
			</Transitions>
		</Grid.Transitions>

		<!-- Scrim: slightly darker than the checking overlay so the card reads -->
		<Border Background="#C8060C14"/>

		<!-- Glass card -->
		<Border x:Name="UpdateDownloadCard" Width="380"
				HorizontalAlignment="Center" VerticalAlignment="Center"
				CornerRadius="20" Padding="36,34,36,30"
				Background="#CC060C14" BorderBrush="#30FFFFFF" BorderThickness="1"
				RenderTransformOrigin="0.5,0.5" RenderTransform="scale(0.94)">
			<Border.BoxShadow>
				0 20 60 0 #554CAF50, 0 10 32 0 #60000000
			</Border.BoxShadow>
			<Border.Transitions>
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.40">
						<TransformOperationsTransition.Easing>
							<BackEaseOut/>
						</TransformOperationsTransition.Easing>
					</TransformOperationsTransition>
				</Transitions>
			</Border.Transitions>

			<StackPanel Spacing="16">
				<!-- Leaf logo with matching green glow -->
				<Image Source="/Assets/LeafRebrandedTransparent.png"
					   Width="64" Height="64" Stretch="Uniform" HorizontalAlignment="Center">
					<Image.Effect>
						<DropShadowEffect Color="#5CCF6B" BlurRadius="28" OffsetX="0" OffsetY="0" Opacity="0.55"/>
					</Image.Effect>
				</Image>

				<StackPanel Spacing="3">
					<TextBlock x:Name="UpdateOverlayTitle" Text="Updating Leaf Client"
							   Foreground="#F0FFFFFF" FontWeight="SemiBold" FontSize="17"
							   LetterSpacing="0.3" HorizontalAlignment="Center"/>
					<TextBlock x:Name="UpdateOverlayVersion" Text="Downloading v2.0"
							   Foreground="#80FFFFFF" FontSize="12" HorizontalAlignment="Center"/>
				</StackPanel>

				<!-- Progress bar: animated Width via DoubleTransition -->
				<Grid Height="8" Margin="0,8,0,0">
					<Border Background="#1EFFFFFF" CornerRadius="4"/>
					<Border x:Name="UpdateProgressBar" CornerRadius="4"
							HorizontalAlignment="Left" Width="0">
						<Border.Background>
							<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
								<GradientStop Color="#7CE38A" Offset="0"/>
								<GradientStop Color="#2E8B4A" Offset="1"/>
							</LinearGradientBrush>
						</Border.Background>
						<Border.Effect>
							<DropShadowEffect Color="#5CCF6B" BlurRadius="16" OffsetX="0" OffsetY="0" Opacity="0.65"/>
						</Border.Effect>
						<Border.Transitions>
							<Transitions>
								<DoubleTransition Property="Width" Duration="0:0:0.35" Easing="CubicEaseOut"/>
							</Transitions>
						</Border.Transitions>
					</Border>
				</Grid>

				<!-- Status + percentage on one row so the card stays compact -->
				<Grid Margin="0,2,0,0" ColumnDefinitions="*,Auto">
					<TextBlock Grid.Column="0" x:Name="UpdateDlStatusLabel" Text="Please wait..."
							   Foreground="#80FFFFFF" FontSize="11" VerticalAlignment="Center"/>
					<TextBlock Grid.Column="1" x:Name="UpdateProgressText" Text="0%"
							   Foreground="#F0FFFFFF" FontSize="13" FontWeight="SemiBold"
							   VerticalAlignment="Center"/>
				</Grid>
			</StackPanel>
		</Border>
	</Grid>

	<!-- ══════════════════════════════════════════════════════
	     PROFILE EDITOR OVERLAY  (ZIndex 999)
	══════════════════════════════════════════════════════ -->
	<Grid x:Name="ProfileEditorOverlay" IsVisible="False" ZIndex="999">

		<!-- Dimmed backdrop -->
		<Border Background="#AA000000"/>

		<!-- Dialog card — new side-nav layout -->
		<Border x:Name="ProfileEditorCard"
				Width="720" MinHeight="560" MaxHeight="900"
				VerticalAlignment="Center" HorizontalAlignment="Center"
				CornerRadius="18" ClipToBounds="True"
				BorderBrush="#162030" BorderThickness="1"
				BoxShadow="0 40 120 0 #70000000">
			<Border.Background>
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
					<GradientStop Offset="0" Color="#0D1520"/>
					<GradientStop Offset="0.5" Color="#0A1018"/>
					<GradientStop Offset="1" Color="#080C14"/>
				</LinearGradientBrush>
			</Border.Background>
			<Border.Transitions>
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut"/>
				</Transitions>
			</Border.Transitions>

			<Grid RowDefinitions="Auto,*,Auto">

				<!-- ══ HEADER ══ -->
				<Border Grid.Row="0" Padding="20,14,16,12"
						BorderBrush="#12FFFFFF" BorderThickness="0,0,0,1">
					<Grid ColumnDefinitions="Auto,Auto,*,Auto">
						<Border Width="3" Height="18" CornerRadius="2" Margin="0,0,14,0"
								VerticalAlignment="Center">
							<Border.Background>
								<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
									<GradientStop Offset="0" Color="#9333EA"/>
									<GradientStop Offset="1" Color="#6D28D9"/>
								</LinearGradientBrush>
							</Border.Background>
						</Border>
						<TextBlock Grid.Column="1" x:Name="PO_TitleText" Text="New Profile"
								   FontWeight="Bold" FontSize="15" VerticalAlignment="Center"
								   Foreground="#E5E7EB" LetterSpacing="0.3"/>
						<Button Grid.Column="3" Click="OnProfileOverlayClose"
								Width="32" Height="32" CornerRadius="10" Padding="0"
								Background="Transparent" BorderThickness="0" Cursor="Hand">
							<Button.Styles>
								<Style Selector="Button:pointerover /template/ ContentPresenter">
									<Setter Property="Background" Value="#30EF4444"/>
								</Style>
								<Style Selector="Button /template/ ContentPresenter">
									<Setter Property="Transitions">
										<Transitions>
											<BrushTransition Property="Background" Duration="0:0:0.15"/>
										</Transitions>
									</Setter>
								</Style>
							</Button.Styles>
							<TextBlock Text="✕" FontSize="12" FontWeight="SemiBold"
									   HorizontalAlignment="Center" VerticalAlignment="Center"
									   Foreground="#6B7280"/>
						</Button>
					</Grid>
				</Border>

				<!-- ══ CONTENT: Side Nav + Main ══ -->
				<Grid Grid.Row="1" ColumnDefinitions="82,Auto,*">

					<!-- ── Left: Side Navigation ── -->
					<Border Grid.Column="0" Padding="12,16,6,16">
						<StackPanel Spacing="20">
							<!-- Profile Avatar -->
							<Border Width="52" Height="52" CornerRadius="26"
									HorizontalAlignment="Center" Margin="0,2,0,6">
								<Border.Background>
									<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
										<GradientStop Offset="0" Color="#9333EA"/>
										<GradientStop Offset="1" Color="#6D28D9"/>
									</LinearGradientBrush>
								</Border.Background>
								<Border Width="46" Height="46" CornerRadius="23"
										Background="#0A1018"
										HorizontalAlignment="Center" VerticalAlignment="Center">
									<TextBlock x:Name="PO_AvatarLetter" Text="N"
											   FontSize="20" FontWeight="ExtraBold"
											   Foreground="#B080FF"
											   HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
							</Border>

							<!-- Nav Buttons + sliding indicator -->
							<Grid HorizontalAlignment="Center">
								<Border x:Name="PO_NavIndicator" Width="58" Height="54"
										CornerRadius="14" Background="#0FFFFFFF"
										HorizontalAlignment="Center" VerticalAlignment="Top"
										IsHitTestVisible="False">
									<Border.Transitions>
										<Transitions>
											<ThicknessTransition Property="Margin" Duration="0:0:0.28" Easing="CubicEaseOut"/>
										</Transitions>
									</Border.Transitions>
								</Border>
								<Border x:Name="PO_NavActiveBar" Width="3" Height="24"
										CornerRadius="2" HorizontalAlignment="Left"
										VerticalAlignment="Top" Margin="-2,15,0,0"
										IsHitTestVisible="False">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
											<GradientStop Offset="0" Color="#9333EA"/>
											<GradientStop Offset="1" Color="#6D28D9"/>
										</LinearGradientBrush>
									</Border.Background>
									<Border.Transitions>
										<Transitions>
											<ThicknessTransition Property="Margin" Duration="0:0:0.28" Easing="CubicEaseOut"/>
										</Transitions>
									</Border.Transitions>
								</Border>
								<StackPanel Spacing="8">
									<Button x:Name="PO_NavBtnGeneral" Classes="PONav PONavActive"
											Click="OnProfileOverlayTabClick" Tag="0" ToolTip.Tip="General">
										<StackPanel Spacing="3" HorizontalAlignment="Center">
											<!-- User / identity icon -->
											<Path Width="18" Height="18" Stretch="Uniform" Fill="#9CA3AF"
												  HorizontalAlignment="Center"
												  Data="M12,12 C14.2,12 16,10.2 16,8 C16,5.8 14.2,4 12,4 C9.8,4 8,5.8 8,8 C8,10.2 9.8,12 12,12 Z M12,14 C9.3,14 4,15.3 4,18 L4,20 L20,20 L20,18 C20,15.3 14.7,14 12,14 Z"/>
											<TextBlock Text="General" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button x:Name="PO_NavBtnPerformance" Classes="PONav"
											Click="OnProfileOverlayTabClick" Tag="1" ToolTip.Tip="Performance">
										<StackPanel Spacing="3" HorizontalAlignment="Center">
											<!-- Lightning bolt -->
											<Path Width="18" Height="18" Stretch="Uniform" Fill="#9CA3AF"
												  HorizontalAlignment="Center"
												  Data="M13,2 L3,14 L11,14 L11,22 L21,10 L13,10 Z"/>
											<TextBlock Text="Perf" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button x:Name="PO_NavBtnMods" Classes="PONav"
											Click="OnProfileOverlayTabClick" Tag="2" ToolTip.Tip="Mod Presets">
										<StackPanel Spacing="3" HorizontalAlignment="Center">
											<!-- Cube / package -->
											<Path Width="18" Height="18" Stretch="Uniform" Fill="#9CA3AF"
												  HorizontalAlignment="Center"
												  Data="M12,2 L3,7 L3,17 L12,22 L21,17 L21,7 Z M12,2 L12,12 M3,7 L12,12 M21,7 L12,12"/>
											<TextBlock Text="Mods" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button x:Name="PO_NavBtnAdvanced" Classes="PONav"
											Click="OnProfileOverlayTabClick" Tag="3" ToolTip.Tip="Advanced Overrides">
										<StackPanel Spacing="3" HorizontalAlignment="Center">
											<!-- Sliders / tuning -->
											<Path Width="18" Height="18" Stretch="Uniform" Fill="#9CA3AF"
												  HorizontalAlignment="Center"
												  Data="M4,6 L14,6 M18,6 L20,6 M16,6 C16,7.1 15.1,8 14,8 C12.9,8 12,7.1 12,6 C12,4.9 12.9,4 14,4 C15.1,4 16,4.9 16,6 Z M4,12 L6,12 M10,12 L20,12 M8,12 C8,13.1 7.1,14 6,14 C4.9,14 4,13.1 4,12 C4,10.9 4.9,10 6,10 C7.1,10 8,10.9 8,12 Z M4,18 L14,18 M18,18 L20,18 M16,18 C16,19.1 15.1,20 14,20 C12.9,20 12,19.1 12,18 C12,16.9 12.9,16 14,16 C15.1,16 16,16.9 16,18 Z"/>
											<TextBlock Text="Adv" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
										</StackPanel>
									</Button>
								</StackPanel>
							</Grid>
						</StackPanel>
					</Border>

					<!-- Vertical divider -->
					<Border Grid.Column="1" Width="1" Background="#12FFFFFF" Margin="0,16,0,16"/>

					<!-- ── Right: Main Content ── -->
					<ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="24,16,24,48">
						<Grid>
							<!-- TAB 0: General -->
							<StackPanel x:Name="PO_TabIdentity" Classes="POTabContent" Spacing="16" Opacity="1">
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="12">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x270F;&#xFE0F;" FontSize="12"/>
											<TextBlock Text="PROFILE NAME" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
										</StackPanel>
										<TextBox x:Name="PO_NameBox" Watermark="e.g. Survival, Creative, PvP..."
												 Background="#0F1A24" Foreground="White" CornerRadius="12" Padding="16,14" FontSize="14"
												 BorderBrush="#1C2A38" BorderThickness="1.5"
												 TextChanged="OnPO_NameChanged">
											<TextBox.Styles>
												<Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
													<Setter Property="BorderBrush" Value="#9333EA"/>
													<Setter Property="BorderThickness" Value="1.5"/>
													<Setter Property="Background" Value="#0F1A24"/>
												</Style>
												<Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
													<Setter Property="BorderBrush" Value="#2A3F52"/>
													<Setter Property="Background" Value="#0F1A24"/>
												</Style>
											</TextBox.Styles>
										</TextBox>
										<TextBlock Text="Letters, numbers, underscores and dashes only" FontSize="11" Foreground="#4B5563"/>
									</StackPanel>
								</Border>
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="12">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x1F464;" FontSize="12"/>
											<TextBlock Text="ACCOUNT" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
										</StackPanel>
										<ComboBox x:Name="PO_AccountCombo" HorizontalAlignment="Stretch"
												  Background="#0F1A24" Foreground="White" Padding="14,12" SelectedIndex="0">
											<!-- Populated dynamically from SavedAccounts -->
										</ComboBox>
									</StackPanel>
								</Border>
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="12">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x1F4E6;" FontSize="12"/>
											<TextBlock Text="MINECRAFT VERSION" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
										</StackPanel>
										<ComboBox x:Name="PO_VersionCombo" HorizontalAlignment="Stretch"
												  Background="#0F1A24" Foreground="White" Padding="14,12"
												  SelectionChanged="OnPO_VersionChanged"/>
										<CheckBox x:Name="PO_ShowAllVersions" Content="Show unsupported versions"
												  Foreground="#6B7280" FontSize="12" Click="OnPO_ShowAllVersionsToggle"/>
										<Border x:Name="PO_SupportBanner" CornerRadius="12" Padding="14,10" IsVisible="False" Background="#0B1E0F">
											<Border.Transitions>
												<Transitions><BrushTransition Property="Background" Duration="0:0:0.3"/></Transitions>
											</Border.Transitions>
											<Grid ColumnDefinitions="Auto,*">
												<Border CornerRadius="20" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,12,0" HorizontalAlignment="Center">
													<Ellipse x:Name="PO_SupportDot" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
												</Border>
												<StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
													<TextBlock x:Name="PO_SupportTitle" FontWeight="Bold" FontSize="13"/>
													<TextBlock x:Name="PO_SupportSub" FontSize="11" TextWrapping="Wrap" Opacity="0.8" Foreground="#6B7280"/>
												</StackPanel>
											</Grid>
										</Border>
									</StackPanel>
								</Border>
							</StackPanel>

							<!-- TAB 1: Performance -->
							<StackPanel x:Name="PO_TabPerformance" Classes="POTabContent" IsVisible="False" Spacing="16" Opacity="0">
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="12">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x2615;" FontSize="12"/>
											<TextBlock Text="JAVA RUNTIME" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
										</StackPanel>
										<ComboBox x:Name="PO_JavaCombo" HorizontalAlignment="Stretch"
												  Background="#0F1A24" Foreground="White" Padding="14,12" SelectedIndex="0">
											<ComboBoxItem Content="Bundled Java 21.0.9  (Recommended)" Tag="bundled"/>
											<ComboBoxItem Content="System Java  —  Use installed JDK" Tag="system"/>
										</ComboBox>
										<Border x:Name="PO_JavaBanner" Background="#150D25" CornerRadius="12" Padding="14,10">
											<StackPanel Orientation="Horizontal" Spacing="10">
												<TextBlock Text="&#x2713;" Foreground="#B080FF" FontWeight="Bold" FontSize="13"/>
												<TextBlock x:Name="PO_JavaBannerText"
														   Text="Java 21 — compatible with your selected version"
														   Foreground="#B080FF" FontSize="12" VerticalAlignment="Center"/>
											</StackPanel>
										</Border>
									</StackPanel>
								</Border>
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="14">
										<Grid ColumnDefinitions="*,Auto">
											<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
												<TextBlock Text="&#x1F4BE;" FontSize="12"/>
												<TextBlock Text="ALLOCATED MEMORY" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
											</StackPanel>
											<Border Grid.Column="1" CornerRadius="10" Padding="14,6">
												<Border.Background>
													<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
														<GradientStop Offset="0" Color="#7C3AED"/>
														<GradientStop Offset="1" Color="#5B21B6"/>
													</LinearGradientBrush>
												</Border.Background>
												<TextBlock x:Name="PO_MemLabel" Text="3.0 GB" FontSize="13" FontWeight="Bold" Foreground="White"/>
											</Border>
										</Grid>
										<Slider x:Name="PO_MemSlider" Minimum="1" Maximum="8" Value="3"
												TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="OnPO_MemoryChanged"/>
										<Grid ColumnDefinitions="*,*,*">
											<TextBlock Grid.Column="0" Text="1 GB" FontSize="10" Foreground="#4B5563" HorizontalAlignment="Left"/>
											<TextBlock Grid.Column="1" Text="4 GB" FontSize="10" Foreground="#4B5563" HorizontalAlignment="Center"/>
											<TextBlock Grid.Column="2" Text="8 GB" FontSize="10" Foreground="#4B5563" HorizontalAlignment="Right"/>
										</Grid>
									</StackPanel>
								</Border>
								<Border CornerRadius="14" Padding="18" BorderThickness="1">
									<Border.Background>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
											<GradientStop Offset="0" Color="#110B1E"/>
											<GradientStop Offset="1" Color="#0B141C"/>
										</LinearGradientBrush>
									</Border.Background>
									<Border.BorderBrush>
										<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
											<GradientStop Offset="0" Color="#2A1845"/>
											<GradientStop Offset="1" Color="#152535"/>
										</LinearGradientBrush>
									</Border.BorderBrush>
									<StackPanel Spacing="8">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="&#x1F4A1;" FontSize="14"/>
											<TextBlock Text="Performance Tip" FontWeight="Bold" FontSize="13" Foreground="#D1D5DB" VerticalAlignment="Center"/>
										</StackPanel>
										<TextBlock Text="4–6 GB is ideal for most setups. Too much RAM can reduce performance. Enable mods like Sodium on the Mods tab for bigger gains."
												   FontSize="12" TextWrapping="Wrap" LineHeight="18" Foreground="#6B7280"/>
									</StackPanel>
								</Border>
							</StackPanel>

							<!-- TAB 2: Mods -->
							<StackPanel x:Name="PO_TabMods" Classes="POTabContent" IsVisible="False" Spacing="14" Opacity="0">
								<Border x:Name="PO_ModsSupportBanner" Background="#150D25" CornerRadius="12" Padding="14,10">
									<StackPanel Orientation="Horizontal" Spacing="10">
										<TextBlock Text="&#x2713;" Foreground="#B080FF" FontWeight="Bold" FontSize="13"/>
										<TextBlock x:Name="PO_ModsSupportText" Text="This version supports Fabric mods"
												   Foreground="#B080FF" FontSize="12" VerticalAlignment="Center"/>
									</StackPanel>
								</Border>
								<TextBlock Text="Choose a mod configuration. Mods install automatically on first launch."
										   FontSize="12" TextWrapping="Wrap" Foreground="#6B7280" Margin="0,0,0,2"/>

								<!-- Preset: Balanced -->
								<Border x:Name="PO_PresetBalanced" Classes="POPresetCard" CornerRadius="14" Padding="16" Cursor="Hand"
										Tapped="OnPO_PresetTapped" Tag="balanced">
									<StackPanel Spacing="10">
										<Grid ColumnDefinitions="Auto,*">
											<Border Width="42" Height="42" CornerRadius="12" Margin="0,0,14,0">
												<Border.Background>
													<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
														<GradientStop Offset="0" Color="#1A0D2E"/>
														<GradientStop Offset="1" Color="#150D28"/>
													</LinearGradientBrush>
												</Border.Background>
												<TextBlock Text="&#x26A1;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
												<StackPanel Orientation="Horizontal" Spacing="10">
													<TextBlock Text="Balanced" FontWeight="Bold" FontSize="14" Foreground="White"/>
													<Border CornerRadius="6" Padding="8,3">
														<Border.Background>
															<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
																<GradientStop Offset="0" Color="#7C3AED"/>
																<GradientStop Offset="1" Color="#5B21B6"/>
															</LinearGradientBrush>
														</Border.Background>
														<TextBlock Text="Recommended" FontSize="10" Foreground="White" FontWeight="Bold"/>
													</Border>
												</StackPanel>
												<TextBlock Text="Great FPS boost with essential performance mods" FontSize="12" Foreground="#6B7280"/>
											</StackPanel>
										</Grid>
										<WrapPanel x:Name="PO_BadgesBalanced">
											<Border Background="#1E1030" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Fabric API" FontSize="11" Foreground="#C4B5FD"/>
											</Border>
											<Border Background="#1E1030" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Sodium" FontSize="11" Foreground="#C4B5FD"/>
											</Border>
											<Border Background="#1E1030" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Lithium" FontSize="11" Foreground="#C4B5FD"/>
											</Border>
											<Border Background="#1E1030" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Phosphor" FontSize="11" Foreground="#C4B5FD"/>
											</Border>
										</WrapPanel>
									</StackPanel>
								</Border>

								<!-- Preset: Enhanced -->
								<Border x:Name="PO_PresetEnhanced" Classes="POPresetCard" CornerRadius="14" Padding="16" Cursor="Hand"
										Tapped="OnPO_PresetTapped" Tag="enhanced">
									<StackPanel Spacing="10">
										<Grid ColumnDefinitions="Auto,*">
											<Border Width="42" Height="42" CornerRadius="12" Margin="0,0,14,0" Background="#0D1628">
												<TextBlock Text="&#x1F680;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
												<TextBlock Text="Enhanced" FontWeight="Bold" FontSize="14" Foreground="White"/>
												<TextBlock Text="Maximum performance with shaders and extras" FontSize="12" Foreground="#6B7280"/>
											</StackPanel>
										</Grid>
										<WrapPanel x:Name="PO_BadgesEnhanced">
											<Border Background="#0D1628" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Fabric API" FontSize="11" Foreground="#60A5FA"/>
											</Border>
											<Border Background="#0D1628" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Sodium" FontSize="11" Foreground="#60A5FA"/>
											</Border>
											<Border Background="#0D1628" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Lithium" FontSize="11" Foreground="#60A5FA"/>
											</Border>
											<Border Background="#0D1628" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Iris Shaders" FontSize="11" Foreground="#60A5FA"/>
											</Border>
										</WrapPanel>
									</StackPanel>
								</Border>

								<!-- Preset: Lite -->
								<Border x:Name="PO_PresetLite" Classes="POPresetCard" CornerRadius="14" Padding="16" Cursor="Hand"
										Tapped="OnPO_PresetTapped" Tag="lite">
									<StackPanel Spacing="10">
										<Grid ColumnDefinitions="Auto,*">
											<Border Width="42" Height="42" CornerRadius="12" Margin="0,0,14,0" Background="#1A1A0D">
												<TextBlock Text="&#x1F33F;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
												<TextBlock Text="Lite" FontWeight="Bold" FontSize="14" Foreground="White"/>
												<TextBlock Text="Lightweight — ideal for low-end hardware" FontSize="12" Foreground="#6B7280"/>
											</StackPanel>
										</Grid>
										<WrapPanel x:Name="PO_BadgesLite">
											<Border Background="#1A1A0D" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Fabric API" FontSize="11" Foreground="#FACC15"/>
											</Border>
											<Border Background="#1A1A0D" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Sodium" FontSize="11" Foreground="#FACC15"/>
											</Border>
											<Border Background="#1A1A0D" CornerRadius="6" Padding="10,4" Margin="0,0,6,4">
												<TextBlock Text="Lithium" FontSize="11" Foreground="#FACC15"/>
											</Border>
										</WrapPanel>
									</StackPanel>
								</Border>
							</StackPanel>

							<!-- TAB 3: Advanced per-profile override fields -->
							<StackPanel x:Name="PO_TabAdvanced" Classes="POTabContent" IsVisible="False" Spacing="16" Opacity="0">
								<TextBlock Text="Per-profile overrides. Leave fields blank to inherit from global settings."
										   FontSize="12" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,2"/>
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="10">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x1F4CA;" FontSize="12"/>
											<TextBlock Text="PROFILE STATS" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
										</StackPanel>
										<Grid ColumnDefinitions="*,*,*">
											<StackPanel Grid.Column="0" Spacing="2">
												<TextBlock x:Name="PO_StatLaunches" Text="0" Foreground="White" FontSize="18" FontWeight="Black"/>
												<TextBlock Text="Launches" Foreground="#6B7280" FontSize="10"/>
											</StackPanel>
											<StackPanel Grid.Column="1" Spacing="2">
												<TextBlock x:Name="PO_StatPlaytime" Text="0m" Foreground="White" FontSize="18" FontWeight="Black"/>
												<TextBlock Text="Playtime" Foreground="#6B7280" FontSize="10"/>
											</StackPanel>
											<StackPanel Grid.Column="2" Spacing="2">
												<TextBlock x:Name="PO_StatLastUsed" Text="-" Foreground="White" FontSize="14" FontWeight="Bold"/>
												<TextBlock Text="Last used" Foreground="#6B7280" FontSize="10"/>
											</StackPanel>
										</Grid>
									</StackPanel>
								</Border>
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="12">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x1F4DD;" FontSize="12"/>
											<TextBlock Text="DESCRIPTION &amp; ICON" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
										</StackPanel>
										<TextBox x:Name="PO_DescriptionBox" Watermark="A short note about this profile..."
												 Background="#0F1A24" Foreground="White" CornerRadius="10" Padding="14,10" FontSize="13"
												 BorderBrush="#1C2A38" BorderThickness="1.5"/>
										<Grid ColumnDefinitions="Auto,*">
											<TextBlock Grid.Column="0" Text="Icon emoji:" Foreground="#9CA3AF" FontSize="12"
													   VerticalAlignment="Center" Margin="0,0,10,0"/>
											<TextBox Grid.Column="1" x:Name="PO_IconEmojiBox" Watermark="e.g. emoji glyph"
													 Background="#0F1A24" Foreground="White" CornerRadius="10" Padding="14,10" FontSize="14"
													 BorderBrush="#1C2A38" BorderThickness="1.5" MaxLength="4"/>
										</Grid>
									</StackPanel>
								</Border>
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="12">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x1F527;" FontSize="12"/>
											<TextBlock Text="JVM ARGS OVERRIDE" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
										</StackPanel>
										<TextBox x:Name="PO_JvmArgsBox" Watermark="e.g. -XX:+UseG1GC -Xms2G"
												 Background="#0F1A24" Foreground="White" CornerRadius="10" Padding="14,10" FontSize="12"
												 BorderBrush="#1C2A38" BorderThickness="1.5" FontFamily="Consolas,monospace"
												 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="64"/>
										<TextBlock Text="Space-separated. Appended after the global JVM args at launch."
												   FontSize="10" Foreground="#4B5563"/>
									</StackPanel>
								</Border>
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="12">
										<Grid ColumnDefinitions="*,Auto">
											<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
												<TextBlock Text="&#x1F5A5;" FontSize="12"/>
												<TextBlock Text="CUSTOM RESOLUTION" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
											</StackPanel>
											<ToggleSwitch Grid.Column="1" x:Name="PO_UseCustomResolutionToggle" OffContent="" OnContent=""/>
										</Grid>
										<Grid ColumnDefinitions="*,Auto,*">
											<TextBox Grid.Column="0" x:Name="PO_ResWidthBox" Watermark="Width"
													 Background="#0F1A24" Foreground="White" CornerRadius="10" Padding="14,10" FontSize="13"
													 BorderBrush="#1C2A38" BorderThickness="1.5"/>
											<TextBlock Grid.Column="1" Text="x" Foreground="#6B7280" FontSize="16" FontWeight="Bold"
													   VerticalAlignment="Center" Margin="10,0"/>
											<TextBox Grid.Column="2" x:Name="PO_ResHeightBox" Watermark="Height"
													 Background="#0F1A24" Foreground="White" CornerRadius="10" Padding="14,10" FontSize="13"
													 BorderBrush="#1C2A38" BorderThickness="1.5"/>
										</Grid>
									</StackPanel>
								</Border>
								<Border Background="#0C1620" CornerRadius="16" Padding="20,16" BorderBrush="#152030" BorderThickness="1">
									<StackPanel Spacing="12">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x1F310;" FontSize="12"/>
											<TextBlock Text="AUTO-JOIN SERVER" FontSize="11" FontWeight="Bold" Foreground="#6B7280" LetterSpacing="1.2"/>
										</StackPanel>
										<Grid ColumnDefinitions="*,Auto">
											<TextBox Grid.Column="0" x:Name="PO_QuickJoinAddressBox" Watermark="play.example.com"
													 Background="#0F1A24" Foreground="White" CornerRadius="10" Padding="14,10" FontSize="13"
													 BorderBrush="#1C2A38" BorderThickness="1.5"/>
											<TextBox Grid.Column="1" x:Name="PO_QuickJoinPortBox" Watermark="25565" Width="90"
													 Background="#0F1A24" Foreground="White" CornerRadius="10" Padding="14,10" FontSize="13"
													 BorderBrush="#1C2A38" BorderThickness="1.5" Margin="10,0,0,0"/>
										</Grid>
										<TextBlock Text="When set, the profile auto-connects to this server on launch."
												   FontSize="10" Foreground="#4B5563"/>
									</StackPanel>
								</Border>

							</StackPanel>
						</Grid>
					</ScrollViewer>
				</Grid>

				<!-- ══ FOOTER ══ -->
				<Border Grid.Row="2" Padding="24,12,24,14" BorderBrush="#12FFFFFF" BorderThickness="0,1,0,0">
					<Grid ColumnDefinitions="*,Auto,Auto">
						<Button Grid.Column="1" Content="Cancel" Click="OnProfileOverlayCancel"
								Background="Transparent" Foreground="#9CA3AF"
								BorderThickness="0" Padding="22,11" Cursor="Hand"
								FontWeight="SemiBold" CornerRadius="10" Margin="0,0,10,0">
							<Button.Styles>
								<Style Selector="Button:pointerover /template/ ContentPresenter">
									<Setter Property="Background" Value="#0AFFFFFF"/>
								</Style>
								<Style Selector="Button /template/ ContentPresenter">
									<Setter Property="Transitions">
										<Transitions><BrushTransition Property="Background" Duration="0:0:0.15"/></Transitions>
									</Setter>
								</Style>
							</Button.Styles>
						</Button>
						<Button Grid.Column="2" x:Name="PO_SaveButton" Click="OnProfileOverlaySave"
								Foreground="White" FontWeight="Bold" FontSize="14"
								BorderThickness="0" Cursor="Hand" Padding="28,12" CornerRadius="12">
							<Button.Background>
								<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
									<GradientStop Offset="0" Color="#7C3AED"/>
									<GradientStop Offset="1" Color="#5B21B6"/>
								</LinearGradientBrush>
							</Button.Background>
							<Button.Styles>
								<Style Selector="Button:pointerover">
									<Setter Property="Opacity" Value="0.9"/>
								</Style>
							</Button.Styles>
							<StackPanel Orientation="Horizontal" Spacing="8">
								<TextBlock Text="&#x1F4BE;" FontSize="13"/>
								<TextBlock Text="Save Profile"/>
							</StackPanel>
						</Button>
					</Grid>
				</Border>

			</Grid>
		</Border>
	</Grid>

	<!-- Checkout Overlay -->
	<Grid x:Name="CheckoutOverlay" IsVisible="False" ZIndex="3000">
		<Border Background="#80000000" x:Name="CheckoutBackdrop" Tapped="OnCheckoutBackdropTapped"/>
		<Border x:Name="CheckoutPanel"
				Width="660"
				VerticalAlignment="Stretch" HorizontalAlignment="Center"
				Margin="0,30,0,0"
				CornerRadius="20,20,0,0"
				ClipToBounds="True"
				BorderBrush="#1E3A4A" BorderThickness="1,1,1,0">
			<Border.Background>
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
					<GradientStop Offset="0" Color="#0f1820"/>
					<GradientStop Offset="1" Color="#090e15"/>
				</LinearGradientBrush>
			</Border.Background>
			<Border.RenderTransform>
				<TranslateTransform Y="900"/>
			</Border.RenderTransform>
			<Grid RowDefinitions="Auto,*">
				<!-- Header -->
				<Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="28,22,20,16">
					<StackPanel Spacing="3">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<Border Width="3" CornerRadius="2">
								<Border.Background>
									<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
										<GradientStop Offset="0" Color="#4CAF50"/>
										<GradientStop Offset="1" Color="#2e7d32"/>
									</LinearGradientBrush>
								</Border.Background>
							</Border>
							<TextBlock Text="CHECKOUT" FontWeight="Black" FontSize="18"
									   Foreground="#E5E7EB" LetterSpacing="1.5" VerticalAlignment="Center"/>
						</StackPanel>
					</StackPanel>
					<Border Grid.Column="1" Background="#0F1A24" BorderBrush="#1C2A38" BorderThickness="1"
							CornerRadius="10" Width="32" Height="32"
							Cursor="Hand" Tapped="OnCheckoutClose" VerticalAlignment="Top">
						<TextBlock Text="✕" Foreground="#9CA3AF" FontSize="13" FontWeight="Bold"
								   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
				</Grid>
				<WebView x:Name="CheckoutWebView" Grid.Row="1"
						 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
				<TextBlock x:Name="CheckoutUnsupportedLabel" Grid.Row="1"
						   IsVisible="False"
						   HorizontalAlignment="Center" VerticalAlignment="Center"
						   Margin="20" TextAlignment="Center" TextWrapping="Wrap"
						   Foreground="#CCCCCC" FontSize="14"
						   Text="Checkout is not supported on this platform. Please open the checkout page in your browser."/>
			</Grid>
		</Border>
	</Grid>

	<!-- Monthly Pass Rewards Popup -->
	<Grid x:Name="MonthlyPassOverlay" IsVisible="False" ZIndex="4500">
		<!-- Blurred backdrop -->
		<Border x:Name="MonthlyPassBackdrop" Background="#B3000000" Tapped="OnMonthlyPassBackdropTapped"/>
		<Border x:Name="MonthlyPassPanel"
				Width="720" MaxHeight="680" Margin="0,24"
				HorizontalAlignment="Center" VerticalAlignment="Center"
				CornerRadius="22" ClipToBounds="True"
				BorderBrush="#3D2080" BorderThickness="1">
			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#16082E" Offset="0"/>
					<GradientStop Color="#0D1428" Offset="0.6"/>
					<GradientStop Color="#0A1020" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
			<Border.RenderTransform>
				<ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
			</Border.RenderTransform>
			<Grid RowDefinitions="Auto,*,Auto">
				<!-- Header -->
				<Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="32,26,24,8">
					<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
						<TextBlock Text="✦" Foreground="#C4B5FD" FontSize="20" VerticalAlignment="Center"/>
						<TextBlock Text="LEAF+" Foreground="White"
								   FontSize="20" FontWeight="Black" LetterSpacing="1.6"
								   VerticalAlignment="Center"/>
					</StackPanel>
					<Border Grid.Column="1" Width="32" Height="32" CornerRadius="10"
							Background="#0F1A24" BorderBrush="#1C2A38" BorderThickness="1"
							Cursor="Hand" Tapped="OnMonthlyPassClose" VerticalAlignment="Top">
						<TextBlock Text="✕" Foreground="#9CA3AF" FontSize="13" FontWeight="Bold"
								   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
				</Grid>

				<!-- Perks -->
				<ScrollViewer Grid.Row="1"
							  HorizontalScrollBarVisibility="Disabled"
							  VerticalScrollBarVisibility="Auto" Padding="32,8,32,8">
					<StackPanel Spacing="14" Width="640" HorizontalAlignment="Left">
						<TextBlock Text="What you get every month"
								   Foreground="#C4B5FD" FontSize="12"
								   FontWeight="SemiBold" LetterSpacing="1.2"/>
						<TextBlock Text="A monthly drop of new cosmetics and perks — a steady stream of fresh content without grinding or paying piece by piece."
								   Foreground="#A9A4C9" FontSize="13" TextWrapping="Wrap"/>

						<!-- Perk cards -->
						<Border CornerRadius="14" Background="#14102E" BorderBrush="#3D2080"
								BorderThickness="1" Padding="18,14">
							<Grid ColumnDefinitions="Auto,*">
								<Border Width="44" Height="44" CornerRadius="22" VerticalAlignment="Center" Margin="0,0,14,0">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#A855F7" Offset="0"/>
											<GradientStop Color="#7C3AED" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
									<Path Data="M12,2 L14,9 L21,12 L14,15 L12,22 L10,15 L3,12 L10,9 Z" Fill="White" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<StackPanel Grid.Column="1" Spacing="3">
									<TextBlock Text="Monthly cosmetic drop" Foreground="White"
											   FontWeight="Bold" FontSize="14"/>
									<TextBlock Text="A curated batch of that month's new cosmetics — roughly 80% of each month's releases, delivered straight to your account."
											   Foreground="#8B85AD" FontSize="12" TextWrapping="Wrap"/>
								</StackPanel>
							</Grid>
						</Border>

						<Border CornerRadius="14" Background="#14102E" BorderBrush="#3D2080"
								BorderThickness="1" Padding="18,14">
							<Grid ColumnDefinitions="Auto,*">
								<Border Width="44" Height="44" CornerRadius="22" VerticalAlignment="Center" Margin="0,0,14,0">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#22D3EE" Offset="0"/>
											<GradientStop Color="#0891B2" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
									<Path Data="M12,8 C14.2,8 16,9.8 16,12 C16,14.2 14.2,16 12,16 C9.8,16 8,14.2 8,12 C8,9.8 9.8,8 12,8 Z M19.4,13 C19.5,12.7 19.5,12.3 19.5,12 C19.5,11.7 19.5,11.3 19.4,11 L21,9.8 L19.5,7.2 L17.6,7.9 C17.2,7.6 16.7,7.3 16.2,7.1 L15.9,5 L12.9,5 L12.6,7.1 C12.1,7.3 11.6,7.6 11.2,7.9 L9.3,7.2 L7.8,9.8 L9.4,11 C9.3,11.3 9.3,11.7 9.3,12 C9.3,12.3 9.3,12.7 9.4,13 L7.8,14.2 L9.3,16.8 L11.2,16.1 C11.6,16.4 12.1,16.7 12.6,16.9 L12.9,19 L15.9,19 L16.2,16.9 C16.7,16.7 17.2,16.4 17.6,16.1 L19.5,16.8 L21,14.2 Z" Fill="White" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<StackPanel Grid.Column="1" Spacing="3">
									<TextBlock Text="In-game benefits" Foreground="White"
											   FontWeight="Bold" FontSize="14"/>
									<TextBlock Text="Exclusive Leaf Client mods, quality-of-life tweaks and performance presets only available to subscribers."
											   Foreground="#8B85AD" FontSize="12" TextWrapping="Wrap"/>
								</StackPanel>
							</Grid>
						</Border>

						<Border CornerRadius="14" Background="#14102E" BorderBrush="#3D2080"
								BorderThickness="1" Padding="18,14">
							<Grid ColumnDefinitions="Auto,*">
								<Border Width="44" Height="44" CornerRadius="22" VerticalAlignment="Center" Margin="0,0,14,0">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#F97316" Offset="0"/>
											<GradientStop Color="#DC2626" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
									<Path Data="M13,2 L4,13 L11,13 L11,22 L20,11 L13,11 Z" Fill="White" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<StackPanel Grid.Column="1" Spacing="3">
									<TextBlock Text="Early access to new features" Foreground="White"
											   FontWeight="Bold" FontSize="14"/>
									<TextBlock Text="Try new mods, cosmetics and launcher features weeks before anyone else."
											   Foreground="#8B85AD" FontSize="12" TextWrapping="Wrap"/>
								</StackPanel>
							</Grid>
						</Border>

						<Border CornerRadius="14" Background="#14102E" BorderBrush="#3D2080"
								BorderThickness="1" Padding="18,14">
							<Grid ColumnDefinitions="Auto,*">
								<Border Width="44" Height="44" CornerRadius="22" VerticalAlignment="Center" Margin="0,0,14,0">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#34D399" Offset="0"/>
											<GradientStop Color="#059669" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
									<Path Data="M20.5,11.5 L12.5,3.5 C12.1,3.1 11.6,3 11,3 L4,3 C2.9,3 2,3.9 2,5 L2,12 C2,12.6 2.2,13.1 2.6,13.5 L10.6,21.5 C11,21.9 11.5,22 12,22 C12.5,22 13,21.9 13.4,21.5 L20.5,14.5 C20.9,14.1 21,13.5 21,13 C21,12.5 20.9,11.9 20.5,11.5 Z M6.5,8 C5.7,8 5,7.3 5,6.5 C5,5.7 5.7,5 6.5,5 C7.3,5 8,5.7 8,6.5 C8,7.3 7.3,8 6.5,8 Z" Fill="White" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<StackPanel Grid.Column="1" Spacing="3">
									<TextBlock Text="Custom in-game tag" Foreground="White"
											   FontWeight="Bold" FontSize="14"/>
									<TextBlock Text="A unique colored tag shown next to your name on Leaf Client-enabled servers."
											   Foreground="#8B85AD" FontSize="12" TextWrapping="Wrap"/>
								</StackPanel>
							</Grid>
						</Border>

						<Border CornerRadius="14" Background="#14102E" BorderBrush="#3D2080"
								BorderThickness="1" Padding="18,14">
							<Grid ColumnDefinitions="Auto,*">
								<Border Width="44" Height="44" CornerRadius="22" VerticalAlignment="Center" Margin="0,0,14,0">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#F472B6" Offset="0"/>
											<GradientStop Color="#DB2777" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
									<Path Data="M6,2 L18,2 L22,8 L12,22 L2,8 Z" Fill="White" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<StackPanel Grid.Column="1" Spacing="3">
									<TextBlock Text="Priority support" Foreground="White"
											   FontWeight="Bold" FontSize="14"/>
									<TextBlock Text="Subscriber questions jump to the top of our support queue."
											   Foreground="#8B85AD" FontSize="12" TextWrapping="Wrap"/>
								</StackPanel>
							</Grid>
						</Border>
					</StackPanel>
				</ScrollViewer>

				<!-- Footer — tier selector + subscribe CTA -->
				<Border Grid.Row="2" Background="#070B18" BorderBrush="#1C2A38"
						BorderThickness="0,1,0,0" Padding="24,14,24,14">
					<StackPanel Spacing="12">
						<!-- Three billing tiers -->
						<Grid ColumnDefinitions="*,10,*,10,*">
							<!-- Monthly -->
							<Border Grid.Column="0" x:Name="LeafPlusTier_Monthly" Tag="monthly"
									CornerRadius="12" Padding="12,10" Cursor="Hand"
									Background="#1A1E44" BorderBrush="#7C3AED" BorderThickness="1.5"
									Tapped="OnLeafPlusTierTapped">
								<StackPanel Spacing="3">
									<TextBlock Text="MONTHLY" Foreground="#C4B5FD"
											   FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
									<StackPanel Orientation="Horizontal" Spacing="3">
										<TextBlock x:Name="LeafPlusMonthlyPrice" Text="€4.99" Foreground="White"
												   FontWeight="Black" FontSize="19"/>
										<TextBlock Text="/mo" Foreground="#7C6FAA" FontSize="10"
												   VerticalAlignment="Bottom" Margin="0,0,0,3"/>
									</StackPanel>
									<TextBlock Text="Billed monthly" Foreground="#7C6FAA" FontSize="10"/>
									<StackPanel Orientation="Horizontal" Spacing="3" Margin="0,2,0,0">
										<TextBlock Text="🍃" FontSize="9" VerticalAlignment="Center"/>
										<TextBlock x:Name="LeafPlusMonthlyCoins" Text="500 Leaf Points"
												   Foreground="#4ADE80" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
									</StackPanel>
								</StackPanel>
							</Border>

							<!-- Quarterly -->
							<Border Grid.Column="2" x:Name="LeafPlusTier_Quarterly" Tag="quarterly"
									CornerRadius="12" Padding="12,10" Cursor="Hand"
									Background="#0F1A24" BorderBrush="#1C2A38" BorderThickness="1"
									Tapped="OnLeafPlusTierTapped">
								<StackPanel Spacing="3">
									<Grid ColumnDefinitions="*,Auto">
										<TextBlock Grid.Column="0" Text="QUARTERLY" Foreground="#9CA3AF"
												   FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
										<Border Grid.Column="1" CornerRadius="4" Padding="4,1"
												Background="#1A4C96">
											<TextBlock Text="-7%" Foreground="#93C5FD" FontSize="8" FontWeight="Black"/>
										</Border>
									</Grid>
									<StackPanel Orientation="Horizontal" Spacing="3">
										<TextBlock x:Name="LeafPlusQuarterlyPrice" Text="€13.99" Foreground="White"
												   FontWeight="Black" FontSize="19"/>
										<TextBlock Text="/3mo" Foreground="#7C6FAA" FontSize="10"
												   VerticalAlignment="Bottom" Margin="0,0,0,3"/>
									</StackPanel>
									<TextBlock x:Name="LeafPlusQuarterlySave" Text="Save €0.98" Foreground="#7C6FAA" FontSize="10"/>
									<StackPanel Orientation="Horizontal" Spacing="3" Margin="0,2,0,0">
										<TextBlock Text="🍃" FontSize="9" VerticalAlignment="Center"/>
										<TextBlock x:Name="LeafPlusQuarterlyCoins" Text="1,400 Leaf Points"
												   Foreground="#4ADE80" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
									</StackPanel>
								</StackPanel>
							</Border>

							<!-- Yearly -->
							<Border Grid.Column="4" x:Name="LeafPlusTier_Yearly" Tag="yearly"
									CornerRadius="12" Padding="12,10" Cursor="Hand"
									Background="#0F1A24" BorderBrush="#1C2A38" BorderThickness="1"
									Tapped="OnLeafPlusTierTapped">
								<StackPanel Spacing="3">
									<Grid ColumnDefinitions="*,Auto">
										<TextBlock Grid.Column="0" Text="YEARLY" Foreground="#9CA3AF"
												   FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
										<Border Grid.Column="1" CornerRadius="4" Padding="5,1"
												Background="#7C3AED">
											<TextBlock Text="BEST VALUE" Foreground="White" FontSize="7" FontWeight="Black" LetterSpacing="0.5"/>
										</Border>
									</Grid>
									<StackPanel Orientation="Horizontal" Spacing="3">
										<TextBlock x:Name="LeafPlusYearlyPrice" Text="€49.99" Foreground="White"
												   FontWeight="Black" FontSize="19"/>
										<TextBlock Text="/yr" Foreground="#7C6FAA" FontSize="10"
												   VerticalAlignment="Bottom" Margin="0,0,0,3"/>
									</StackPanel>
									<TextBlock x:Name="LeafPlusYearlySave" Text="Save €9.89" Foreground="#A78BFA" FontSize="10" FontWeight="Bold"/>
									<StackPanel Orientation="Horizontal" Spacing="3" Margin="0,2,0,0">
										<TextBlock Text="🍃" FontSize="9" VerticalAlignment="Center"/>
										<TextBlock x:Name="LeafPlusYearlyCoins" Text="5,000 Leaf Points"
												   Foreground="#4ADE80" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
									</StackPanel>
								</StackPanel>
							</Border>
						</Grid>

						<!-- Subscribe CTA -->
						<Grid ColumnDefinitions="*,Auto">
							<TextBlock Grid.Column="0" Text="Cancel anytime. No hidden fees."
									   Foreground="#7C6FAA" FontSize="11" VerticalAlignment="Center"/>
							<Button Grid.Column="1" Classes="ColorBtn" CornerRadius="12" Padding="26,13,26,11"
									BorderThickness="0" Tapped="OnMonthlyPassSubscribeTapped">
								<Button.Background>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="#7C3AED" Offset="0"/>
										<GradientStop Color="#4F46E5" Offset="1"/>
									</LinearGradientBrush>
								</Button.Background>
								<TextBlock Text="SUBSCRIBE NOW" Foreground="White"
										   FontWeight="ExtraBold" FontSize="12" LetterSpacing="1.3"
										   VerticalAlignment="Center" HorizontalAlignment="Center"
										   Margin="0,2,0,0"/>
							</Button>
						</Grid>
					</StackPanel>
				</Border>
			</Grid>
		</Border>
	</Grid>

	<!-- Leaf+ Payment Method Choice Overlay -->
	<Grid x:Name="LeafPlusPaymentOverlay" IsVisible="False" ZIndex="4600">
		<Border x:Name="LeafPlusPaymentBackdrop" Background="#B3000000" Tapped="OnLeafPlusPaymentBackdropTapped"/>
		<Border x:Name="LeafPlusPaymentPanel"
				Width="440"
				HorizontalAlignment="Center" VerticalAlignment="Center"
				CornerRadius="22" ClipToBounds="True"
				BorderBrush="#3D2080" BorderThickness="1">
			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#16082E" Offset="0"/>
					<GradientStop Color="#0D1428" Offset="0.6"/>
					<GradientStop Color="#0A1020" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
			<Border.RenderTransform>
				<ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
			</Border.RenderTransform>
			<StackPanel Spacing="0">
				<!-- Header -->
				<Grid ColumnDefinitions="*,Auto" Margin="28,24,20,20">
					<StackPanel Spacing="4">
						<TextBlock Text="How would you like to pay?"
								   Foreground="White" FontWeight="Black" FontSize="17"/>
						<TextBlock x:Name="LeafPlusPaymentTierLabel" Text="Leaf+ Monthly"
								   Foreground="#7C6FAA" FontSize="12"/>
					</StackPanel>
					<Border Grid.Column="1" Width="30" Height="30" CornerRadius="9"
							Background="#0F1A24" BorderBrush="#1C2A38" BorderThickness="1"
							Cursor="Hand" Tapped="OnLeafPlusPaymentClose" VerticalAlignment="Top">
						<TextBlock Text="✕" Foreground="#9CA3AF" FontSize="12" FontWeight="Bold"
								   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
				</Grid>

				<!-- Options -->
				<StackPanel Spacing="10" Margin="20,0,20,24">
					<!-- Leaf Points Option -->
					<Border x:Name="LeafPointsPayOption"
							CornerRadius="16" Padding="18,16" Cursor="Hand"
							BorderThickness="1.5" Tapped="OnLeafPlusPayWithPoints">
						<Border.Background>
							<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
								<GradientStop Color="#0D1E12" Offset="0"/>
								<GradientStop Color="#0A1A10" Offset="1"/>
							</LinearGradientBrush>
						</Border.Background>
						<Border.BorderBrush>
							<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
								<GradientStop Color="#22C55E" Offset="0"/>
								<GradientStop Color="#16A34A" Offset="1"/>
							</LinearGradientBrush>
						</Border.BorderBrush>
						<Grid ColumnDefinitions="Auto,*,Auto">
							<!-- Icon -->
							<Border Width="44" Height="44" CornerRadius="22" VerticalAlignment="Center" Margin="0,0,14,0">
								<Border.Background>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="#22C55E" Offset="0"/>
										<GradientStop Color="#16A34A" Offset="1"/>
									</LinearGradientBrush>
								</Border.Background>
								<TextBlock Text="🍃" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</Border>
							<!-- Text -->
							<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
								<TextBlock Text="Use Leaf Points" Foreground="White" FontWeight="Bold" FontSize="14"/>
								<StackPanel Orientation="Horizontal" Spacing="5">
									<TextBlock x:Name="LeafPointsPayCost" Text="500 🍃"
											   Foreground="#4ADE80" FontWeight="Black" FontSize="16"/>
									<TextBlock x:Name="LeafPointsPayBalance" Text="(you have 0)"
											   Foreground="#7C6FAA" FontSize="11" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
								</StackPanel>
							</StackPanel>
							<!-- Arrow -->
							<TextBlock Grid.Column="2" Text="›" Foreground="#4ADE80" FontSize="22"
									   VerticalAlignment="Center" Margin="10,0,0,0"/>
						</Grid>
					</Border>

					<!-- Card / PayPal Option -->
					<Border CornerRadius="16" Padding="18,16" Cursor="Hand"
							BorderThickness="1.5" Tapped="OnLeafPlusPayWithCard">
						<Border.Background>
							<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
								<GradientStop Color="#0F1020" Offset="0"/>
								<GradientStop Color="#0A0C1C" Offset="1"/>
							</LinearGradientBrush>
						</Border.Background>
						<Border.BorderBrush>
							<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
								<GradientStop Color="#7C3AED" Offset="0"/>
								<GradientStop Color="#4F46E5" Offset="1"/>
							</LinearGradientBrush>
						</Border.BorderBrush>
						<Grid ColumnDefinitions="Auto,*,Auto">
							<!-- Icon -->
							<Border Width="44" Height="44" CornerRadius="22" VerticalAlignment="Center" Margin="0,0,14,0">
								<Border.Background>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="#7C3AED" Offset="0"/>
										<GradientStop Color="#4F46E5" Offset="1"/>
									</LinearGradientBrush>
								</Border.Background>
								<TextBlock Text="💳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</Border>
							<!-- Text -->
							<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
								<TextBlock Text="Pay with Card / PayPal" Foreground="White" FontWeight="Bold" FontSize="14"/>
								<TextBlock x:Name="LeafCardPayPrice" Text="€4.99/month"
										   Foreground="#A78BFA" FontSize="12"/>
							</StackPanel>
							<!-- Arrow -->
							<TextBlock Grid.Column="2" Text="›" Foreground="#A78BFA" FontSize="22"
									   VerticalAlignment="Center" Margin="10,0,0,0"/>
						</Grid>
					</Border>
				</StackPanel>
			</StackPanel>
		</Border>
	</Grid>

	<!-- Purchase Celebration Overlay -->
	<Grid x:Name="CelebrationOverlay" IsVisible="False" ZIndex="5000">
		<Border Background="#D9000000" Tapped="OnCelebrationBackdropTapped"/>
		<Border x:Name="CelebPanel"
				Width="420"
				CornerRadius="28"
				BorderBrush="#33FFFFFF" BorderThickness="1"
				HorizontalAlignment="Center" VerticalAlignment="Center"
				Padding="0,0,0,32">
			<Border.Background>
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
					<GradientStop Offset="0" Color="#1C1C2E"/>
					<GradientStop Offset="1" Color="#0D0D14"/>
				</LinearGradientBrush>
			</Border.Background>
			<StackPanel Spacing="0">
				<!-- Top label -->
				<Border x:Name="CelebUnlockedBanner"
						CornerRadius="28,28,0,0"
						Padding="0,14,0,14"
						HorizontalAlignment="Stretch"
						Opacity="0">
					<Border.Background>
						<LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
							<GradientStop Offset="0"   Color="#00000000"/>
							<GradientStop Offset="0.3" Color="#40FFFFFF"/>
							<GradientStop Offset="0.7" Color="#40FFFFFF"/>
							<GradientStop Offset="1"   Color="#00000000"/>
						</LinearGradientBrush>
					</Border.Background>
					<TextBlock Text="✦  NEW COSMETIC UNLOCKED  ✦"
							   Foreground="White" FontSize="11"
							   FontWeight="ExtraBold" LetterSpacing="2"
							   HorizontalAlignment="Center"/>
				</Border>

				<!-- Icon area -->
				<Grid HorizontalAlignment="Center" Margin="0,28,0,20">
					<!-- Outer glow ring -->
					<Ellipse x:Name="CelebGlowRingOuter"
							 Width="200" Height="200"
							 StrokeThickness="1"
							 Stroke="#20FFFFFF"
							 IsVisible="False" Opacity="0"/>
					<!-- Main glow ring -->
					<Ellipse x:Name="CelebGlowRing"
							 Width="160" Height="160"
							 StrokeThickness="2.5"
							 Stroke="#4ADE80"
							 IsVisible="False" Opacity="0"/>
					<!-- Inner fill circle -->
					<Ellipse x:Name="CelebGlowFill"
							 Width="140" Height="140"
							 IsVisible="False" Opacity="0">
						<Ellipse.Fill>
							<RadialGradientBrush>
								<GradientStop Offset="0"   Color="#304ADE80"/>
								<GradientStop Offset="1"   Color="#00000000"/>
							</RadialGradientBrush>
						</Ellipse.Fill>
					</Ellipse>
					<TextBlock x:Name="CelebGiftIcon"
							   Text="🎁" FontSize="90"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center"/>
					<Border x:Name="CelebItemRendererHost"
							 Width="160" Height="200"
							 Background="Transparent"
							 HorizontalAlignment="Center"
							 VerticalAlignment="Center"
							 Margin="0,-60,0,0"
							 IsVisible="False" Opacity="0"/>
				</Grid>

				<!-- Result panel -->
				<StackPanel x:Name="CelebResultPanel"
							Spacing="10" Margin="36,0,36,0"
							HorizontalAlignment="Center"
							IsVisible="False" Opacity="0">
					<TextBlock Text="YOU GOT"
							   Foreground="#60FFFFFF" FontSize="11"
							   FontWeight="ExtraBold" LetterSpacing="3"
							   HorizontalAlignment="Center"/>
					<TextBlock x:Name="CelebItemName"
							   Text="" FontSize="26" FontWeight="Black"
							   HorizontalAlignment="Center"
							   TextAlignment="Center"
							   TextWrapping="Wrap"/>
					<Border x:Name="CelebRarityBadge"
							CornerRadius="20" Padding="16,5"
							HorizontalAlignment="Center"
							BorderThickness="1">
						<TextBlock x:Name="CelebRarityText"
								   Text="" FontSize="9"
								   FontWeight="ExtraBold" LetterSpacing="2"/>
					</Border>
					<Border Height="1" Margin="0,4,0,4">
						<Border.Background>
							<LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
								<GradientStop Offset="0"   Color="#00FFFFFF"/>
								<GradientStop Offset="0.5" Color="#22FFFFFF"/>
								<GradientStop Offset="1"   Color="#00FFFFFF"/>
							</LinearGradientBrush>
						</Border.Background>
					</Border>
					<Border x:Name="CelebEquipBtn"
							Background="#224ADE80" BorderBrush="#4ADE80" BorderThickness="1"
							CornerRadius="12" Height="44"
							Cursor="Hand" Tapped="OnCelebEquipNow">
						<TextBlock Text="EQUIP NOW →" Foreground="#4ADE80"
								   FontSize="12" FontWeight="ExtraBold"
								   HorizontalAlignment="Center" VerticalAlignment="Center"
								   LetterSpacing="1"/>
					</Border>
					<TextBlock Text="Skip" Foreground="#44FFFFFF"
							   FontSize="11" HorizontalAlignment="Center"
							   Cursor="Hand" Tapped="OnCelebClose"
							   Margin="0,2,0,0"/>
				</StackPanel>
			</StackPanel>
		</Border>
	</Grid>

	<!-- TNT Celebration Animation Overlay -->
	<Grid x:Name="TntAnimOverlay" IsVisible="False" ZIndex="4000">
		<!-- Dark backdrop -->
		<Rectangle x:Name="TntBackdrop" Fill="#CC000000" Opacity="0"/>
		<!-- Full-screen white flash (explosion moment only) -->
		<Rectangle x:Name="TntWhiteFlash" Fill="White" Opacity="0" IsHitTestVisible="False"/>
		<!-- Particle canvas -->
		<Canvas x:Name="TntParticleCanvas" IsHitTestVisible="False"/>
		<!-- Centered TNT group: glow behind block + block + per-block flash overlay -->
		<Grid x:Name="TntBlockGroup"
			  Width="260" Height="260"
			  HorizontalAlignment="Center"
			  VerticalAlignment="Center"
			  IsHitTestVisible="False">
			<!-- Radial glow around the block (color set at runtime per preset) -->
			<Ellipse x:Name="TntGlow"
					 Width="340" Height="340"
					 Opacity="0"
					 IsHitTestVisible="False">
				<Ellipse.Fill>
					<RadialGradientBrush>
						<GradientStop Offset="0"   Color="#DDFF9900"/>
						<GradientStop Offset="0.45" Color="#88FF5500"/>
						<GradientStop Offset="1"   Color="#00000000"/>
					</RadialGradientBrush>
				</Ellipse.Fill>
			</Ellipse>
			<!-- TNT block texture (pixel-perfect) -->
			<Image x:Name="TntBlockImage"
				   Source="/Assets/TNT.png"
				   Width="140" Height="140"
				   HorizontalAlignment="Center"
				   VerticalAlignment="Center"
				   RenderOptions.BitmapInterpolationMode="None"/>
			<!-- White flash overlaid on the TNT block itself (charging effect), masked to TNT shape -->
			<Rectangle x:Name="TntBlockFlash"
					   Width="140" Height="140"
					   HorizontalAlignment="Center"
					   VerticalAlignment="Center"
					   Fill="White" Opacity="0"
					   IsHitTestVisible="False">
				<Rectangle.OpacityMask>
					<ImageBrush Source="/Assets/TNT.png" Stretch="Uniform"/>
				</Rectangle.OpacityMask>
			</Rectangle>
		</Grid>
	</Grid>


	<!-- Toast notification container — ZIndex 6000, bottom-right -->
	<ItemsControl x:Name="ToastContainer" ZIndex="6000"
	              HorizontalAlignment="Right" VerticalAlignment="Bottom"
	              Margin="0,0,24,24" IsHitTestVisible="False">
	    <ItemsControl.ItemsPanel>
	        <ItemsPanelTemplate>
	            <StackPanel Spacing="8" VerticalAlignment="Bottom"/>
	        </ItemsPanelTemplate>
	    </ItemsControl.ItemsPanel>
	</ItemsControl>

	<Border x:Name="OfflineOverlay"
	        IsVisible="False"
	        ZIndex="99999"
	        Background="#F0000000"
	        IsHitTestVisible="True">
		<Grid>
			<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="18" MaxWidth="440">
				<TextBlock Text="📡"
				           HorizontalAlignment="Center"
				           FontSize="68"
				           Opacity="0.85"/>
				<TextBlock Text="No Internet Connection"
				           HorizontalAlignment="Center"
				           FontSize="26"
				           FontWeight="SemiBold"
				           Foreground="White"/>
				<TextBlock Text="Leaf Client needs an active internet connection to continue. Check your network and we'll reconnect automatically."
				           HorizontalAlignment="Center"
				           TextAlignment="Center"
				           FontSize="14"
				           Foreground="#BBFFFFFF"
				           TextWrapping="Wrap"/>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
					<Ellipse x:Name="OfflineSpinnerDot"
					         Width="10" Height="10"
					         Fill="#FF5252"/>
					<TextBlock x:Name="OfflineStatusText"
					           Text="Checking connection…"
					           Foreground="#AAFFFFFF"
					           FontSize="13"
					           VerticalAlignment="Center"/>
				</StackPanel>
				<Button x:Name="OfflineRetryButton"
				        Content="Retry Now"
				        HorizontalAlignment="Center"
				        Padding="22,10"
				        FontSize="14"
				        FontWeight="SemiBold"
				        Background="#3DDC84"
				        Foreground="White"
				        BorderThickness="0"
				        CornerRadius="8"
				        Cursor="Hand"/>
			</StackPanel>
		</Grid>
	</Border>

	</Grid>
	<!-- This closes the MAIN Grid -->
</Window>
